            if (!sATA && !eATA) {
            } else {
                if (!sATA) sATA = `${tRetDate1.substring(0, 6)}01`;
                if (!eATA) eATA = `99999999`;
                sqlATA = `and a3.ata between '${sATA}' and '${eATA}' `;
            }

            var sqlFACIN_DATE = '';
            var sFACIN_DATE = args.data.S_FACIN_DATE;
            var eFACIN_DATE = args.data.E_FACIN_DATE;
