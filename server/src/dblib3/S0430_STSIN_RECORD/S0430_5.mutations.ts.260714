                                )
                        `;
                        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                        tSQLArray.push(tSQL99_1);
                    }

                    if (tInQtyFoc > 0) {
                        if (tInQty > 0) {
                            tInDateTime = String(parseInt(tInDateTime) + 1);
                        }

                        let tSQL99 = `
                            insert into
                                ksv_stock_in (
                                    PO_CD,
                                    PO_SEQ,
                                    ORDER_CD,
                                    MATL_CD,
                                    VENDOR_CD,
                                    MRP_SEQ,
                                    MATL_SEQ,
