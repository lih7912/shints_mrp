        } else if (typeof tTypeVal === "number" && typeof val === "string") {
            _dataEDT_KSV_ORDER_MST1[`${name0}`] = parseInt(val);
        }

        let val1 = (e.value && e.value.SIZE_MEMBER) || "";
        let name1 = "SIZE_MEMBER";
        let tTypeVal1 = _dataEDT_KSV_ORDER_MST1[`${name}`];
        if (typeof tTypeVal1 === "string" && typeof val1 === "string") {
            _dataEDT_KSV_ORDER_MST1[`${name1}`] = String(val1);
        } else if (typeof tTypeVal1 === "number" && typeof val1 === "string") {
            _dataEDT_KSV_ORDER_MST1[`${name1}`] = parseInt(val1);
        }

        setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
        setDataEDT_KSV_ORDER_MST1_SIZE_GROUP(e.value);

        var tSaveObjCols = [];
        datasTBL_KSV_ORDER_MEM_COL.forEach((col, i) => {
            var tObj = { ...col };
            tSaveObjCols.push(tObj);
        });

        var tSizeCols = e.value.SIZE_MEMBER.split(",");

        var tObjCols = [];
        var tIdx = 0;
        var tMax = 0;
        for (tIdx = 0; tIdx < tSizeCols.length; tIdx++) {
            var tObjColOne = {};
            tObjColOne.field_name = tSizeCols[tIdx];
            if (tObjColOne.field_name.length > tMax)
                tMax = tObjColOne.field_name.length;
            tObjColOne.field = "SIZE_COL_" + tSizeCols[tIdx];
            tObjColOne.kind = "EDIT";
            tObjColOne.mid = "N";
            tObjCols.push(tObjColOne);
        }
        setDataEDT_KSV_ORDER_MST1_SIZE_GROUP_MAX(String(tMax));

        setDatasTBL_KSV_ORDER_MEM_COL(tObjCols);
        console.log(
            "Change Size Memember(2): " + tObjCols.length + ", MAX=" + tMax,
        );

        tIdx = 0;
        var wArray = [];
        for (tIdx = 0; tIdx < datasTBL_KSV_ORDER_MST.length; tIdx++) {
            var tOneObj = { ...datasTBL_KSV_ORDER_MST[tIdx] };
            var tOrderMem = [...tOneObj.ORDER_MEM];

            // if (tSaveObjCols.length <= tObjCols.length) {

            var tIdx1 = 0;
            var tNewOrderMem = [];
            for (tIdx1 = 0; tIdx1 < tOrderMem.length; tIdx1++) {
                var tOneOrderMem = { ...tOrderMem[tIdx1] };

                var tWObj = {};
                tWObj.PROD_CD = tOneOrderMem.PROD_CD;
                tWObj.ADD_FLAG = tOneOrderMem.ADD_FLAG;
                tWObj.COLOR = tOneOrderMem.COLOR;
                tWObj.TOT_CNT = tOneOrderMem.TOT_CNT;
                tWObj.PRICE = tOneOrderMem.PRICE;
                tWObj.SIZE_CNT = "";

                if (tSaveObjCols.length <= tObjCols.length) {
                    var tIdx2 = 0;
                    for (tIdx2 = 0; tIdx2 < tObjCols.length; tIdx2++) {
                        if (tIdx2 < tSaveObjCols.length) {
                            var tColObj0 = tSaveObjCols[tIdx2];
                            var tKeyName0 = tColObj0.field;

                            var tColObj1 = tObjCols[tIdx2];
                            var tKeyName1 = tColObj1.field;

                            tWObj[`${tKeyName1}`] =
                                tOneOrderMem[`${tKeyName0}`];
                        } else {
                            var tColObj1 = tObjCols[tIdx2];
                            var tKeyName1 = tColObj1.field;
                            tWObj[`${tKeyName1}`] = "0";
                        }
                    }
                    tNewOrderMem.push(tWObj);
                } else {
                    var tOverQty = 0;
                    tSaveObjCols.forEach((col, i) => {
                        if (i >= tObjCols.length) {
                            var tKeyName = col.field;
                            tOverQty += parseInt(tOneOrderMem[`${tKeyName}`]);
                        }
                    });
                    var tIdx2 = 0;
                    for (tIdx2 = 0; tIdx2 < tObjCols.length; tIdx2++) {
                        var tColObj0 = tSaveObjCols[tIdx2];
                        var tKeyName0 = tColObj0.field;

                        var tColObj1 = tObjCols[tIdx2];
                        var tKeyName1 = tColObj1.field;

                        var tValue = tOneOrderMem[`${tKeyName0}`];
                        if (tIdx2 === 0) {
                            tValue = parseInt(tValue) + tOverQty;
                            tValue = String(tValue);
                        }
                        tWObj[`${tKeyName1}`] = tValue;
                    }
                    tNewOrderMem.push(tWObj);
                }
            }
            tOneObj.ORDER_MEM = [...tNewOrderMem];
            wArray.push(tOneObj);
        }

        setDatasTBL_KSV_ORDER_MST(wArray);
        var tObjORDER_MST = { ...datasTBL_KSV_ORDER_MST[0] };
        // setSelectedTBL_KSV_ORDER_MST(tObjORDER_MST);
        setSelectedTBL_KSV_ORDER_MST([]);

        setDatasTBL_KSV_ORDER_MEM([]);
        setSelectedTBL_KSV_PROD_MEM([]);
    };

