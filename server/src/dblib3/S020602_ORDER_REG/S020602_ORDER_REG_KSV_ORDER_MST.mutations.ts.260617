    Mutation: {
        mgrInsert_S020602_PARTIAL_SHIP: async (_, args, contextValue) => {
            // FIX_FLAG
            var tDateNew = new Date();
            tDateNew.setMonth(tDateNew.getMonth() + 1);
            var tZeroDate = '00';
            var tDateNew_M =
                tZeroDate.substring(
                    0,
                    2 - String(tDateNew.getMonth() + 1).length,
                ) + String(tDateNew.getMonth() + 1);
            var tDateNew_D =
                tZeroDate.substring(0, 2 - String(tDateNew.getDate()).length) +
                String(tDateNew.getMonth());
            var tNewDateStr = tDateNew.getFullYear() + tDateNew_M + tDateNew_D;

            var tDate = new Date();
            var mm = tDate.getMonth() + 1;
            var mm_str = '';
            if (mm > 9) mm_str = mm.toString();
            else mm_str = '0' + mm;

            var dd = tDate.getDate();
            var dd_str = '';
            if (dd > 9) dd_str = dd;
            else dd_str = '0' + dd;

            var hours = tDate.getHours();
            var hours_str = '';
            if (hours > 9) hours_str = hours.toString();
            else hours_str = '0' + hours;

            var minutes = tDate.getMinutes();
            var minutes_str = '';
            if (minutes > 9) minutes_str = minutes.toString();
            else minutes_str = '0' + minutes;

            var seconds = tDate.getSeconds();
            var seconds_str = '';
            if (seconds > 9) seconds_str = seconds.toString();
            else seconds_str = '0' + seconds;

            var yyyy = tDate.getFullYear();

            var tRetDate =
                yyyy.toString() +
                mm_str +
                dd_str +
                hours_str +
                minutes_str +
                seconds_str;
            var tRetDate1 = tRetDate.substring(0, 8);
            var tYY = 'B' + yyyy.toString().substring(2) + '-';

            // let tPO = "POA2022S672";
            var tUserInfo = AFLib.getUserInfo(contextValue);

            /*
      var tSQL = `
          SELECT
              max(A.SEQ) + 1 as max_seq
          FROM
              KSV_ORDER_MST A,
              KCD_STYLE B
          WHERE
              A.STYLE_CD = B.STYLE_CD
              and A.YY = ${tOneMst.YY}
              and B.BUYER_CD = '${tOneMst.BUYER_CD}'
      `;
      var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL));
      var tRet = nRet0[0];
      var tMaxSeq = tRet.max_seq;
*/
            var tInput = { ...args.datas };

            var tSQLArray = [];

            var sql1 = `
                select
                    *
                from
                    ksv_order_mst
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));
            var tOrderMst = nRet1[0];

            var tErrorStr = '';
            if (tOrderMst.DUE_DATE === '') {
                tErrorStr = 'Check Due Date';
            }
            if (tOrderMst.ORDER_STATUS === '9') {
                tErrorStr = 'Ended Order';
            }
            if (tOrderMst.ORDER_STATUS === '8') {
                tErrorStr = 'End Reported Order';
            }
            if (tOrderMst.ORDER_STATUS === '*') {
                tErrorStr = 'Approval Waiting Order';
            }
            if (tOrderMst.FC_NEGO_TYPE !== '1') {
                tErrorStr = 'FC Price Not Decided. ';
            }

            // Check FC Amt
            var sql2 = `
                select
                    count(*) as c_cnt
                from
                    ksv_order_ship
                where
                    order_cd = '${tInput.ORDER_CD}'
                    and ship_ptype in ('1', '3')
                    and fc_chk_flag = '0'
            `;
            var nRet2 = await prisma.$queryRaw(Prisma.raw(sql2));
            if (nRet2.length > 0) {
                if (nRet2[0].c_cnt > 0) {
                    tErrorStr =
                        'FC Amt Not Checked. ( Goto Menu> Account> Cmpt Payment ) ';
                }
            }

            if (tErrorStr !== '') {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:Partinal Ship(${tErrorStr})`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            // Set Order Status
            let tSQL99 = `
                update ksv_order_mst
                set
                    order_status = '5'
                where
                    order_cd = '${tInput.ORDER_CD}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            // Set Cmpt Payment Partial Ship
            var tFcPrice = parseFloat(tOrderMst.FC_PRICE);
            let tSQL99 = `
                update ksv_order_ship
                set
                    fc_bill_price = '${tFcPrice}',
                    fc_chk_flag = '2',
                    fc_chk_user = '${tUserInfo.USER_ID}',
                    fc_chk_datetime = '${tRetDate}'
                where
                    order_cd = '${tInput.ORDER_CD}'
                    and fc_chk_flag = '0'
                    and fc_bill_flag = '0'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            if (tOrderMst.CURR_CD === 'KRW') {
                // Set Krw Fob Update
                var sql3 = `
                    select distinct
                        b.ship_qty,
                        b.ship_date,
                        h.curr_cd,
                        h.start_date,
                        h.usd_rate,
                        a.avr_price,
                        a.tot_cnt,
                        (
                            a.avr_price * (b.ship_qty / a.tot_cnt) * h.usd_rate
                        ) as fob
                    from
                        ksv_order_mst a,
                        kcd_code c,
                        ksv_invoice_mem b,
                        kcd_code e,
                        ksv_invoice_mst f,
                        ksv_order_ship g,
                        kcd_currency h
                    where
                        b.order_cd = '${tInput.ORDER_CD}'
                        and a.order_cd = b.order_cd
                        and c.cd_group = 'SHIP_PTYPE'
                        and c.cd_code = b.ship_ptype
                        and e.cd_group = 'delivery_type'
                        and e.cd_code = b.delivery_type
                        and b.invoice_no = f.invoice_no
                        and g.order_cd = b.order_cd
                        and g.invoice_no = f.invoice_no
                        and h.start_date = (
                            select
                                top 1 start_date
                            from
                                kcd_currency
                            where
                                start_date between '20000101' and b.ship_date
                                and curr_cd = a.curr_cd
                            order by
                                start_date desc
                        )
                        and h.curr_cd = a.curr_cd
                    order by
                        b.ship_date
                `;
                var tShipCnt = 0;
                var tLastUsdRate = 0;
                var tAvrPrice = 0;
                var tOrderCnt = 0;
                var tUsdPrice = 0;
                var nRet3 = await prisma.$queryRaw(Prisma.raw(sql3));
                nRet3.forEach((col1, i1) => {
                    tShipCnt += parseFloat(col1.ship_qty);
                    tLastUsdRate = parseFloat(col1.usd_rate);
                    tAvrPrice = parseFloat(col1.avr_price);
                    tOrderCnt = parseFloat(col1.tot_cnt);
                    tUsdPrice += parseFloat(col1.fob);
                });
                if (tShipCnt > 0) {
                    if (tOrderCnt > tShipCnt) {
                        // 선적이 있는 경우 잔여 수량에 대해선 마지막 선적일 기준 환율 적용
                        tUsdPrice +=
                            ((tAvrPrice * (tOrderCnt - tShipCnt)) / tOrderCnt) *
                            tLastUsdRate;
                    }
                }

                if (tUsdPrice > 0) {
                    let tSQL99 = `
                        update ksv_order_mst
                        set
                            usd_price = '${tUsdPrice}'
                        where
                            order_cd = '${tInput.ORDER_CD}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);
                }
            }

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'SUCCEED:Partial Ship';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:Partial Ship(${e.message})`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }
        },
