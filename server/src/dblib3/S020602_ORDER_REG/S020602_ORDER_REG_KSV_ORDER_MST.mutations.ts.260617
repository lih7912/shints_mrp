                var tObj = {};
                tObj.CODE = 'ERROR:' + e.message;
                tObj.id = 0;
                tRetArray.push(tObj);
            }
            return tRetArray;
        },
        mgrInsert_S020602_COPY_ORDER: async (_, args, contextValue) => {
            // FIX_FLAG
            var tDateNew = new Date();
            tDateNew.setMonth(tDateNew.getMonth() + 1);
            var tZeroDate = '00';
            var tDateNew_M =
                tZeroDate.substring(
                    0,
                    2 - String(tDateNew.getMonth() + 1).length,
                ) + String(tDateNew.getMonth() + 1);
            var tDateNew_D =
                tZeroDate.substring(0, 2 - String(tDateNew.getDate()).length) +
                String(tDateNew.getMonth());
            var tNewDateStr = tDateNew.getFullYear() + tDateNew_M + tDateNew_D;

            var tDate = new Date();
            var mm = tDate.getMonth() + 1;
            var mm_str = '';
            if (mm > 9) mm_str = mm.toString();
            else mm_str = '0' + mm;

            var dd = tDate.getDate();
            var dd_str = '';
            if (dd > 9) dd_str = dd;
            else dd_str = '0' + dd;

            var hours = tDate.getHours();
            var hours_str = '';
            if (hours > 9) hours_str = hours.toString();
            else hours_str = '0' + hours;

            var minutes = tDate.getMinutes();
            var minutes_str = '';
            if (minutes > 9) minutes_str = minutes.toString();
            else minutes_str = '0' + minutes;

            var seconds = tDate.getSeconds();
            var seconds_str = '';
            if (seconds > 9) seconds_str = seconds.toString();
            else seconds_str = '0' + seconds;

            var yyyy = tDate.getFullYear();

            var tRetDate =
                yyyy.toString() +
                mm_str +
                dd_str +
                hours_str +
                minutes_str +
                seconds_str;
            var tRetDate1 = tRetDate.substring(0, 8);
            var tYY = 'B' + yyyy.toString().substring(2) + '-';

            // let tPO = "POA2022S672";

            /*
      var tSQL = `
          SELECT
              max(A.SEQ) + 1 as max_seq
          FROM
              KSV_ORDER_MST A,
              KCD_STYLE B
          WHERE
              A.STYLE_CD = B.STYLE_CD
              and A.YY = ${tOneMst.YY}
              and B.BUYER_CD = '${tOneMst.BUYER_CD}'
      `;
      var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL));
      var tRet = nRet0[0];
      var tMaxSeq = tRet.max_seq;
*/
            var tUserInfo = AFLib.getUserInfo(contextValue);
            var tInput = { ...args.datas };

            var tSQLArray = [];

            var tBuyerCd = tInput.ORDER_CD.substring(0, 2);
            var tYYYY0 = tRetDate.substring(0, 4);
            var tYY0 = tRetDate.substring(2, 4);

            var tSQL = `
                SELECT
                    isnull(max(A.SEQ) + 1, 1) as max_seq
                FROM
                    KSV_ORDER_MST A,
                    KCD_STYLE B
                WHERE
                    A.STYLE_CD = B.STYLE_CD
                    and A.YY = ${tYYYY0}
                    and left(A.ORDER_CD, 2) = '${tBuyerCd}'
            `;
            var nRet1_1 = await prisma.$queryRaw(Prisma.raw(tSQL));
            var tRet = nRet1_1[0];
            var tOrderSeq = tRet.max_seq;

            var sql1 = `
                select
                    *
                from
                    ksv_order_mst
                where
                    ORDER_CD like '${tInput.ORDER_CD}%'
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));

            var tIdx = 0;
            for (tIdx = 0; tIdx < nRet1.length; tIdx++) {
                var tOne = nRet1[tIdx];
                var tOldOrderCd = tOne.ORDER_CD;

                var tOrderPrefix = tOne.ORDER_CD.substring(0, 6);
                var tSeqStr = AFLib.printF(tOrderSeq, 4);
                var tOrderPostFix = '';
                if (tOne.ORDER_CD.length > 10)
                    tOrderPostFix = tOne.ORDER_CD.substring(10, 13);
                var tOrderCd = tOrderPrefix + tSeqStr + tOrderPostFix;

                tOne.ORDER_CD = tOrderCd;
                tOne.SEQ = tOrderSeq;
                tOne.REG_DATETIME = tRetDate;
                tOne.REG_USER = tUserInfo.USER_ID;
                tOne.ORDER_DATE = tRetDate.substring(0, 8);
                tOne.ORDER_STATUS = '*';
                delete tOne.id;

                let tSQL99 = AFLib.createTableSql('KSV_ORDER_MST', tOne);
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                tSQLArray.push(tSQL99_1);

                var sql2 = `
                    select
                        *
                    from
                        ksv_order_mem
                    where
                        ORDER_CD = '${tOldOrderCd}'
                `;
                var nRet2 = await prisma.$queryRaw(Prisma.raw(sql2));

                var tIdx1 = 0;
                for (tIdx1 = 0; tIdx1 < nRet2.length; tIdx1++) {
                    var tOne1 = nRet2[tIdx1];
                    tOne1.ORDER_CD = tOrderCd;
                    delete tOne1.id;

                    let tSQL99 = AFLib.createTableSql('KSV_ORDER_MEM', tOne1);
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);
                }
            }

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'SUCCEED:Delete Order' + tNewCd;
                tObj.id = 0;
                tRetArray.push(tObj);
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Delete Order';
                tObj.id = 0;
                tRetArray.push(tObj);
            }
            return tRetArray;
        },
        mgrUpdate_S020602_END_CONFIRM: async (_, args, contextValue) => {
            // FIX_FLAG

            var tRetDate = AFLib.getCurrTime();
            var tRetDate1 = tRetDate.substring(0, 8);
            var tUserInfo = AFLib.getUserInfo(contextValue);

            var tInput = { ...args.datas };

            var tSQLArray = [];

            var sql1 = `
                select
                    *
                from
                    ksv_order_mst
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));
            var tInput1 = nRet1[0];

            var sqlSample = `
                select
                    isnull(PATT_USER, '') as PATT_USER,
                    isnull(SEW_USER, '') as SEW_USER,
                    isnull(sample_end_flag, '0') as SAMPLE_END_FLAG,
                    isnull(sample_end_date, '') as SAMPLE_END_DATE
                from
                    kzz_sample_cost
                where
                    order_cd = '${tInput.ORDER_CD}'
            `;
            var nRetSample = await prisma.$queryRaw(Prisma.raw(sqlSample));

            if (tInput1.ORDER_STATUS === '8' || tInput1.ORDER_STATUS === '9') {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:End/End Report인것은 처리불가합니다..';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var tSampleShints = 0;
            if (tInput1.SAMPLE_FLAG === '1' && tInput1.FACTORY_CD === 'FC010') { 
                if (
                    nRetSample.length <= 0 ||
                    nRetSample[0].SAMPLE_END_FLAG === '0' ||
                    nRetSample[0].SAMPLE_END_FLAG === ''
                ) {
                    var tRetArray = [];
                    var tObj = {};
                    tObj.CODE =
                        'ERROR:개발실 Sample Order는 임가공마감이 되어야 End Report가능합니다.';
                    tObj.id = 0;
                    tRetArray.push(tObj);
                    return tRetArray;
                }
                tSampleShints = 1;
            } else if (tInput1.SAMPLE_FLAG === '1') {
                // 20260608. won
                tSampleShints = 1;
            }

            if (tSampleShints === 0 && tInput.PO_CD === '') {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Before PO. Check Order Status.';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var sql2 = `
                select
                    isnull(count(*), 0) as cmpt_cnt
                from
                    ksv_order_cmpt
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
                    and nego_type = '1'
            `;
            var nRet2 = await prisma.$queryRaw(Prisma.raw(sql2));
            var tCmptCnt = 0;
            if (nRet2.length > 0) tCmptCnt = nRet2[0].cmpt_cnt;

            var sql3 = `
                select
                    isnull(sum(ship_qty), 0) as invoice_qty
                from
                    ksv_invoice_mem
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            var nRet3 = await prisma.$queryRaw(Prisma.raw(sql3));
            var tInvoiceQty = 0;
            if (nRet3.length > 0) tInvoiceQty = nRet3[0].invoice_qty;

            if (
                tCmptCnt <= 0 &&
                parseFloat(tInput1.FC_PRICE) <= 0 &&
                tSampleShints === 0
            ) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Insert Factory Price';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            // Check FC Amt
            var tFcChk = 0;
            if (tInput1.FC_NEGO_TYPE !== '1') {
                tFcChk = 1;
            }

            var sql4 = `
                select
                    isnull(count(*), 0) as ship_cnt
                from
                    ksv_order_ship
                where
                    order_cd = '${tInput1.ORDER_CD}'
                    and ship_ptype in ('1', '3')
                    and fc_chk_flag = '0'
            `;
            var nRet4 = await prisma.$queryRaw(Prisma.raw(sql4));
            /*
      if (nRet4.length <= 0 || nRet4[0].ship_cnt <= 0) {
          tFcChk = 2;
      }
*/
            if (nRet4.length > 0 && nRet4[0].ship_cnt > 0) {
                tFcChk = 2;
            }

            var tMsgFc = '';
            if (tFcChk === 1) {
                tMsgFc = 'FC Price Not Decided. ( Goto Menu> FPM> Nego Cmpt )';
            }
            if (tFcChk === 2) {
                tMsgFc =
                    'FC Amt Not Checked. ( Goto Menu> Account> Cmpt Payment )';
            }

            // Check FOB
            var tFobChk = 0;

            var sql5 = `
                select
                    a.sales_price,
                    a.ship_price,
                    a.ship_qty,
                    isnull(b.pay_qty, 0) as ship_qty2,
                    isnull(b.pay_price, 0) as sales_price2,
                    e.curr_cd 
                from
                    ksv_invoice_mem a
                    left join ksv_tax_mem b on b.invoice_no = a.invoice_no
                                           and b.order_cd = a.order_cd
                    left join ksv_tax_mst c on c.tax_cd = b.tax_cd,
                    ksv_invoice_mst d, ksv_order_mst e
                where
                    a.order_cd = '${tInput1.ORDER_CD}'
                    and a.invoice_no = d.invoice_no
                    and (
                        (isnull(c.docu_no, '') <> '')
                        or (
                            isnull(c.docu_no, '') = ''
                            and d.docu_no <> ''
                        )
                    )
                    and e.order_cd = a.order_cd
            `;
            var nRet5 = await prisma.$queryRaw(Prisma.raw(sql5));

            var tInvShipQty = 0;
            var tInvShipAmt = 0;

            var tSalesPrice = 0;
            nRet5.forEach((col, i) => {
                // var tPrice = col.ship_price;
                // var tPrice = col.sales_price;
                /*
          var tPrice = col.sales_price;
          if (col.sales_price > 0) tSalesPrice = col.sales_price;
          if (col.sales_price <= 0) tPrice = tSalesPrice; 
          */
                var tPrice = parseFloat(col.sales_price);
                var tShipQty = parseFloat(col.ship_qty);
                // if (parseFloat(col.sales_price2) > 0) {
                if (parseFloat(col.ship_qty2) > 0) {
                    tPrice = parseFloat(col.sales_price2);
                    tShipQty = parseFloat(col.ship_qty2);
                }
                tInvShipQty += parseFloat(tShipQty);
                tInvShipAmt += parseFloat(tShipQty) * tPrice;
            });
            var tInvoiceFOB = 0;
            if (tInvShipQty > 0) {
                tInvoiceFOB = tInvShipAmt / tInvShipQty;
                if (nRet5[0].curr_cd === 'KRW')
                    tInvoiceFOB = parseFloat(tInvoiceFOB).toFixed(0);
                else tInvoiceFOB = parseFloat(tInvoiceFOB).toFixed(4);
            }

            var sql6 = `
                select
                    a.fob,
                    a.ship_qty,  
                    b.curr_cd
                from
                    ksv_order_fob a, ksv_order_mst b
                where
                    a.order_cd = '${tInput1.ORDER_CD}'
                and a.order_cd = b.order_cd
            `;
            var nRet6 = await prisma.$queryRaw(Prisma.raw(sql6));

            var tFobShipQty = 0;
            var tFobShipAmt = 0;

            nRet6.forEach((col, i) => {
                tFobShipQty += col.ship_qty;
                tFobShipAmt += col.ship_qty * col.fob;
            });
            var tOrderFOB = 0;
            if (tFobShipQty > 0) {
                tOrderFOB = tFobShipAmt / tFobShipQty;
                if (nRet6[0].curr_cd === 'KRW')
                    tOrderFOB = parseFloat(tOrderFOB).toFixed(0);
                else tOrderFOB = parseFloat(tOrderFOB).toFixed(4);
            }

            console.log(
                `Check : End Report(FOB) : ${tOrderFOB} / ${tInvoiceFOB} `,
            );
            if (parseFloat(tOrderFOB) !== parseFloat(tInvoiceFOB)) tFobChk = 1;

            var sql6 = `
                select
                    isnull(d.order_cd, 'N') as order_cd,
                    a.invoice_no
                from
                    ksv_order_ship a
                    left join ksv_invoice_mem d on a.order_cd = d.order_cd
                    and a.invoice_no = d.invoice_no
                    --       kcd_code b,kcd_code c,
                where
                    a.order_cd = '${tInput1.ORDER_CD}'
                    --	 and b.cd_group = 'DELIVERY_TYPE' and b.cd_code =* a.delivery_type 
                    --   and c.cd_group = 'SHIP_PTYPE' and c.cd_code =* a.ship_ptype
            `;
            var nRet6 = await prisma.$queryRaw(Prisma.raw(sql6));
            if (nRet6.length > 0) {
                nRet6.forEach((col, i) => {
                    if (col.order_cd === 'N') tFobChk = 2;
                });
            }

            var tMsgFob = '';
            if (tFobChk === 1) {
                tMsgFob = `FOB is Different from Invoice ${tOrderFOB}, ${tInvoiceFOB} `;
            }
            if (tFobChk === 2) {
                tMsgFob = 'Not insert into Invoice %s. ';
            }

            // End Report 진행 가능 여부를 체크함
            if (
                parseFloat(tInput1.AVR_PRICE) <= 0 &&
                tInput1.SAMPLE_FLAG === '1' &&
                parseFloat(tInput1.TOT_CNT) < 7
            ) {
                if (tSampleShints === 0 && tFcChk > 0) {
                    var tRetArray = [];
                    var tObj = {};
                    tObj.CODE = 'ERROR:' + tMsgFc;
                    tObj.id = 0;
                    tRetArray.push(tObj);
                    return tRetArray;
                }
                if (tSampleShints === 0 && parseInt(tInput1.ORDER_STATUS) < 7) {
                    var tRetArray = [];
                    var tObj = {};
                    tObj.CODE = 'ERROR:Must Ship End First.';
                    tObj.id = 0;
                    tRetArray.push(tObj);
                    return tRetArray;
                }
            } else {
                if (tInput1.SAMPLE_COST_FLAG !== '1') {
                    if (
                        tInvShipQty !== tFobShipQty - 1 &&
                        tInvShipQty !== tFobShipQty
                    ) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE = `ERROR:Insert invoice data.(diffrent invoice ship qty(${tInvShipQty}), fob ship qty(${tFobShipQty})`;
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                    if (tInput1.STYLE_CD !== '00-0000') {
                        if (parseInt(tInput1.ORDER_STATUS) < 7) {
                            var tRetArray = [];
                            var tObj = {};
                            tObj.CODE = 'ERROR:Must Ship End First.';
                            tObj.id = 0;
                            tRetArray.push(tObj);
                            return tRetArray;
                        }
                        if (tFobChk > 0) {
                            var tRetArray = [];
                            var tObj = {};
                            tObj.CODE = 'ERROR:' + tMsgFob;
                            tObj.id = 0;
                            tRetArray.push(tObj);
                            return tRetArray;
                        }
                        if (tFcChk > 0) {
                            var tRetArray = [];
                            var tObj = {};
                            tObj.CODE = 'ERROR:' + tMsgFc;
                            tObj.id = 0;
                            tRetArray.push(tObj);
                            return tRetArray;
                        }
                    }
                } else {
                    if (tInput1.SAMPLE_END_FLAG > 0) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE = 'ERROR:' + tMsgFc;
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                    var sql7 = `
                        select
                            isnull(sample_end_flag, '0') as sample_end_flag
                        from
                            kzz_sample_cost
                        where
                            order_cd = '${tInput1.ORDER_CD}'
                    `;
                    var nRet7 = await prisma.$queryRaw(Prisma.raw(sql7));
                    if (nRet7.length > 0 && nRet7[0].sample_end_flag === '1') {
                    } else {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE = `ERROR:Check Sample Cost Part.(sample_end_flag !== 1)`;
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                }
            }

            // Check Stock
            //  1) po_status 체크
            var sql7 = `
                select
                    c.status_cd,
                    c.po_status
                from
                    ksv_po_mem a,
                    ksv_po_mst c
                where
                    a.po_cd = '${tInput.PO_CD}'
                    and a.po_seq = 1
                    and a.order_cd = '${tInput1.ORDER_CD}'
                    and c.po_cd = a.po_cd
                    and c.po_seq = a.po_seq
            `;
            var nRet7 = await prisma.$queryRaw(Prisma.raw(sql7));
            if (
                tSampleShints === 0 &&
                nRet7.length > 0 &&
                parseInt(nRet7[0].po_status) < 4
            ) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:check PO status';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            //  2) 입고단가 0인것 체크
            var sql8 = `
                select
                    *
                from
                    ksv_stock_in a,
                    kcd_matl_mst b,
                    kcd_vendor c
                where
                    a.po_cd = '${tInput.PO_CD}'
                    and a.order_cd = '${tInput.ORDER_CD}'
                    -- and a.pay_price < 0.0000001
                    -- and a.in_price < 0.0000001
                    and a.pay_price < 0.00001
                    and a.in_price < 0.00001
                    and b.matl_cd = a.matl_cd
                    and b.vendor_cd <> 'V0558'
                    and c.vendor_cd = b.vendor_cd
                    and c.vendor_type <> '4'
                    and a.in_qty > 0
            `;
            var nRet8 = await prisma.$queryRaw(Prisma.raw(sql8));
            if (tSampleShints === 0 && nRet8.length > 0) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:Some Material's Input Price is 0. Contact Matl Part.(${nRet8.length}, ${nRet8[0].MATL_CD} )`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }
            //  2) 입고단가 0인것 체크
            var sql9 = `
                select
                    isnull(count(*), 0) as stsin_cnt
                from
                    ksv_stock_mem a
                where
                    a.po_cd = '${tInput.PO_CD}'
                    and a.order_cd = '${tInput1.ORDER_CD}'
                    and a.diff_po_type <> '2'
                    and a.po_qty > 0
                    and a.po_seq < 200
                    and a.po_cd not in (
                        select
                            po_cd
                        from
                            ksv_stock_in
                        where
                            po_cd = a.po_cd
                            and po_seq = a.po_seq
                            and order_cd = a.order_cd
                            and matl_cd = a.matl_cd
                            and mrp_seq = a.mrp_seq
                    )
            `;
            var nRet9 = await prisma.$queryRaw(Prisma.raw(sql9));
            if (
                tSampleShints === 0 &&
                nRet9.length > 0 &&
                nRet9[0].stsin_cnt > 0
            ) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:Some Material Not Inputted. Contact Matl Part(${nRet9[0].stsin_cnt}).`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            // End Report 진행
            let tSQL99 = `
                update ksv_order_mst
                set
                    remark = '${tInput.END_REMARK}'
                where
                    order_cd = '${tInput.ORDER_CD}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            // FOB Update
            var sql9_1 = `
                select
                    *
                from
                    ksv_invoice_mem
                where
                    order_cd = '${tInput.ORDER_CD}'
            `;
            var nRet9_1 = await prisma.$queryRaw(Prisma.raw(sql9_1));
            var tSumAvrPrice = 0;
            var tSumUsdPrice = 0;
            var tSumQty = 0;
            nRet9_1.forEach((col, i) => {
                tSumQty += parseFloat(col.SHIP_QTY);
                tSumAvrPrice +=
                    parseFloat(col.SHIP_QTY) * parseFloat(col.SALES_PRICE);
                tSumUsdPrice +=
                    parseFloat(col.SHIP_QTY) * parseFloat(col.SHIP_PRICE);
            });
            if (tSumQty > 0) {
                tSumAvrPrice = AFLib.numToFixed(tSumAvrPrice / tSumQty, 4);
                tSumUsdPrice = AFLib.numToFixed(tSumUsdPrice / tSumQty, 4);
            }

            let tSQL99 = `
                update ksv_order_mst
                set
                    org_order_status = order_status,
                    order_status = '8',
                    upd_user = '${tUserInfo.USER_ID}',
                    upd_datetime = '${tRetDate}'
                    -- avr_price = '${tSumAvrPrice}',
                    -- usd_price = '${tSumUsdPrice}'
                where
                    order_cd like '${tInput.ORDER_CD}%'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            let tSQL99 = `
                update ksv_order_ship
                set
                    fc_bill_price = '${tInvoiceFOB}',
                    fc_chk_flag = '1',
                    fc_chk_user = '${tUserInfo.USER_ID}',
                    fc_chk_datetime = '${tRetDate}'
                where
                    order_cd = '${tInput1.ORDER_CD}'
                    and fc_chk_flag = '0'
                    and fc_bill_flag = '0'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'SUCCEED:Order End Report';
                tObj.id = 0;
                tRetArray.push(tObj);
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Order End Report';
                tObj.id = 0;
                tRetArray.push(tObj);
            }
            return tRetArray;
        },
        mgrUpdate_S020602_CANCEL_END_REPORT: async (_, args, contextValue) => {
            // FIX_FLAG
            var tDateNew = new Date();
            tDateNew.setMonth(tDateNew.getMonth() + 1);
            var tZeroDate = '00';
            var tDateNew_M =
                tZeroDate.substring(
                    0,
                    2 - String(tDateNew.getMonth() + 1).length,
                ) + String(tDateNew.getMonth() + 1);
            var tDateNew_D =
                tZeroDate.substring(0, 2 - String(tDateNew.getDate()).length) +
                String(tDateNew.getMonth());
            var tNewDateStr = tDateNew.getFullYear() + tDateNew_M + tDateNew_D;

            var tDate = new Date();
            var mm = tDate.getMonth() + 1;
            var mm_str = '';
            if (mm > 9) mm_str = mm.toString();
            else mm_str = '0' + mm;

            var dd = tDate.getDate();
            var dd_str = '';
            if (dd > 9) dd_str = dd;
            else dd_str = '0' + dd;

            var hours = tDate.getHours();
            var hours_str = '';
            if (hours > 9) hours_str = hours.toString();
            else hours_str = '0' + hours;

            var minutes = tDate.getMinutes();
            var minutes_str = '';
            if (minutes > 9) minutes_str = minutes.toString();
            else minutes_str = '0' + minutes;

            var seconds = tDate.getSeconds();
            var seconds_str = '';
            if (seconds > 9) seconds_str = seconds.toString();
            else seconds_str = '0' + seconds;

            var yyyy = tDate.getFullYear();

            var tRetDate =
                yyyy.toString() +
                mm_str +
                dd_str +
                hours_str +
                minutes_str +
                seconds_str;
            var tRetDate1 = tRetDate.substring(0, 8);
            var tYY = 'B' + yyyy.toString().substring(2) + '-';

            // let tPO = "POA2022S672";
            var tUserInfo = AFLib.getUserInfo(contextValue);

            /*
      var tSQL = `
          SELECT
              max(A.SEQ) + 1 as max_seq
          FROM
              KSV_ORDER_MST A,
              KCD_STYLE B
          WHERE
              A.STYLE_CD = B.STYLE_CD
              and A.YY = ${tOneMst.YY}
              and B.BUYER_CD = '${tOneMst.BUYER_CD}'
      `;
      var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL));
      var tRet = nRet0[0];
      var tMaxSeq = tRet.max_seq;
*/
            var tInput = { ...args.datas };

            var tSQLArray = [];

            var sql1 = `
                select
                    *
                from
                    ksv_order_mst
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));
            var tInput1 = nRet1[0];

            if (
                tInput1.ORDER_STATUS === '5' ||
                tInput1.ORDER_STATUS === '7' ||
                tInput1.ORDER_STATUS === '8'
            ) {
            } else {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE =
                    'ERROR:End Report상태만 Partial Ship, Ship End, End report상태만 PO상태로 변경 가능합니다.';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var sql9_1 = `
                select
                    *
                from
                    ksv_invoice_mem
                where
                    order_cd = '${tInput.ORDER_CD}'
            `;
            var nRet9_1 = await prisma.$queryRaw(Prisma.raw(sql9_1));
            var tSumAvrPrice = 0;
            var tSumUsdPrice = 0;
            var tSumQty = 0;
            nRet9_1.forEach((col, i) => {
                if (parseFloat(col.SHIP_PRICE) > 0 && tSumUsdPrice <= 0)
                    tSumUsdPrice = parseFloat(col.SHIP_PRICE);
                if (parseFloat(col.SALES_PRICE) > 0 && tSumAvrPrice <= 0)
                    tSumAvrPrice = parseFloat(col.SALES_PRICE);
            });

            let tSQL99 = `
                update ksv_order_mst
                set
                    org_order_status = order_status,
                    order_status = '3',
                    upd_user = '${tUserInfo.USER_ID}',
                    upd_datetime = '${tRetDate}'
                    -- avr_price = '${tSumAvrPrice}',
                    -- usd_price = '${tSumUsdPrice}'
                where
                    order_cd like '${tInput.ORDER_CD}%'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'SUCCEED:Cancel End Report';
                tObj.id = 0;
                tRetArray.push(tObj);
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Cancel End Report';
                tObj.id = 0;
                tRetArray.push(tObj);
            }
            return tRetArray;
        },
