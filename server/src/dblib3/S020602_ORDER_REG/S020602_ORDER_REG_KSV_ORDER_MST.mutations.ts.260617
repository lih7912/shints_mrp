                                    and start_date = '${tmpObj.SHIP_DATE}'
                            `;
                            var retCurrency = await prisma.$queryRaw(
                                Prisma.raw(sqlCurrency),
                            );
                            if (retCurrency.length <= 0) {
                                sqlCurrency = `
                                    select
                                        *
                                    from
                                        kcd_currency
                                    where
                                        curr_cd = '${tMstMain.CURR_CD}'
                                        and start_date = (
                                            select
                                                max(start_date)
                                            from
                                                kcd_currency
                                            where
                                                curr_cd = '${tMstMain.CURR_CD}'
                                        )
                                `;
                                retCurrency = await prisma.$queryRaw(
