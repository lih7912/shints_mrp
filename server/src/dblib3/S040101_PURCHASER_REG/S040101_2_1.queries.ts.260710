            });

            /*
        tRet10.forEach((col, i) => {
            var tObj = { ...col };
            tDatas.push(tObj);
        });
        */

            var tArray = [];
            var tIdx1 = 0;
            var tMessage = '';
            for (tIdx1 = 0; tIdx1 < tDatas.length; tIdx1++) {
