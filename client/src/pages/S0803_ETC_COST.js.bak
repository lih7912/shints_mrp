            </label>
          </div>
        </span>
      </div>
      <div className="af-div-first" style={{ width: '52rem', marginLeft: '0rem', height: '8rem' }}>
        <span className="af-span-3-0" style={{ width: '20rem' }}>
          <p className="af-span-p" style={{ width: '8rem', display: 'inline-block' }}>시작일</p>
          <div className="af-span-div">
