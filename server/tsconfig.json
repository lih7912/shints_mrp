{
    "compilerOptions": {
        "target": "es5",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "dist",
        "rootDir": ".",
        "lib": ["esnext"],
        "allowJs": true,
        "checkJs": false,
        "noCheck": true,
        "ignoreDeprecations": "5.0",
        "strict": false,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "noEmitOnError": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "sourceMap": false,
        "declaration": false
    },
    "include": ["src/**/*", "routes/**/*"],
    "exclude": ["node_modules", "dist", "**/*.bak", "**/*.real", "**/*.1"]
}
