                });
                if (tCheck === 0 && tOne.STSIN_CD !== '') {
                    if (stsInArray.length === 0)
                        stsInSql = `'${tOne.STSIN_CD}'`;
                    else stsInSql += `,'${tOne.STSIN_CD}'`;
