                        var tIndex2 = -1;

                        tMonArray.forEach((col1, i1) => {
                            if (col1 === col.yymm) tIndex = i1;
                        });
                        tLineArray.forEach((col1, i1) => {
                            if (col1 === col.line_type) tIndex2 = i1;
                        });

                        if (tIndex !== -1 && tIndex2 !== -1) {
                            tArray99[tIndex][tIndex2] = col.order_qty;
                            tArray99[tIndex][tIndex2 + 1] = col.order_amt;
                        }
                    });
                    var tStartCol = 7;
                    sheet.getCell(tStartRow, 2).value = tOne.BUYER_CD;
                    for (var tIdx = 0; tIdx < 10; tIdx++) {
                        for (var tIdx1 = 0; tIdx1 < 12; tIdx1++) {
                            sheet.getCell(
                                tStartRow + tIdx,
                                tStartCol + tIdx1,
                            ).value = tArray99[tIdx1][tIdx];
                        }
                    }
                    tStartRow += 10;

                    for (var tIdx = 0; tIdx < 12; tIdx++) {
                        for (var tIdx1 = 0; tIdx1 < 10; tIdx1++) {
                            tArray99[tIdx][tIdx1] = 0;
                        }
                    }
                    var sql2_2 = `
                        SELECT
                            a.yymm,
                            a.line_type,
                            SUM(a.PLAN_QTY) AS totqty,
                            SUM(a.PLAN_AMT) AS totamt,
                            sum(b.USD_RATE * a.PLAN_AMT) AS usamt
                        FROM
                            ${tTableName} a,
                            KCD_CURR_COM b
                        where
                            a.yymm between '${args.data.S_DATE}' and '${args.data.E_DATE}'
                            and (a.BUYER_CD = '${tOne.BUYER_CD}')
                            and (a.CURR_CD = b.CURR_CD)
                            AND b.start_date = (
                                SELECT
                                    MAX(START_DATE)
                                FROM
                                    KCD_CURR_COM
                            )
                        GROUP BY
                            a.YYMM,
                            a.line_type
                        order by
                            a.YYMM,
                            a.line_type
                    `;
                    var tRet2_2 = await prisma.$queryRaw(Prisma.raw(sql2_2));
                    tRet2_2.forEach((col, i) => {
                        var tIndex = -1;
                        var tIndex2 = -1;

                        tMonArray.forEach((col1, i1) => {
                            if (col1 === col.yymm) tIndex = i1;
                        });
                        tLineArray.forEach((col1, i1) => {
                            if (col1 === col.line_type) tIndex2 = i1;
                        });

                        if (tIndex !== -1 && tIndex2 !== -1) {
                            tArray99[tIndex][tIndex2] = col.totqty;
                            tArray99[tIndex][tIndex2 + 1] = col.usamt;
