              */

                    if (remainPoQty <= 0 && remainPoQtyFoc <= 0) break;
                }

                // remainPoQty가 남은 경우 . MOQ, OverIn 순으로 처리
                // MOQ,Over-In,Foc 처리 (stock_mem정보를 이용하여 stock_matl 생성 및 조정)
                let sqlStockMem = `
                    select
                        a.*,
                        b.LC_FLAG,
                        b.DEPOSIT_RATE,
                        b.BUYER_CD,
                        b.VENDOR_CD,
                        b.CURR_CD as CURR_CD2,
                        c.PO_PRICE as PO_PRICE2
                    from
                        ksv_stock_mem a,
                        ksv_pu_mst2 b,
                        ksv_stock_mem2 c
                    where
                        a.po_cd in (${poCdSql})
                        and a.pu_cd = '${mainObj.PU_CD}'
                        and a.pu_cd = b.pu_cd
                        and a.matl_cd = '${mainObj.MATL_CD}'
                        and a.pu_cd = c.pu_cd
                        and a.matl_cd = c.matl_cd
                        and a.po_cd = c.po_cd
                        and a.po_seq in (99, 98, 97)
                        -- and   (a.po_qty - a.in_qty) > 0
                        -- and   a.po_qty > 0
                        and c.reg_datetime = (
                            select
                                max(reg_datetime)
                            from
                                ksv_stock_mem2
                            where
                                a.po_cd = po_cd
                                and a.matl_cd = matl_cd
                                and a.pu_cd = pu_cd
                        )
                    order by
                        a.po_cd,
                        a.order_cd
                `;
                let retStockMem = [];
                retStockMem = await prisma.$queryRaw(Prisma.raw(sqlStockMem));

                var idxStockMem = 0;
                console.log(
                    `===========>MOQ StsIn : (3) ${mainObj.PO_CD}/${mainObj.MATL_CD}/${retStockMem.length}`,
                );
                for (
