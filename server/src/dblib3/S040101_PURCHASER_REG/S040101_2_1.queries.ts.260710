                eMrpDate = `${tRetDate.substring(0, 6)}01}`;
            if (args.data.E_MRP_DATE === '') eMrpDate = '99999999';
            tSQL += `                and   left(a1.reg_datetime, 8) between '${sMrpDate}' and '${eMrpDate}' `;

