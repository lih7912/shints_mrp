                    )
                    -- and curr_cd in( 'USD', 'KRW')
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_CURRENCY = tRet;

            var tSQL = '';
            let sqlStr = `
                SELECT
                    *
                FROM
                    KCD_SIZE_MST
                WHERE
                    (
                        buyer_cd = '${tBuyerCd}'
                        or size_group = '${tOrderMst.SIZE_GROUP}'
