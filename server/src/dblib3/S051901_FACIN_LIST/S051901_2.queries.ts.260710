                 from ksv_stock_facin a 
                      left join ksv_stock_out a1 on a1.stsout_cd = a.stsout_cd
                                                and a1.po_cd = a.po_cd
                                                and a1.matl_cd = a.matl_cd
                      left join (
                          select
