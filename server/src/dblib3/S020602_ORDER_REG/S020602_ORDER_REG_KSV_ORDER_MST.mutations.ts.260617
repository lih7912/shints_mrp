                var tObj = {};
                tObj.CODE = 'ERROR:Update PI_MST:' + e.message;
                tObj.id = 0;
                tRetArray.push(tObj);
            }

            return tRetArray;
        },

        mgrInsert_S020602_5_FILE_UPDATE: async (_, args, contextValue) => {
            //
            var tRetDate = AFLib.getCurrTime();
            var tRetDate1 = tRetDate.substring(0, 8);

