                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL3));
                    if (tCheck2 > 0) tSQLArray.push(tSQL99_1);
                }

                try {
                    global.currentTransactionInfo = {
                        contextValue: contextValue,
