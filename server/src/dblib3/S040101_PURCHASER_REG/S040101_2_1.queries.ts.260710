                tVendorSql = ` and  d.vendor_type in ('1',  '7') `;
                tVendorSql += ` and  left(d.vendor_name, 6) <> 'IMPORT' `;
            } else if (
                tTeam === 'PUR' ||
                tTeam1 === 'PUR1' ||
                tTeam2 === 'MC'
            ) {
                tVendorSql = ` and  (d.vendor_type in ('3', '4', '7') `;
                tVendorSql += ` or   (d.vendor_type in ('1')  `;
