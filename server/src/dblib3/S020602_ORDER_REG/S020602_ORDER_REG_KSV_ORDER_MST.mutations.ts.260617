                                );
                            }

                            var tFobObj = {};
                            tFobObj.order_cd = tWObj.ORDER_CD;
                            tFobObj.fob_seq = tIdx7 + 1;
                            tFobObj.ship_qty = tmpObj.SHIP_QTY;
                            if (tmpObj.DOCU_NO2) {
                                tFobObj.ship_qty = tmpObj.PAY_QTY;
                                tFobObj.fob = tmpObj.PAY_PRICE;
                                tFobObj.fob100 = tmpObj.PAY_PRICE;
                            } else {
                                if (tMstMain.CURR_CD === 'USD') {
                                    tFobObj.fob = tmpObj.SALES_PRICE;
                                    tFobObj.fob100 = tmpObj.SALES_PRICE;
                                } else {
                                    tFobObj.fob = tmpObj.SALES_PRICE;
                                    tFobObj.fob100 = tmpObj.SALES_PRICE;
                                    /*
                            var tmpVal = parseFloat(tmpObj.SHIP_PRICE) / parseFloat(retCurrency[0].USD_RATE);
                            if (tMstMain.CURR_CD === 'KRW') {
                                tmpVal = parseFloat(tmpVal).toFixed(0);
                            } else {
                                tmpVal = parseFloat(tmpVal).toFixed(4);
                            }
                            tFobObj.fob = tmpVal;
                            tFobObj.fob100 = tmpVal;
                            */
                                }
                            }
                            let tSQL99 = AFLib.createTableSql(
                                'KSV_ORDER_FOB',
                                tFobObj,
                            );
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        }
                    }

                    let tSQL99 = `
                        update ksv_order_mst
                        set
                            nat_cd = '${tWObj.NAT_CD}',
                            ref_order_no = '${tWObj.REF_ORDER_NO}',
                            remark = '${tWObj.REMARK}',
                            ref_q_liner = '${tWObj.REF_Q_LINER}',
                            ref_order_req = '${tWObj.REF_ORDER_REQ}',
                            due_date = '${tWObj.DUE_DATE}',
                            etd = '${tWObj.ETD}',
                            -- matl_due_date = '${tWObj.MATL_DUE_DATE}',
                            tot_cnt = '${tWObj.TOT_CNT}',
                            add_cnt = '${tWObj.ADD_CNT}',
                            price_term = '${tWObj.PRICE_TERM}',
                            ${sqlPrice} size_group = '${tOrderMst1.SIZE_GROUP}',
                            upd_user = '${tWObj.UPD_USER}',
                            upd_datetime = '${tWObj.UPD_DATETIME}',
                            buyer_team = '${tWObj.BUYER_TEAM}'
                        where
                            order_cd = '${tWObj.ORDER_CD}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    let tSQL99 = `
                        update kzz_sample_cost 
                        set 
                            order_qty = '${tWObj.TOT_CNT}'
                        where  
                            order_cd = '${tWObj.ORDER_CD}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    var sql2 = `
                        select
                            a.book_date,
                            a.job_cd,
                            a.user_id
                        from
                            ${tTabName1} a,
                            ${tTabName} b
                        where
                            a.order_cd = '${tWObj.ORDER_CD}'
                            and a.book_date = b.book_date
                            and a.user_id = b.user_id
                            and b.status_cd = '0'
                            and a.JOB_CD not in ('d', 'e')
                        order by
                            1 desc
                    `;
                    var nRet2 = [];
                    if (tTabName1 !== '' && tTabName !== '')
                        nRet2 = await prisma.$queryRaw(Prisma.raw(sql2));
                    if (nRet2.length > 0) {
                        var tUpdateJobCd = nRet2[0].job_cd;
                        if (tUpdateJobCd === 'I') tUpdateJobCd = 'I';
                        else tUpdateJobCd = 'U';

                        if (tOrderMst.IS_SAMPLE === '1') {
                            /*
                    let tSQL99 = `
                        update ${tTabName1}
                        set
                            job_cd = '${tUpdateJobCd}',
                            fob = ${tWObj.AVR_PRICE},
                            qty = ${tWObj.TOT_CNT},
