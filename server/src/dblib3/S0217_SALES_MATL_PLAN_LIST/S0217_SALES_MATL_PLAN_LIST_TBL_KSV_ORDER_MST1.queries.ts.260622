                    for (var tIdx = 0; tIdx < 12; tIdx++) {
                        tArray99[tIdx][0] = 0;
                        tArray99[tIdx][1] = 0;
                    }
                    var sql2_1 = `
                        select
                            a.yymm,
                            isnull(sum(a.order_amt), 0) as order_amt,
                            isnull(sum(a.order_qty), 0) as order_qty
                        from
                            ksv_order_plan_order a,
                            kcd_buyer b
                        where
                            a.factory_cd in ('${args.data.FACTORY_CD}')
                            and a.buyer_cd = '${tOne.BUYER_CD}'
                            and a.buyer_cd = b.buyer_cd
                            and a.yymm between '${args.data.S_DATE}' and '${args.data.E_DATE}'
                        group by
                            yymm
                    `;
                    var tRet2_1 = await prisma.$queryRaw(Prisma.raw(sql2_1));
                    tRet2_1.forEach((col, i) => {
                        var tIndex = -1;
                        var tIndex2 = -1;

                        tMonArray.forEach((col1, i1) => {
                            if (col1 === col.yymm) tIndex = i1;
                        });
                        tIndex2 = 0;

                        if (tIndex !== -1 && tIndex2 !== -1) {
                            tArray99[tIndex][tIndex2] = col.order_qty;
                            tArray99[tIndex][tIndex2 + 1] = col.order_amt;
                        }
                    });
                    var tStartCol = 7;
                    sheet.getCell(tStartRow, 2).value = tOne.BUYER_CD;
                    for (var tIdx1 = 0; tIdx1 < 12; tIdx1++) {
                        sheet.getCell(tStartRow + 0, tStartCol + tIdx1).value =
                            tArray99[tIdx1][0];
                        sheet.getCell(tStartRow + 1, tStartCol + tIdx1).value =
                            tArray99[tIdx1][1];
                    }
                    tStartRow += 2;

                    for (var tIdx = 0; tIdx < 12; tIdx++) {
                        tArray99[tIdx][0] = 0;
                        tArray99[tIdx][1] = 0;
                    }
                    var sql2_2 = `
                        SELECT
                            a.yymm,
                            SUM(a.PLAN_QTY) AS totqty,
                            SUM(a.PLAN_AMT) AS totamt,
                            sum(b.USD_RATE * a.PLAN_AMT) AS usamt
                        FROM
                            ${tTableName} a,
                            KCD_CURR_COM b
                        where
                            a.yymm between '${args.data.S_DATE}' and '${args.data.E_DATE}'
                            and (a.BUYER_CD = '${tOne.BUYER_CD}')
                            and (a.CURR_CD = b.CURR_CD)
                            AND b.start_date = (
                                SELECT
                                    MAX(START_DATE)
                                FROM
                                    KCD_CURR_COM
                            )
                        GROUP BY
                            a.YYMM
                        order by
                            a.YYMM
                    `;
                    var tRet2_2 = await prisma.$queryRaw(Prisma.raw(sql2_2));
                    tRet2_2.forEach((col, i) => {
                        var tIndex = -1;
                        var tIndex2 = -1;

                        tMonArray.forEach((col1, i1) => {
                            if (col1 === col.yymm) tIndex = i1;
                        });
                        tIndex2 = 0;

                        if (tIndex !== -1 && tIndex2 !== -1) {
                            tArray99[tIndex][0] = col.totqty;
                            tArray99[tIndex][1] = col.usamt;
                        }
                    });
                    tStartCol = 7;
                    for (var tIdx1 = 0; tIdx1 < 12; tIdx1++) {
                        sheet.getCell(tStartRow + 0, tStartCol + tIdx1).value =
                            tArray99[tIdx1][0];
                        sheet.getCell(tStartRow + 1, tStartCol + tIdx1).value =
                            tArray99[tIdx1][1];
                    }
                    tStartRow += 3;
                }

                return await upload(`${tWExcelFile}.xlsx`, wb);
            } catch (error) {
                var tRetArray = [];
                var tObj = {};
                tObj.id = 1;
                tObj.CODE = `ERROR:${error.message}`;
                tRetArray.push(tObj);
                return tRetArray;
            }
        },

        mgrQuery_S0217_SALES_MATL_PLAN_LIST_TBL_KSV_ORDER_MST1: async (
            _,
            args,
        ) => {
            var tSQL = '';
            var tTableName = '';
            if (args.data.FACTORY_CD !== 'FC034') {
                tTableName = 'KSV_ORDER_PLAN_ETHIOPIA';
            }
            if (args.data.FACTORY_CD !== 'FC044') {
                tTableName = 'KSV_ORDER_PLAN';
            }

            if (args.KEY1 !== '') {
                tSQL += `AND KEY1 = '${args.KEY1}' `;
            }
            let sqlStr = `
                SELECT
                    COLLECTION,
                    CURR_CD,
                    SUM(PLAN_QTY) as SUM_QTY
                FROM
                    ${tTableName}
                WHERE
                    YYMM BETWEEN '${args.data.S_DATE}' AND '${args.data.E_DATE}'
                GROUP BY
                    COLLECTION,
                    CURR_CD
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));

            var tRetArray = [];

            var tIdx = 0;
            for (tIdx = 0; tIdx < tRet.length; tIdx++) {
                var tOne = { ...tRet[tIdx] };

                let sqlStr1 = `
