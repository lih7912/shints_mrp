           tObj.DEPOSIT_AMT = AFLib.numToFixed(parseFloat(tObj.DEPOSIT_AMT), 2);
           tObj.PAY_AMT = AFLib.numToFixed(parseFloat(tObj.PAY_AMT), 2);
           tObj.END_AMT = AFLib.numToFixed(parseFloat(tObj.END_AMT), 2);

           var tSql9 = `
               select
                   isnull(a.SEQ, 0) as SEQ,
