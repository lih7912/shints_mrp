            else tObjTot.rate = 0.0;
            tSumArrayShip.push(tObjTot);

            try {
                var tSQL = '';

                // Excel Read
                var tPath0 = '';
                var tCols0 = __dirname.split('/');
                var tFlag0 = 0;
                tCols0.forEach((col, i) => {
                    if (col !== '') {
                        if (col === 'src') {
