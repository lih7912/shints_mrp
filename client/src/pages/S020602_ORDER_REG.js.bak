                    tObj0.SHIP_QTY = tObj1.SHIP_QTY;
                    tObj0.SHIP_PRICE = tObj1.SHIP_PRICE;
                    tObj0.SALES_PRICE = tObj1.SALES_PRICE;
                    tObj0.INVOICE_NO = tObj1.INVOICE_NO;
                    tObj0.DELIVERY_TYPE_NAME = tObj1.DELIVERY_TYPE_NAME;
                    tObj0.COUNTRY = tObj1.COUNTRY;
                    tShipQty += parseFloat(tObj1.SHIP_QTY);
                    if (parseFloat(tObj0.SALES_PRICE) > 0)
                        sumSellQty += parseFloat(tObj1.SHIP_QTY);
                    else sumFocQty += parseFloat(tObj1.SHIP_QTY);
                    tArrayInvoice.push(tObj0);
                }
                setDatasTBL_KSV_ORDER_MEM3_1(tArrayInvoice);

                // Price 정보 Update
                var tUserInfo = serviceLib.getUserInfo();
                if (tUserInfo.USER_ID === "won21kr")
                    setDataPrice(
                        `${data.ORDER_MST[0].AVR_PRICE}/${data.ORDER_MST[0].USD_PRICE}`,
                    );
                else setDataPrice(``);

                if (tArrayInvoice.length > 0) {
                    var valPrice = 0;
                    var valTotalAmt = 0;
                    var valTotalQty = 0;
                    tArrayInvoice.forEach((col10, i10) => {
                        var tmpAmt =
                            parseFloat(col10.SHIP_QTY) *
                            parseFloat(col10.SALES_PRICE);

                        if (col10.CURR_CD === data.ORDER_MST[0].CURR_CD) {
                            valTotalAmt += parseFloat(tmpAmt);
                            valTotalQty += parseFloat(col10.SHIP_QTY);
                        } else {
                            var objPrice = {};
                            data.CODE_CURRENCY.forEach((col11, i11) => {
                                if (col11.CURR_CD === col10.CURR_CD)
                                    objPrice = { ...col11 };
                            });
                            var tSrcAmt = tmpAmt * parseFloat(col10.USD_RATE); // SRC Curr-> USD 금액으로

                            objPrice = {};
                            data.CODE_CURRENCY.forEach((col11, i11) => {
                                if (col11.CURR_CD === data.ORDER_MST[0].CURR_CD)
                                    objPrice = { ...col11 };
                            });
                            var tDestAmt =
                                tSrcAmt / parseFloat(objPrice.USD_RATE); // Src USD -> Dest Curr 금액으로
                            valTotalAmt += parseFloat(tDestAmt);
                            valTotalQty += parseFloat(col10.SHIP_QTY);
                        }
                    });
                    // valPrice = valTotalAmt / valTotalQty;
                    valPrice = valTotalAmt / saveShipQty;

                    var tCurrCd = data.ORDER_MST[0].CURR_CD;
                    if (tCurrCd === "KRW") valPrice = valPrice.toFixed(0);
                    else valPrice = valPrice.toFixed(4);
                    _dataEDT_KSV_ORDER_MST1.FOB = valPrice;

                    var objPrice = {};
                    data.CODE_CURRENCY.forEach((col11, i11) => {
