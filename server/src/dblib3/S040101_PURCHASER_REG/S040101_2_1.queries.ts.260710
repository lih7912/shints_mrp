            } else if (objUser.PART === 'M01') {
                // 기획팀 향후 삭제
                tVendorSql = ` and  f2.vendor_type in ('1', '3', '7', '4', '5') `;
            } else {
                if (args.data.PO_CD.length >= 9) {
                } else {
