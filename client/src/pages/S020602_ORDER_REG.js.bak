    const checkRequired = (field, requiredInput) => {
        if (!field) {
            alert(`${requiredInput}정보가 입력되지 않았습니다.`);
            return true;
        }
        return false;
    };
    const saveEDT_KSV_ORDER_MST = () => {
        var tObj = { ...dataEDT_KSV_ORDER_MST1 };
        // if (tObj.ORDER_CD === '') {

        let tEdit1 = { ...dataEDT_KSV_ORDER_MST };
        if (checkRequired(tEdit1.STYLE_CD, "Style")) return;
        if (checkRequired(tEdit1.BUYER_CD, "Buyer")) return;
        if (checkRequired(tEdit1.PRICE_TERM, "Price Term")) return;
        if (checkRequired(tEdit1.BUYER_TEAM, "Buyer Team")) return;

        let tEdit2 = { ...dataEDT_KSV_ORDER_MST1 };
        if (checkRequired(tEdit2.FACTORY_CD, "Factory")) return;

        if (tEdit2.IS_SAMPLE !== "1") {
            if (checkRequired(tEdit2.CURR_CD, "Currency")) return;
            if (checkRequired(tEdit2.FOB, "FOB")) return;
            if (checkRequired(tEdit2.FOB_USD, "FOB")) return;
        }

        if (workMode === "reg" && tObj.ORDER_CD !== "") {
            alert(
                "등록된 Order는 다시 등록 할 수 없습니다. Reset후 새 오더를 등록하십시요",
            );
            return;
        }

        if (workMode === "reg") {
            var tObjMST1 = { ...dataEDT_KSV_ORDER_MST1 };
            tObjMST1.ORDER_CD = "";
            setDataEDT_KSV_ORDER_MST1(tObjMST1);

            saveEDT_KSV_ORDER_MST_INSERT("0");
        } else {
            if (workMode === "info") saveEDT_KSV_ORDER_MST_INSERT("1");
            else if (workMode === "change") saveEDT_KSV_ORDER_MST_INSERT("2");
            toast.current.show({
                severity: "success",
                summary: "Info",
                detail: "Order를 수정합니다",
                life: 3000,
            });
        }
    };

    const saveEDT_KSV_ORDER_MST_INSERT = (argMode, argMode2) => {
        var tInsertObj = {};

        var tObjMST1 = { ...dataEDT_KSV_ORDER_MST1 };
        tObjMST1.ORDER_QTY = String(tObjMST1.ORDER_QTY);
        tObjMST1.ADD_QTY = String(tObjMST1.ADD_QTY);
        tObjMST1.FOB = String(serviceLib.numToFixed(tObjMST1.FOB, 2));
        delete tObjMST1.ORDER_QTY_ONLY;

        if (parseFloat(tObjMST1.ORDER_QTY) <= 0) {
            alert("오더 수량이 0인 것은 등록할수 없습니다");
            return;
        }

        var tEdtObj = { ...dataEDT_KSV_ORDER_MST };
        tEdtObj.XX_ORDER_REMAIN = String(
            parseInt(tEdtObj.XX_ORDER_QTY) - parseInt(tObjMST1.ORDER_QTY),
        );
        setDataEDT_KSV_ORDER_MST(tEdtObj);
        tInsertObj.ORDER_MST = { ...tEdtObj };

        if (
            tInsertObj.ORDER_MST.PRICE_TERM === "" &&
            argMode !== "4" &&
            argMode !== "3"
        ) {
            setPopupDialog(true);
            return;
        }

        if (argMode !== "4") {
            if (checkRequired(tObjMST1.FACTORY_CD, "Factory")) return;
            if (checkRequired(tObjMST1.CURR_CD, "Currency")) return;
            if (checkRequired(tObjMST1.FOB, "FOB")) return;
            if (checkRequired(tObjMST1.SIZE_GROUP, "Size")) return;
        }

        var _tObj4 = { ...dataEDT_KSV_ORDER_MST4 };

        if (argMode !== "4") {
            if (checkRequired(_tObj4.EXF_DATE, "EXF Date")) return;
        }

        tInsertObj.ORDER_MST2 = { ...dataEDT_KSV_ORDER_MST2 };
        if (tObjMST1.FACTORY_CD === "FC010" && argMode !== "4") {
            if (checkRequired(tInsertObj.ORDER_MST2.SAMPLE_STEP, "SAMPLE 단계"))
                return;
            if (
                checkRequired(tInsertObj.ORDER_MST2.SAMPLE_ROUND, "SAMPLE 차수")
            )
                return;
            if (
                checkRequired(
                    tInsertObj.ORDER_MST2.SAMPLE_REASON,
                    "SAMPLE 원인",
                )
            )
                return;
        }

        var tOrderMemArray = [];

        let _dataEDT_KSV_ORDER_MST = { ...dataEDT_KSV_ORDER_MST };

        var tORDER_MST_ARRAY = [];

        var isOldCombined = 0;
        var tmpArray100 = [];
        datasTBL_KSV_ORDER_MST.forEach((col, i) => {
            var tObj = { ...col };
            if (
                tObj.ORDER_CD.length === 13 &&
                tObj.ORDER_CD.substring(11, 12) === "D"
            ) {
                isOldCombined = 1;
                tObj.TYPE = `Combined-D`;
            }
            if (
                tObj.ORDER_CD.length === 13 &&
                tObj.ORDER_CD.substring(11, 12) === "Z"
            ) {
                isOldCombined = 1;
                tObj.TYPE = `Combined-Z`;
            }
            tmpArray100.push(tObj);
        });

        tmpArray100.forEach((col, i) => {
            var tObj = { ...col };
            if (isOldCombined === 1) tObj.IS_OLD_COMBINED = "1";
            else tObj.IS_OLD_COMBINED = "0";
            if (tObj.TYPE === "Main" || tObj.TYPE === "Combined")
                tORDER_MST_ARRAY.push(tObj);
        });

        var tIdx = 0;
        var tSumAmt = 0.0;
        var tSumQty = 0.0;

        for (tIdx = 0; tIdx < tORDER_MST_ARRAY.length; tIdx++) {
            var tOneObj = { ...tORDER_MST_ARRAY[tIdx] };
            if (
                tInsertObj.ORDER_MST.IS_COMBINED !== "1" ||
                (tInsertObj.ORDER_MST.IS_COMBINED === "1" &&
                    tORDER_MST_ARRAY.length < 2)
            ) {
                let _dataEDT_KSV_ORDER_MST4 = { ...dataEDT_KSV_ORDER_MST4 };
                tOneObj.NAT_CD = _dataEDT_KSV_ORDER_MST4.NAT_CD;
                tOneObj.BUYER_PO = _dataEDT_KSV_ORDER_MST4.BUYER_PO;
                tOneObj.EXF_DATE = _dataEDT_KSV_ORDER_MST4.EXF_DATE;
                tOneObj.ETD_DATE = _dataEDT_KSV_ORDER_MST4.ETD_DATE;
                tOneObj.IS_DL = _dataEDT_KSV_ORDER_MST4.IS_DL;
                tOneObj.REMARK1 = _dataEDT_KSV_ORDER_MST4.REMARK1;
                tOneObj.REMARK2 = _dataEDT_KSV_ORDER_MST4.REMARK2;
                tOneObj.NOTE = _dataEDT_KSV_ORDER_MST4.NOTE;
            } else {
                if (tIdx === 0) {
                    var tOneObj1 = { ...tORDER_MST_ARRAY[1] };
                    tOneObj.NAT_CD = tOneObj1.NAT_CD;
                    tOneObj.BUYER_PO = "Combined Order";
                    tOneObj.EXF_DATE = tOneObj1.EXF_DATE;
                    tOneObj.ETD_DATE = tOneObj1.ETD_DATE;
                    tOneObj.IS_DL = tOneObj1.IS_DL;
                    tOneObj.REMARK1 = tOneObj1.REMARK1;
                    tOneObj.REMARK2 = tOneObj1.REMARK2;
                    tOneObj.NOTE = tOneObj1.NOTE;
                }
            }

            if (typeof tOneObj.ADD_QTY === "undefined") {
                tOneObj.ADD_QTY = "0";
            }
            tOneObj.ADD_QTY = String(tOneObj.ADD_QTY);
            tOneObj.ORDER_QTY = String(tOneObj.ORDER_QTY);

            var tArray = [];
            if (tIdx === 0 && tORDER_MST_ARRAY.length > 1) {
                var tRetObjCalc = calc_MAIN_ORDER_MEM({});
                tArray = [...tRetObjCalc.TmpArray];
                // tArray = [ ...datasTBL_KSV_ORDER_MEM_MAIN ];
                tOneObj.ADD_QTY = String(tRetObjCalc.AddCnt);
                tOneObj.ORDER_QTY = String(tRetObjCalc.TotalCnt);
            } else tArray = [...tOneObj.ORDER_MEM];

            tOneObj.ORDER_MEM = [];

            // Size Array 초기화
            var tSizeQtyArray = [];

            var tOneObj9 = { ...tArray[0] };
            var tKeys9 = Object.keys(tOneObj9);
            var tIdx9 = 0;
            for (tIdx9 = 0; tIdx9 < tKeys9.length; tIdx9++) {
                var tKey = tKeys9[tIdx9];
                if (tKey.includes("SIZE_COL")) {
                    var tName = tKey.replace("SIZE_COL_", "");
                    var tObj = {};
                    tObj.name1 = tName;
                    tObj.value1 = 0;
                    tSizeQtyArray.push(tObj);
                }
            }

            var tIdx1 = 0;
            for (tIdx1 = 0; tIdx1 < tArray.length; tIdx1++) {
                var tOneObj1 = tArray[tIdx1];

                var tWObj = {};
                tWObj.id = tOneObj1.id;
                tWObj.PROD_CD = tOneObj1.PROD_CD;
                tWObj.ADD_FLAG = tOneObj1.ADD_FLAG;
                tWObj.COLOR = tOneObj1.COLOR;
                tWObj.TOT_CNT = String(tOneObj1.TOT_CNT);
                tWObj.PRICE = String(tOneObj1.PRICE);

                tSumAmt += parseFloat(tWObj.PRICE) * parseFloat(tWObj.TOT_CNT);
                tSumQty += parseFloat(tWObj.TOT_CNT);

                var tKeys = Object.keys(tOneObj1);
                var tIdx2 = 0;
                var tSizeCnt = "";

                var tSaveName = "";
                var tSaveQty = 0;
                for (tIdx2 = 0; tIdx2 < tKeys.length; tIdx2++) {
                    var tKey = tKeys[tIdx2];
                    if (tKey.includes("SIZE_COL")) {
                        var tValue = tOneObj1[`${tKey}`];
                        tSizeCnt += makeNumberFormat(tValue, 6);

                        var tName = tKey.replace("SIZE_COL_", "");
                        if (parseInt(tValue) > tSaveQty) {
                            tSaveName = tName;
                            tSaveQty = parseInt(tValue);
                        }

                        var tTmpArray = [];
                        tSizeQtyArray.forEach((col, i) => {
                            var tObj = { ...col };
                            if (tObj.name1 === tName) {
                                tObj.value1 += parseInt(tValue);
                            } else {
                            }
                            tTmpArray.push(tObj);
                        });
                        tSizeQtyArray = [...tTmpArray];
                    }
                }
                tWObj.SIZE_CNT = tSizeCnt;
                tWObj.MID_SIZE = tSaveName;
                tWObj.MID_SIZE_QTY = String(tSaveQty);
                tOneObj.ORDER_MEM.push(tWObj);
            }

            var tSaveName = "";
            var tSaveQty = 0;
            tSizeQtyArray.forEach((col, i) => {
                if (col.value1 > tSaveQty) {
                    tSaveName = col.name1;
                    tSaveQty = col.value1;
                }
            });
            tOneObj.MID_SIZE = tSaveName;
            tOneObj.MID_SIZE_QTY = tSaveName;
            tOrderMemArray.push(tOneObj);
        }

        var tObjMST1 = { ...dataEDT_KSV_ORDER_MST1 };
        //  수정 Price
        var tPriceAvr = tSumAmt / tSumQty;

        if (datasTBL_KSV_ORDER_MEM3.length > 0) {
            // 선적서류가 있는경우 화면의 금액 사용
        } else {
            // 선적내용이 없는 경우. 화면상의 주문금액 가중평균
        }
        tObjMST1.ADD_QTY = String(tObjMST1.ADD_QTY);
        tObjMST1.ORDER_QTY = String(tObjMST1.ORDER_QTY);
        delete tObjMST1.ORDER_QTY_ONLY;
        tInsertObj.ORDER_MST1 = { ...tObjMST1 };
        tInsertObj.ORDER_MST_ARRAY = [...tOrderMemArray];
        tInsertObj.OP_MODE = argMode;
        tInsertObj.OP_MODE2 = "";
        if (argMode2) tInsertObj.OP_MODE2 = argMode2;
        console.log(tInsertObj);
        //setIsProgress(true);

        serviceS020602_ORDER_REG
            .mgrInsert_KSV_ORDER_MST(tInsertObj)
            .then((data) => {
                if (typeof data.graphQLErrors === "undefined") {
                    console.log(
                        "ServiceS020602_ORDER_REG.mgrInsert_KSV_ORDER_MST() call => " +
                            data.length,
                    );
                    if (data.length > 0) {
                        setIsProgress(false);
                        var tRetObj = data[0];
                        if (argMode === "4") {
                            alert(tRetObj.CODE);
                            setCreateDialog(false);
                            process_REFRESH(dataEDT_KSV_ORDER_MST1.ORDER_CD);
                            return;
                        }
                        if (argMode === "3") {
                            alert(tRetObj.CODE);
                            setCreateDialog(false);
                            process_REFRESH(dataEDT_KSV_ORDER_MST1.ORDER_CD);
                            return;
                        }
                        if (tRetObj.CODE.includes("ERR")) {
                            setIsProgress(false);
                            alert(tRetObj.CODE);
                        } else {
                            if (tRetObj.CODE.includes("SUCC")) {
                                alert(tRetObj.CODE);
                                process_REFRESH(
                                    dataEDT_KSV_ORDER_MST1.ORDER_CD,
                                );
                            } else {
                                var tObjMST1 = { ...dataEDT_KSV_ORDER_MST1 };
                                tObjMST1.ORDER_CD = tRetObj.CODE;
                                setDataEDT_KSV_ORDER_MST1(tObjMST1);
                                process_REFRESH(tRetObj.CODE);
                            }
                        }
                    }
                    // Search
                } else {
                    setIsProgress(false);
