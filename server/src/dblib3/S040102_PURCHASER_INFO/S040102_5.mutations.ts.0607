                    pu_cd = '${tInput.PU_CD}'
            `;
            var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL));
            var tPuMst2 = {};
            if (nRet0.length > 0) {
                tPuMst2 = nRet0[0];
            }

            var tPayReports = [];
            var tCancelAmt = 0;
            var sql0 = `
                select
                    *
