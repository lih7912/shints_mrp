import { ServiceLib } from '../service/service_lib/ServiceLib';
import apiOption from '../assets/env_graphql';
import $ from 'jquery';

import '../App.scss';

/** Core: 실제 UI (memo 대상) */
const MgrKzzAcctCore = ({ pathname }) => {
  // 로그인 확인(마운트 1회) + 초기 로드
  const toast = useRef(null);
  const serviceLibRef = useRef(null);

  useEffect(() => {
    serviceLibRef.current = new ServiceLib();
    serviceLibRef.current.loginConfirm();

    // 초기 로드
    fetchCostCenters();
    fetchSuppliers();
    fetchAccts();
    // 초기 목록(필터 기본값) 조회
    fetchList();

    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  // ====== 상수/상태 ======
  // 상태 드롭다운: 고정값
  const STATUS_OPTIONS = [
    { label: 'ALL', value: '' },
    { label: '등록', value: '등록' },
    { label: '상신', value: '상신' },
    { label: '취소', value: '취소' },
    { label: '종결', value: '종결' },
    { label: '삭제요청', value: '삭제요청' },
    { label: '삭제완료', value: '삭제완료' },
    { label: '전표', value: '전표' },
    { label: '송금', value: '송금' },
    { label: '반려', value: '반려' },
  ];
  // 로컬 yyyy-MM-dd 포맷터
  const formatDateLocal = (d) => {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  };

  // 기본값 계산 (오늘/한달 전)
  const today = new Date();
  const defaultDateTo = formatDateLocal(today);
  const monthAgo = new Date(today);
  monthAgo.setMonth(today.getMonth() - 1); // 3/31 → 2/29 같은 경우도 JS가 자동 보정
  const defaultDateFrom = formatDateLocal(monthAgo);

  // 기간 기준 옵션 (라디오)
  // 'closing' = 종빙일, 'request' = 송금요청일, 'all' = 모든기간
  const [dateType, setDateType] = useState('closing');
  const [dateFrom, setDateFrom] = useState(defaultDateFrom);
  const [dateTo, setDateTo] = useState(defaultDateTo);

  // 상태
  const [status, setStatus] = useState(''); // ''=ALL

  // ── 코스트센터 Dropdown 상태 ─────────────────────────────
  const [ccOptions, setCcOptions] = useState([{ label: '전체', value: '' }]);
  const [ccSelected, setCcSelected] = useState(''); // '' = 전체
  const [ccLoading, setCcLoading] = useState(false);

  // ── 거래처(Supplier) Dropdown 상태 ──────────────────────
  const [supplierOptions, setSupplierOptions] = useState([{ label: '전체', value: '' }]);
  const [supplierSelected, setSupplierSelected] = useState('');
  const [supplierLoading, setSupplierLoading] = useState(false);

  // ── 계정과목(Acct) Dropdown 상태 ────────────────────────
  const [acctOptions, setAcctOptions] = useState([{ label: '전체', value: '' }]);
  const [acctSelected, setAcctSelected] = useState('');
  const [acctLoading, setAcctLoading] = useState(false);

  // ── 목록 데이터 ──────────────────────────────────────────
  const [rows, setRows] = useState([]);
  const [listLoading, setListLoading] = useState(false);

  // ====== API 호출 (옵션 포맷 전용) ======
  const API_BASE = 'https://insa.shints.com/StsApp';

  // 코스트센터 목록
  const fetchCostCenters = async () => {
    setCcLoading(true);
    try {
      const { data } = await axios.get(`${API_BASE}/LoadCC`);
      const items = Array.isArray(data) ? data : [];
      setCcOptions([{ label: '전체', value: '' }, ...items]);
      setCcSelected((prev) => (prev === undefined || prev === null ? '' : prev));
    } catch (e) {
      console.error(e);
      toast.current?.show({
        severity: 'error',
        summary: '코스트센터',
        detail: '목록을 불러오지 못했습니다.',
        life: 3000,
      });
    } finally {
      setCcLoading(false);
    }
  };

  // 거래처(Supplier) 목록
  const fetchSuppliers = async () => {
    setSupplierLoading(true);
    try {
      const { data } = await axios.get(`${API_BASE}/LoadSupplier`);
      const items = Array.isArray(data) ? data : [];
      setSupplierOptions([{ label: '전체', value: '' }, ...items]);
      setSupplierSelected((prev) => (prev === undefined || prev === null ? '' : prev));
    } catch (e) {
      console.error(e);
      toast.current?.show({
        severity: 'error',
        summary: '거래처',
        detail: '목록을 불러오지 못했습니다.',
        life: 3000,
      });
    } finally {
      setSupplierLoading(false);
    }
  };

  // 계정과목(Acct) 목록
  const fetchAccts = async () => {
    setAcctLoading(true);
    try {
      const { data } = await axios.get(`${API_BASE}/LoadAcct`);
      const items = Array.isArray(data) ? data : [];
      setAcctOptions([{ label: '전체', value: '' }, ...items]);
      setAcctSelected((prev) => (prev === undefined || prev === null ? '' : prev));
    } catch (e) {
      console.error(e);
      toast.current?.show({
        severity: 'error',
        summary: '계정과목',
        detail: '목록을 불러오지 못했습니다.',
        life: 3000,
      });
    } finally {
      setAcctLoading(false);
    }
  };
  // yyyyMMdd or yyyy-MM-dd → yyyy-MM-dd 로 표시
  const formatDateYMD = (v) => {
    if (v == null) return '';
    const s = String(v).trim();
    if (!s) return '';
    const digits = s.replace(/\D/g, ''); // 숫자만
    if (digits.length === 8) {
      const y = digits.slice(0, 4);
      const m = digits.slice(4, 6);
      const d = digits.slice(6, 8);
      return `${y}-${m}-${d}`;
    }
    return s; // 다른 형태면 그대로
  };

  // 금액 천단위 콤마
  const formatMoney = (v) => {
    if (v == null || v === '') return '';
    const num = typeof v === 'number' ? v : Number(String(v).replace(/,/g, '').trim());
    if (!isFinite(num)) return String(v);
    return num.toLocaleString('ko-KR'); // 12,345 형식
  };

  // ====== 조회(LoadList) 호출 ======
  // 서버가 기대하는 파라미터 키는 다음으로 가정했습니다:
  // cc, supplier, acct, status, dateFrom, dateTo, dateType
  // (필요 시 서버 명세에 맞춰 키 이름만 바꾸세요.)
  const fetchList = async () => {
    setListLoading(true);
    try {
      const params = {
        cc: ccSelected || '',
        supplier: supplierSelected || '',
        acct: acctSelected || '',
        status: status || '',
        dateFrom: dateFrom || '',
        dateTo: dateTo || '',
        dateType: dateType || 'closing', // 'closing' | 'request' | 'all'
      };

      const { data } = await axios.get(`${API_BASE}/LoadList`, { params });

      // 서버 응답 -> 그리드에 표시할 필드로 정규화
      // 응답 필드명이 다를 수 있어 안전하게 매핑합니다.
      const normalize = (r) => ({
        id: r?.id ?? `${r?.CODE ?? r?.code ?? ''}-${r?.REQ_DATE ?? r?.req_date ?? ''}-${r?.VENDOR ?? r?.vendor ?? ''}`,
        code: r?.CODE ?? r?.code ?? '',
        status: r?.STATUS ?? r?.status ?? '',

        // ✅ 날짜 포맷 적용 (yyyy-MM-dd)
        closingDate: formatDateYMD(r?.CLOSING_DATE ?? r?.closing_date ?? r?.closingDate ?? ''),
        reqDate:     formatDateYMD(r?.REQ_DATE     ?? r?.req_date     ?? r?.requestDate ?? ''),
        payDate:     formatDateYMD(r?.PAY_DATE     ?? r?.pay_date     ?? r?.remitDate   ?? ''),

        costCenter: r?.COST_CENTER ?? r?.cost_center ?? r?.costCenter ?? '',
        account:    r?.ACCOUNT     ?? r?.account     ?? r?.acct       ?? '',
        currency:   r?.CURR        ?? r?.currency    ?? '',

        // ✅ 금액 포맷 적용 (천단위 콤마)
        amount: formatMoney(r?.AMOUNT ?? r?.amount ?? 0),

        vendor: r?.VENDOR ?? r?.vendor ?? r?.supplier ?? '',
        card:   r?.CARD   ?? r?.card   ?? '',
        method: r?.METHOD ?? r?.method ?? '',
      });

      const list = Array.isArray(data) ? data.map(normalize) : [];
      setRows(list);
    } catch (e) {
      console.error(e);
      toast.current?.show({
        severity: 'error',
        summary: '조회',
        detail: '목록을 불러오지 못했습니다.',
        life: 3000,
      });
      setRows([]);
    } finally {
      setListLoading(false);
    }
<<<<<<< HEAD
  };

  // ====== 액션 ======
  const handleSearch = () => {
    fetchList();
  };
  
  const resetDatesToDefault = () => {
  const now = new Date();
  const to = formatDateLocal(now);
  const fromDate = new Date(now);
  fromDate.setMonth(now.getMonth() - 1);
  const from = formatDateLocal(fromDate);
  setDateFrom(from);
  setDateTo(to);
  };

  const handleReset = () => {
    setCcSelected('');
    setSupplierSelected('');
    setAcctSelected('');
    setStatus('');
    setDateType('closing');
    resetDatesToDefault();          // ✅ 여기서 기본값으로 되돌림
    setRows([]);
    setTimeout(() => fetchList(), 0);
  };

  return (
