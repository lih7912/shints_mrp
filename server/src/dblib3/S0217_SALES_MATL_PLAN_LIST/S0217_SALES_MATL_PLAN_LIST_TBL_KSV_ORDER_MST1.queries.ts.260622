                        YYMM,
                        SUM(PLAN_QTY) as YYMM_QTY,
                        SUM(PLAN_AMT) as YYMM_AMT
                    FROM
                        ${tTableName}
                    WHERE
                        YYMM BETWEEN '${args.data.S_DATE}' AND '${args.data.E_DATE}'
                        AND COLLECTION = '${tOne.COLLECTION}'
                        AND CURR_CD = '${tOne.CURR_CD}'
                    GROUP BY
