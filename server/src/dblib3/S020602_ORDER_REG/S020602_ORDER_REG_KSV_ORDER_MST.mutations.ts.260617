                    *
                from
                    ksv_order_mst
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));
            var tInput1 = nRet1[0];

            switch (tInput1.ORDER_STATUS) {
                case '9':
                    return [{ CODE: 'Already Ended Ship Status.', id: 0 }];
                case '8':
                    return [{ CODE: 'Already End Reported.', id: 0 }];
                case '*':
                    return [{ CODE: 'Approval waiting status.', id: 0 }];
            }

            let query = `
                select
                    isnull(sum(ship_cnt), 0) as SUM_SHIP_CNT
                from
                    ksv_order_ship
                where
                    ORDER_CD = '${tInput.ORDER_CD}'
            `;
            let shipCnt = (await prisma.$queryRaw(Prisma.raw(query)))[0]
                .SUM_SHIP_CNT;

            if (shipCnt <= 0) {
                return [{ CODE: 'No Shipment history exists.', id: 0 }];
            }

            /*
      if (tInput1.ORDER_STATUS !== '3' && tInput1.ORDER_STATUS !== '5') {
         var tRetArray = [];
         var tObj = {};
         tObj.CODE = 'ERROR:선적완료는 Part Ship  or PO 상태인것만 선적완료 처리 할수 있습니다.';
         tObj.id = 0; 
         tRetArray.push(tObj);
         return (tRetArray);
      }
         */

            let tSQL99 = `
