                    sum(F0.SHIP_AMOUNT) as SHIP_AMOUNT,
                    isnull(sum(F0.TOT_CNT), 0) as ORDER_QTY,
                    0 as SHIP_AMOUNT3,
                    F.PAYMENT_TYPE,
                    G.CD_NAME AS PAYMENT_NAME,
