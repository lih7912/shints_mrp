                    tMessage = `Total ${tDatas.length} record inquried.  Output 1000 Record. `;
                    break;
                }

                if (tOne1.PU_CD === '') {
                    var tSql2_0 = `
                        select
                            *
                        from
                            ksv_pu_mst2
                        where
                            vendor_cd = '${tOne1.VENDOR_CD}'
