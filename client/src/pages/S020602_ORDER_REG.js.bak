    const onRowClick1TBL_KSV_ORDER_MST_Sub = (
        argData0,
        argData1,
        argSizeGroup,
        argMode,
    ) => {
        var tWArray = [...argData1];
        var argData = {};

        if (typeof argData0.length !== "undefined") {
            argData = { ...argData0[0] };
        } else {
            argData = { ...argData0 };
        }

        if (argSizeGroup === "") {
            alert(
                `Size을 먼저 선택해야 합니다. 해당 Buyer에 대한 Size가 없는경우 Size을 먼저 등록하세요`,
            );
            return;
        }

        tSaveTBL_KSV_ORDER_MST_ID = argData.id;

        var tMainArray = [];

        if (
            argData.TYPE === "Main" &&
            dataEDT_KSV_ORDER_MST.IS_COMBINED === "1" &&
            tWArray.length > 1
        ) {
            // if (argData.TYPE === "Main" || argData.TYPE === "Combined") {

            var _dataEDT_KSV_ORDER_MST1 = { ...dataEDT_KSV_ORDER_MST1 };
            var _tTotalCnt = 0;
            var _tAddCnt = 0;

            var tRetObjCalc = calc_MAIN_ORDER_MEM(argData);
            _tTotalCnt = tRetObjCalc.TotalCnt;
            _tAddCnt = tRetObjCalc.AddCnt;

            console.log(
                argData.TYPE +
                    "," +
                    dataEDT_KSV_ORDER_MST.IS_COMBINED +
                    "," +
                    tWArray.length,
            );
            console.log(_tTotalCnt + "," + _tAddCnt);

            var tTmpArray = [...tRetObjCalc.TmpArray];

            _dataEDT_KSV_ORDER_MST1.ORDER_QTY = _tTotalCnt;
            _dataEDT_KSV_ORDER_MST1.ADD_QTY = _tAddCnt;
            _dataEDT_KSV_ORDER_MST1.ORDER_QTY_ONLY = String(
                _tTotalCnt - _tAddCnt,
            );
            setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);

            argData.ORDER_QTY = _tTotalCnt;
            argData.ADD_QTY = _tAddCnt;

            let argTBL_KSV_ORDER_MST = argData;
            editTBL_KSV_ORDER_MST(argTBL_KSV_ORDER_MST);
            setDataTBL_KSV_ORDER_MST(argTBL_KSV_ORDER_MST);

            setSelectedTBL_KSV_ORDER_MST(argData);

            console.log(
                `calc_MAIN_ORDER_MEM(Step1): ${tTmpArray.length}/`,
                tTmpArray,
                argData,
            );
            if (typeof tTmpArray.ORDER_MEM !== "undefined") {
                tTmpArray.ORDER_MEM.forEach((item, index) => {
                    item.seq = index + 1;
                });
            }
            setDatasTBL_KSV_ORDER_MEM(tTmpArray);
            setDatasTBL_KSV_ORDER_MEM_MAIN(tTmpArray);
            // setDatasTBL_KSV_ORDER_MEM (tMainArray);
            // setDatasTBL_KSV_ORDER_MEM (argData.ORDER_MEM);

            setSelectedTBL_KSV_PROD_MEM([]);
            setSelectedTBL_KSV_ORDER_MEM([]);

            var tSelArray = [];
            datasTBL_KSV_PROD_MEM.forEach((col2, i2) => {
                var tObj2 = { ...col2 };
                tTmpArray.forEach((col3, i3) => {
                    if (tObj2.COLOR === col3.COLOR) tSelArray.push(tObj2);
                });
            });
            setSelectedTBL_KSV_PROD_MEM(tSelArray);
        } else {
            let argTBL_KSV_ORDER_MST = argData;
            editTBL_KSV_ORDER_MST(argTBL_KSV_ORDER_MST);
            setDataTBL_KSV_ORDER_MST(argTBL_KSV_ORDER_MST);

            setSelectedTBL_KSV_ORDER_MST(argData);
            argData.ORDER_MEM.forEach((item, index) => {
                item.seq = index + 1;
            });

            setDatasTBL_KSV_ORDER_MEM(argData.ORDER_MEM);
            setSelectedTBL_KSV_PROD_MEM([]);
            setSelectedTBL_KSV_ORDER_MEM([]);

            var tSelArray = [];
            datasTBL_KSV_PROD_MEM.forEach((col2, i2) => {
                var tObj2 = { ...col2 };
                argData.ORDER_MEM.forEach((col3, i3) => {
                    if (tObj2.COLOR === col3.COLOR) tSelArray.push(tObj2);
                });
            });
            setSelectedTBL_KSV_PROD_MEM(tSelArray);
        }

        if (typeof argMode !== "undefined") {
        } else {
            let _dataEDT_KSV_ORDER_MST4 = { ...dataEDT_KSV_ORDER_MST4 };
            _dataEDT_KSV_ORDER_MST4.BUYER_PO = argData.BUYER_PO;
            _dataEDT_KSV_ORDER_MST4.NAT_CD = argData.NAT_CD;
            _dataEDT_KSV_ORDER_MST4.EXF_DATE = argData.EXF_DATE;
            _dataEDT_KSV_ORDER_MST4.ETD_DATE = argData.ETD_DATE;
            _dataEDT_KSV_ORDER_MST4.REF_ORDER_NO = argData.REF_ORDER_NO;
            _dataEDT_KSV_ORDER_MST4.REMARK1 = argData.REMARK1;
            _dataEDT_KSV_ORDER_MST4.REMARK2 = argData.REMARK2;
            _dataEDT_KSV_ORDER_MST4.NOTE = argData.NOTE;
