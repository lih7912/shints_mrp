            `;
            var tRet0 = await prisma.$queryRaw(Prisma.raw(sqlStr));
            var tRet = [];
            var tIdx0 = 0;
            for (tIdx0 = 0; tIdx0 < tRet0.length; tIdx0++) {
                var tObj = { ...tRet0[tIdx0] };
                let sql100 = `
                    select
                        *
                    from
