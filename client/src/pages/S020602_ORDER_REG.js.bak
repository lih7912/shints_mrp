            setIS_FACTORY_ETP("1");
        } else {
            setIS_FACTORY_SHINTS("0");
            setIS_FACTORY_BVT("0");
            setIS_FACTORY_ETP("0");
        }
    };
    const onCheckboxChangeFACTORY = (e, name) => {
        let val = "";
        if (e.checked) {
            val = "1";
        } else {
            val = "0";
        }

        var tObj = { ...dataEDT_KSV_ORDER_MST1 };
        if (name === "SHINTS" && val === "1") {
