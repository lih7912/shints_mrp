const S020602_ORDER_REG = () => {
    const isMountedRef = useRef(true);

    // 컴포넌트 언마운트 시 cleanup
    useEffect(() => {
        return () => {
            isMountedRef.current = false;
        };
    }, []);

    const serviceLibRef = useRef(null);
    if (!serviceLibRef.current) {
        serviceLibRef.current = new ServiceLib();
        serviceLibRef.current.loginConfirm();
    }
    const serviceLib = serviceLibRef.current;
    const serviceS020602_ORDER_REGRef = useRef(null);
    if (!serviceS020602_ORDER_REGRef.current) serviceS020602_ORDER_REGRef.current = new ServiceS020602_ORDER_REG();
    const serviceS020602_ORDER_REG = serviceS020602_ORDER_REGRef.current;
    const serviceS0200_KCD_STYLERef = useRef(null);
    if (!serviceS0200_KCD_STYLERef.current) serviceS0200_KCD_STYLERef.current = new ServiceS0200_KCD_STYLE();
    const serviceS0200_KCD_STYLE = serviceS0200_KCD_STYLERef.current;

    const toast = useRef(null);
    var tSaveTBL_KSV_ORDER_MST_ID = -1;

    /* */
    const [value_PATTERN, setValue_PATTERN] = useState("");
    const [value_SEW, setValue_SEW] = useState("");
    const [saveOrderMstOld, setSaveOrderMstOld] = useState([]);
    const [saveCurrency, setSaveCurrency] = useState([]);

    /* progress */
    const [isProgress, setIsProgress] = useState(false);
    const [popupDialog, setPopupDialog] = useState(false);
    const [createDialog, setCreateDialog] = useState(false);

    // Image
    const [dataUrlImage, setDataUrlImage] = useState("");

    const [saveJOB_CD, setSaveJOB_CD] = useState("");
    const [dataPrice, setDataPrice] = useState("");

    /* splitter 관련 */
    const [styleVal, setStyleVal] = useState({ width: "65vw" });

    const [saveOrderMst, setSaveOrderMst] = useState({});
    const [saveStyleInfo, setSaveStyleInfo] = useState({});

    const [workMode, setWorkMode] = useState("reg");
    const [styleVal1, setStyleVal1] = useState({
        width: "123rem",
        height: "22rem",
    });
    const [styleVal1_1, setStyleVal1_1] = useState({
        display: "none",
        width: "123rem",
        height: "9rem",
    });
    const [styleVal1_2, setStyleVal1_2] = useState({
        display: "none",
        width: "13rem",
    });
    const [styleVal1_2_1, setStyleVal1_2_1] = useState({
        display: "none",
        width: "13rem",
    });
    const [styleVal1_3, setStyleVal1_3] = useState({
        display: "none",
        width: "13rem",
    });
    const [styleValReg, setStyleValReg] = useState({
        display: "none",
        width: "13rem",
    });
    const set_REG_STYLE = (e) => {
        let rVal = { ...styleVal1 };
        rVal.display = "none";
        setStyleVal1(rVal);

        rVal = { ...styleVal1_1 };
        rVal.display = "none";
        setStyleVal1_1(rVal);

        rVal = { ...styleVal1_2 };
        rVal.display = "none";
        setStyleVal1_2(rVal);

        rVal = { ...styleVal1_2_1 };
        rVal.display = "none";
        setStyleVal1_2_1(rVal);

        rVal = { ...styleVal1_3 };
        rVal.display = "none";
        setStyleVal1_3(rVal);

        rVal = { ...styleValReg };
        rVal.display = "inline-block";
        setStyleValReg(rVal);
    };
    const set_INFO_STYLE = (argStatus) => {
        let rVal = { ...styleVal1 };
        rVal.display = "inline-block";
        setStyleVal1(rVal);

        rVal = { ...styleVal1_1 };
        rVal.display = "inline-block";
        setStyleVal1_1(rVal);

        if (argStatus === "Cancel") {
            rVal = { ...styleVal1_2 };
            rVal.display = "none";
            setStyleVal1_2(rVal);

            rVal = { ...styleVal1_2_1 };
            rVal.display = "inline-block";
            setStyleVal1_2_1(rVal);
        } else {
            rVal = { ...styleVal1_2 };
            rVal.display = "inline-block";
            setStyleVal1_2(rVal);

            rVal = { ...styleVal1_2_1 };
            rVal.display = "none";
            setStyleVal1_2_1(rVal);
        }

        rVal = { ...styleValReg };
        rVal.display = "none";
        setStyleValReg(rVal);
    };
    const set_XX_CHANGE_STYLE = (e) => {
        let rVal = { ...styleVal1_3 };
        rVal.display = "inline-block";
        setStyleVal1_3(rVal);

        rVal = { ...styleValReg };
        rVal.display = "none";
        setStyleValReg(rVal);
    };

    const [styleVal2, setStyleVal2] = useState({
        display: "none",
        marginLeft: "0.5rem",
        height: "2rem",
        width: "35rem",
    });

    const [styleVal3, setStyleVal3] = useState({ width: "35rem" });
    const set_STYLE3_N = (e) => {
        const rVal = { ...styleVal3 };
        rVal.display = "none";
        setStyleVal3(rVal);
    };
    const set_STYLE3_Y = (e) => {
        const rVal = { ...styleVal3 };
        rVal.display = "block";
        setStyleVal3(rVal);
    };

    const [styleVal_capa, setStyleVal_capa] = useState({
        display: "inline-block",
        width: "12rem",
    });
    const [styleVal_capa1, setStyleVal_capa1] = useState(true);

    const [styleVal_combine, setStyleVal_combine] = useState({
        display: "none",
        width: "19rem",
    });
    const [styleVal_combine1, setStyleVal_combine1] = useState(true);
    const set_styleVal_combine_N = (e) => {
        const rVal = { ...styleVal_combine };
        rVal.display = "none";
        setStyleVal_combine(rVal);
        setStyleVal_combine1(true);
    };
    const set_styleVal_combine_Y = (e) => {
        const rVal = { ...styleVal_combine };
        rVal.display = "inline-block";
        setStyleVal_combine(rVal);
        setStyleVal_combine1(false);
    };

    const [styleVal_qry, setStyleVal_qry] = useState({
        width: "107rem",
        height: "3rem",
    });
    const [styleVal_change_0, setStyleVal_change_0] = useState({
        display: "none",
        width: "14rem",
    });
    const [styleVal_change_1, setStyleVal_change_1] = useState({
        display: "none",
        width: "13rem",
    });
    const set_styleVal_XX_Change_N = (e) => {
        const rVal = { ...styleVal_qry };
        rVal.height = "3rem";
        setStyleVal_qry(rVal);

        const rVal1 = { ...styleVal_change_0 };
        rVal1.display = "none";
        setStyleVal_change_0(rVal1);

        const rVal2 = { ...styleVal_change_1 };
        rVal2.display = "none";
        setStyleVal_change_1(rVal2);
    };
    const set_styleVal_XX_Change_Y = (e) => {
        const rVal = { ...styleVal_qry };
        rVal.height = "5rem";
        setStyleVal_qry(rVal);

        const rVal1 = { ...styleVal_change_0 };
        rVal1.display = "inline-block";
        setStyleVal_change_0(rVal1);

        const rVal2 = { ...styleVal_change_1 };
        rVal2.display = "inline-block";
        setStyleVal_change_1(rVal2);
    };

    const [styleVal_change, setStyleVal_change] = useState({
        display: "none",
        width: "16rem",
    });
    const set_styleVal_change_N = (e) => {
        const rVal = { ...styleVal_change };
        rVal.display = "none";
        setStyleVal_change(rVal);
    };
    const set_styleVal_change_Y = (e) => {
        const rVal = { ...styleVal_change };
        rVal.display = "inline-block";
        setStyleVal_change(rVal);
    };

    const [styleVal_devsample, setStyleVal_devsample] = useState(true);
    const set_styleVal_devsample_N = (e) => {
        setStyleVal_devsample(true);
    };
    const set_styleVal_devsample_Y = (e) => {
        setStyleVal_devsample(false);
    };

    const [styleVal_approval, setStyleVal_approval] = useState({
        disabled: true,
        width: "16rem",
    });
    const set_styleVal_approval_N = (e) => {
        const rVal = { ...styleVal_approval };
        rVal.disabled = true;
        setStyleVal_approval(rVal);
    };
    const set_styleVal_approval_Y = (e) => {
        const rVal = { ...styleVal_approval };
        rVal.disabled = false;
        setStyleVal_approval(rVal);
    };

    /* Compute Order Qty, Add Qty */
    const recompute_ORDER_QTY = (argData) => {
        var _dataEDT_KSV_ORDER_MST1 = { ...dataEDT_KSV_ORDER_MST1 };

        // var _dataTBL_KSV_ORDER_MST = { ...dataTBL_KSV_ORDER_MST };

        var tSaveObj = {};
        var tORDER_MST_ARRAY = [...datasTBL_KSV_ORDER_MST];
        var tWArray = [];
        var tIdx = 0;
        var tMainTotal = 0;
        var tMainTotalAdd = 0;
        for (tIdx = 0; tIdx < tORDER_MST_ARRAY.length; tIdx++) {
            var tOne = { ...tORDER_MST_ARRAY[tIdx] };

            if (tORDER_MST_ARRAY.length === 1) {
                var tTotQty =
                    parseInt(argData.ORDER_QTY) + parseInt(argData.ADD_QTY);
                tOne.ORDER_QTY = String(tTotQty);
                tOne.ADD_QTY = argData.ADD_QTY;
                tOne.ORDER_QTY_ONLY = String(
                    parseFloat(tTotQty) - parseFloat(argData.ADD_QTY),
                );
                if (tOne.ADD_QTY === null || tOne.ADD_QTY === "")
                    tOne.ADD_QTY = "0";
                tMainTotal += parseInt(tOne.ORDER_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);

                tOne.ORDER_MEM = [...argData.ORDER_MEM];
                tSaveObj = { ...tOne };
                tWArray.push(tOne);
                setDataTBL_KSV_ORDER_MST(tOne);
                continue;
            }

            if (
                tOne.TYPE === "Main" ||
                tOne.TYPE === "Main-D" ||
                tOne.TYPE === "Main-Z"
            ) {
                tWArray.push(tOne);
                continue;
            }
            if (tOne.TYPE === "Combined-D" || tOne.TYPE === "Combined-Z") {
                tWArray.push(tOne);
                continue;
            }

            var tCheckCondition = false;
            if (tOne.ORDER_CD === "") {
                tCheckCondition = tOne.BUYER_PO === argData.BUYER_PO;
            } else {
                tCheckCondition = tOne.ORDER_CD === argData.ORDER_CD;
            }

            if (tCheckCondition) {
                var tTotQty =
                    parseInt(argData.ORDER_QTY) + parseInt(argData.ADD_QTY);
                tOne.ORDER_QTY = String(tTotQty);
                tOne.ADD_QTY = argData.ADD_QTY;
                tOne.ORDER_QTY_ONLY = String(
                    parseFloat(tTotQty) - parseFloat(argData.ADD_QTY),
                );
                if (tOne.ADD_QTY === null || tOne.ADD_QTY === "")
                    tOne.ADD_QTY = "0";
                tMainTotal += parseInt(tOne.ORDER_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);

                tOne.ORDER_MEM = [...argData.ORDER_MEM];
                tSaveObj = { ...tOne };
                tWArray.push(tOne);
                setDataTBL_KSV_ORDER_MST(tOne);
            } else {
                tWArray.push(tOne);
                tMainTotal += parseInt(tOne.ORDER_QTY) + parseInt(tOne.ADD_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);
            }
        }

        var tWArray1 = [];
        tWArray.forEach((col, i) => {
            var tObj = { ...col };
            if (
                tObj.TYPE === "Main" ||
                tObj.TYPE === "Main-D" ||
                tObj.TYPE === "Main-Z"
            ) {
                tObj.ORDER_QTY = String(tMainTotal);
                tObj.ADD_QTY = String(tMainTotalAdd);
                tObj.ORDER_QTY_ONLY = String(tMainTotal - tMainTotalAdd);
                tWArray1.push(tObj);
            } else if (
                (tObj.TYPE === "Combined-D" || tObj.TYPE === "Combined-Z") &&
                tObj.ORDER_CD.substring(0, 13) === argData.ORDER_CD
            ) {
                tObj.ORDER_QTY = tSaveObj.ORDER_QTY;
                tObj.ADD_QTY = tSaveObj.ADD_QTY;
                tObj.ORDER_QTY_ONLY = tSaveObj.ORDER_QTY_ONLY;
                tWArray1.push(tObj);
            } else {
                tWArray1.push(tObj);
            }
        });

        setDatasTBL_KSV_ORDER_MST(tWArray1);

        _dataEDT_KSV_ORDER_MST1.ORDER_QTY = String(tMainTotal);
        _dataEDT_KSV_ORDER_MST1.ADD_QTY = String(tMainTotalAdd);
        _dataEDT_KSV_ORDER_MST1.ORDER_QTY_ONLY = String(
            tMainTotal - tMainTotalAdd,
        );
        setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
    };

    const recompute_ORDER_REMOVE = (argData) => {
        var _dataEDT_KSV_ORDER_MST1 = { ...dataEDT_KSV_ORDER_MST1 };

        // var _dataTBL_KSV_ORDER_MST = { ...dataTBL_KSV_ORDER_MST };

        var tSaveObj = {};
        var tORDER_MST_ARRAY = [...datasTBL_KSV_ORDER_MST];
        var tWArray = [];
        var tIdx = 0;
        var tMainTotal = 0;
        var tMainTotalAdd = 0;
        for (tIdx = 0; tIdx < tORDER_MST_ARRAY.length; tIdx++) {
            var tOne = { ...tORDER_MST_ARRAY[tIdx] };

            if (tORDER_MST_ARRAY.length > 1)
                if (
                    tOne.ORDER_CD.substring(0, 13) ===
                    argData.ORDER_CD.substring(0, 13)
                )
                    continue;

            if (tORDER_MST_ARRAY.length === 1) {
                var tTotQty =
                    parseInt(argData.ORDER_QTY) + parseInt(argData.ADD_QTY);
                tOne.ORDER_QTY = String(tTotQty);
                tOne.ADD_QTY = argData.ADD_QTY;
                tOne.ORDER_QTY_ONLY = String(
                    parseFloat(tTotQty) - parseFloat(argData.ADD_QTY),
                );
                if (tOne.ADD_QTY === null || tOne.ADD_QTY === "")
                    tOne.ADD_QTY = "0";
                tMainTotal += parseInt(tOne.ORDER_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);

                tOne.ORDER_MEM = [...argData.ORDER_MEM];
                tSaveObj = { ...tOne };
                tWArray.push(tOne);
                setDataTBL_KSV_ORDER_MST(tOne);
                continue;
            }

            if (
                tOne.TYPE === "Main" ||
                tOne.TYPE === "Main-D" ||
                tOne.TYPE === "Main-Z"
            ) {
                tWArray.push(tOne);
                continue;
            }
            if (tOne.TYPE === "Combined-D" || tOne.TYPE === "Combined-Z") {
                tWArray.push(tOne);
                continue;
            }

            var tCheckCondition = false;
            if (tOne.ORDER_CD === "") {
                tCheckCondition = tOne.BUYER_PO === argData.BUYER_PO;
            } else {
                tCheckCondition = tOne.ORDER_CD === argData.ORDER_CD;
            }

            if (tCheckCondition) {
                var tTotQty =
                    parseInt(argData.ORDER_QTY) + parseInt(argData.ADD_QTY);
                tOne.ORDER_QTY = String(tTotQty);
                tOne.ADD_QTY = argData.ADD_QTY;
                tOne.ORDER_QTY_ONLY = String(
                    parseFloat(tTotQty) - parseFloat(argData.ADD_QTY),
                );
                if (tOne.ADD_QTY === null || tOne.ADD_QTY === "")
                    tOne.ADD_QTY = "0";
                tMainTotal += parseInt(tOne.ORDER_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);

                tOne.ORDER_MEM = [...argData.ORDER_MEM];
                tSaveObj = { ...tOne };
                tWArray.push(tOne);
                setDataTBL_KSV_ORDER_MST(tOne);
            } else {
                tWArray.push(tOne);
                tMainTotal += parseInt(tOne.ORDER_QTY) + parseInt(tOne.ADD_QTY);
                tMainTotalAdd += parseInt(tOne.ADD_QTY);
            }
        }

        var tWArray1 = [];
        tWArray.forEach((col, i) => {
            var tObj = { ...col };
            if (
                tObj.TYPE === "Main" ||
                tObj.TYPE === "Main-D" ||
                tObj.TYPE === "Main-Z"
            ) {
                tObj.ORDER_QTY = String(tMainTotal);
                tObj.ADD_QTY = String(tMainTotalAdd);
                tObj.ORDER_QTY_ONLY = String(tMainTotal - tMainTotalAdd);
                tWArray1.push(tObj);
            } else if (
                (tObj.TYPE === "Combined-D" || tObj.TYPE === "Combined-Z") &&
                tObj.ORDER_CD.substring(0, 13) === argData.ORDER_CD
            ) {
                tObj.ORDER_QTY = tSaveObj.ORDER_QTY;
                tObj.ADD_QTY = tSaveObj.ADD_QTY;
                tObj.ORDER_QTY_ONLY = tSaveObj.ORDER_QTY_ONLY;
                tWArray1.push(tObj);
            } else {
                tWArray1.push(tObj);
            }
        });

        setDatasTBL_KSV_ORDER_MST(tWArray1);

        _dataEDT_KSV_ORDER_MST1.ORDER_QTY = String(tMainTotal);
        _dataEDT_KSV_ORDER_MST1.ADD_QTY = String(tMainTotalAdd);
        _dataEDT_KSV_ORDER_MST1.ORDER_QTY_ONLY = String(
            tMainTotal - tMainTotalAdd,
        );
        setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
    };

    /* */
    const [disableVal, setDisableVal] = useState(false);
    const [disableValFob, setDisableValFob] = useState(false);
    const [disableValFactory, setDisableValFactory] = useState(false);

    const process_RESET_EDT = (argBuyerCd, argStyleCd) => {
        setDataUrlImage("");
        var tObj = { ...dataEDT_KSV_ORDER_MST };
        if (argStyleCd !== "") tObj.STYLE_CD = argStyleCd;
        else if (argBuyerCd !== "") {
            tObj.BUYER_CD = argStyleCd;
            var tArray = [];
            var tObj = {};
            tObj.STYLE_CD = "";
