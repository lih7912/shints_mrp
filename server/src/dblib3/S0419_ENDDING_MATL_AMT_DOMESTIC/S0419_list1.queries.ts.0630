                if (parseFloat(tObj.LC_QTY) > 0) {
                    tObj.DEPOSIT_AMT = String(tObj.LC_AMT);
                }

                tObj.IN_QTY = AFLib.numToFixed(parseFloat(tObj.IN_QTY), 2);
