                tSQLArray = [];

                var tInput1 = { ...tWorkArray[tIdx] };
                tInput1.STOCK_IDX = tInput1.stock_idx;

                if (!tInput1.CANCEL_REASON) tInput1.CANCEL_REASON = '';
                if (tInput1.CANCEL_REASON === 'N') tInput1.CANCEL_REASON = '';

                // StockMatlObj
                var tSQL0_1 = `
