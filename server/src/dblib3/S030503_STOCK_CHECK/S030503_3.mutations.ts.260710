                if (nRet0.length <= 0) {
                    tSQL0 = `
                        select
                            *
                        from
                            ksv_stock_use
                        where
                            stock_idx = '${tInput1.STOCK_IDX}'
                            and use_po_cd = '${tInput1.PO_CD}'
                            and use_po_seq = '${tInput1.PO_SEQ}'
