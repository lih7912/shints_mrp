                        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                        tSQLArray.push(tSQL99_1);
                    }

                    if (
                        tMstMain.SAMPLE_FLAG === '1' &&
                        tMstMain.FACTORY_CD === 'FC010' &&
                        tObj.TYPE === 'Main'
                    ) {
                        var strWorkType = '0';
                        var strPattCost = '0';
                        var strSewCost = '0';
                        var strWeldingCost = '0';
                        var strSampleStep = tOrderMst2.SAMPLE_STEP;
                        var strSampleRound = tOrderMst2.SAMPLE_ROUND;
                        var strSampleReason = tOrderMst2.SAMPLE_REASON;

                        var tBuyerCd = tWObj.ORDER_CD.substring(0, 2);
                        var tYY1 = tWObj.YY.toString().substring(2, 4);
                        var tSQL0 = `
                            select
                                max(seq) as t_seq
                            from
                                kzz_sample_cost
                            where
                                yy = '${tWObj.YY}'
                                and left(sample_cd, 2) = '${tBuyerCd}'
                        `;
                        var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL0));
                        var tSeq1 = 1;
                        if (nRet0.length > 0) tSeq1 = nRet0[0].t_seq + 1;

                        var tZero = '0000';
                        var tSeq1Str =
                            tZero.substring(0, 4 - String(tSeq1).length) +
                            String(tSeq1);

                        var strSampleCd = `${tBuyerCd}${tYY1}-A${tSeq1Str}`;
                        let tSQL99 = `
                            INSERT INTO
                                kzz_sample_cost (
                                    sample_cd,
                                    yy,
                                    seq,
                                    order_cd,
                                    order_qty,
                                    style_cd,
                                    work_type,
                                    sew_cost,
                                    patt_cost,
                                    welding_cost,
                                    buyer_cd,
                                    etc_amount,
                                    sample_end_flag,
                                    end_flag,
                                    sub_patt_cost,
                                    sub_sew_cost,
                                    sub_welding_cost,
                                    confirm_flag,
                                    patt_grade,
                                    sew_grade,
                                    repair_qty,
                                    sample_step,
                                    sample_round,
                                    sample_reason,
                                    reg_user,
                                    reg_datetime
                                )
                            values
                                (
                                    '${strSampleCd}',
                                    '${tWObj.YY}',
                                    '${tSeq1}',
                                    '${tWObj.ORDER_CD}',
                                    '${tWObj.TOT_CNT}',
                                    '${tWObj.STYLE_CD}',
                                    '${strWorkType}',
                                    '${strSewCost}',
                                    '${strPattCost}',
                                    '${strWeldingCost}',
                                    '${tBuyerCd}',
                                    '0',
                                    '0',
                                    '0',
                                    '0',
                                    '0',
                                    '0',
                                    'Y',
                                    '0',
                                    '0',
                                    '0',
                                    '${strSampleStep}',
                                    '${strSampleRound}',
                                    '${strSampleReason}',
                                    '${tWObj.REG_USER}',
                                    '${tWObj.REG_DATETIME}'
                                )
                        `;
                        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                        tSQLArray.push(tSQL99_1);
                    }
                } else if (tOpMode === '1' && tObj.TYPE.includes('Main')) {
                    var sqlPrice = '';
                    // if (tDbName.includes('test20')) {
                    if (1) {
                        if (tMstMain.CURR_CD === 'KRW') {
                            var tmpAvrPrice = parseFloat(
                                parseFloat(tWObj.AVR_PRICE).toFixed(0),
                            );
                            sqlPrice += `avr_price = '${tmpAvrPrice}',`;
                            sqlPrice += `usd_price = '${tWObj.USD_PRICE}',`;
                            sqlPrice += `curr_cd = '${tMstMain.CURR_CD}',`;

                            let tSQL99 = `
                                update ksv_order_mem
                                set
                                    price = '${tmpAvrPrice}'
                                where
                                    order_cd = '${tWObj.ORDER_CD}'
                            `;
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        } else {
                            sqlPrice += `avr_price = '${tWObj.AVR_PRICE}',`;
                            sqlPrice += `usd_price = '${tWObj.USD_PRICE}',`;
                            sqlPrice += `curr_cd = '${tMstMain.CURR_CD}',`;

                            let tSQL99 = `
                                update ksv_order_mem
                                set
                                    price = '${tWObj.AVR_PRICE}'
                                where
                                    order_cd = '${tWObj.ORDER_CD}'
                            `;
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        }

                        // ksv_order_fob 수정
                        var sqlInvoiceMem = `
                            select
                                A.*,
                                isnull(b.PAY_PRICE, '0') as PAY_PRICE,
                                isnull(b.PAY_QTY, '0') as PAY_QTY,
                                isnull(a0.DOCU_NO, '') as DOCU_NO,
                                isnull(c.DOCU_NO, '') as DOCU_NO2
                            from
                                ksv_invoice_mst a0,
                                ksv_invoice_mem a
                                left join ksv_tax_mem b on a.invoice_no = b.invoice_no
                                and a.order_cd = b.order_cd
                                left join ksv_tax_mst c on c.tax_cd = b.tax_cd
                            where
                                a.order_cd = '${tWObj.ORDER_CD}'
                                and a.invoice_no = a0.invoice_no
                                and (
                                    (
                                        isnull(c.DOCU_NO, '') = ''
                                        and a0.DOCU_NO is not null
                                        and a0.DOCU_NO <> ''
                                    )
                                    or isnull(c.DOCU_NO, '') <> ''
                                )
                        `;
                        var retInvoiceMem = await prisma.$queryRaw(
                            Prisma.raw(sqlInvoiceMem),
                        );
                        if (retInvoiceMem.length > 0) {
                            let tSQL99 = `
                                delete from ksv_order_fob
                                where
                                    order_cd = '${tWObj.ORDER_CD}'
                            `;
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        }

                        var tIdx7 = 0;
                        for (tIdx7 = 0; tIdx7 < retInvoiceMem.length; tIdx7++) {
                            var tmpObj = { ...retInvoiceMem[tIdx7] };
                            var sqlCurrency = `
                                select
