                        and matl_cd = '${tInput1.MATL_CD}'
                        and mrp_seq = '${tInput1.MRP_SEQ}'
                `;
                var ret999 = await prisma.$queryRaw(Prisma.raw(sql999));
                if (ret999.length > 0) {
                    if (
                        parseFloat(ret999[0].PO_QTY) === parseFloat(upCancelQty)
                    ) {
                        tSQL3 = `
                            delete from ksv_po_mrp
                            where
                                po_cd = '${tInput1.PO_CD}'
