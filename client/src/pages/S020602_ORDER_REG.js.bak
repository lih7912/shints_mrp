                        _dataEDT_KSV_ORDER_MST.XX_ORDER_CD =
                            argData.XX_ORDER_CD;
                        _dataEDT_KSV_ORDER_MST.XX_ORDER_QTY =
                            argData.XX_ORDER_QTY;
                    } else {
                        _dataEDT_KSV_ORDER_MST.XX_ORDER_CD = "";
                        _dataEDT_KSV_ORDER_MST.XX_ORDER_QTY = "0";
                    }

                    if (tStyleCd.DL === "" || tStyleCd.DL === " ")
                        tStyleCd.DL = "X";

                    if (tStyleCd.DL === "X") {
                        _dataEDT_KSV_ORDER_MST.IS_COMBINED = "0";
                        set_styleVal_combine_N();
                    } else {
                        _dataEDT_KSV_ORDER_MST.IS_COMBINED = "1";
                        set_styleVal_combine_Y();
                    }
                    setDataEDT_KSV_ORDER_MST(_dataEDT_KSV_ORDER_MST);

                    let _dataEDT_KSV_ORDER_MST4 = { ...dataEDT_KSV_ORDER_MST4 };
                    _dataEDT_KSV_ORDER_MST4.IS_DL = tStyleCd.DL;
                    setDataEDT_KSV_ORDER_MST4(_dataEDT_KSV_ORDER_MST4);

                    var tArray = [];
                    data.PROD_MST.forEach((col, i) => {
                        var tObj = { ...col };
                        if (col.ADD_FLAG === "0") tObj.ADD_FLAG_NAME = "";
                        else tObj.ADD_FLAG_NAME = "ADD";
                        tArray.push(tObj);
                    });
                    setDatasTBL_KSV_PROD_MEM(tArray);

                    if (workMode === "reg") {
                        editEDT_KSV_ORDER_MST4_IS_DL(tStyleCd.DL);
                    }

                    setDatasEDT_KSV_ORDER_MST1_SIZE_GROUP(data.SIZE_MST);
                    setDataEDT_KSV_ORDER_MST1_SIZE_GROUP(data.SIZE_MST[0]);

                    // File
                    if (data.FILE_INFO.length > 0) {
                        if (data.FILE_INFO[0].URL !== "")
                            setDataUrlImage(data.FILE_INFO[0].URL);
                    }
                } else {
                    console.log(
                        "serviceS020602_ORDER_REG.mgrQueryORDER_REG_QRY_STYLE_INFO error => " +
                            JSON.stringify(data.graphQLErrors),
                    );
                }
            });
    };

