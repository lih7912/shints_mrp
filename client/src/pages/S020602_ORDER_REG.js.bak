    const makeKey = (r) =>
        r?.id ?? `${r?.PROD_CD ?? ""}__${r?.COLOR ?? ""}__${r?.ADD_FLAG ?? ""}`;

    const norm = (v) => {
        if (v === null || v === undefined) return "";
        if (typeof v === "number") return Number.isNaN(v) ? "" : String(v);
        if (typeof v === "boolean") return v ? "1" : "0";
        return String(v).trim();
    };

    // DATAGRID CODE : TBL_KSV_ORDER_MEM10
    const dynamicColumnsTBL_KSV_ORDER_MEM10 = datasTBL_KSV_ORDER_MEM10_COL.map(
        (col, i) => {
            const tHeader = `id_msg_${col.field_name}_KSV_ORDER_MST_dt`;
            const tHeaderStr = serviceLib.getLocaleMessage(tHeader);

            const bodyWithDiff = (rowData) => {
                const key = makeKey(rowData);
                const isDiff = diffMap?.[key]?.[col.field];
                const className = isDiff ? "diff-td" : "";
                return (
                    <span className={className}>{rowData?.[col.field]}</span>
                );
            };

            return (
                <AFColumn
                    key={col.field}
                    field={col.field}
                    headerClassName="t-header"
                    header={tHeaderStr}
                    style={{ width: "2rem", flexBasis: "auto" }}
                    body={bodyWithDiff}
                />
            );
        },
    );

    const dynamicFields = React.useMemo(() => {
        return React.Children.toArray(dynamicColumnsTBL_KSV_ORDER_MEM10)
            .map((el) => el?.props?.field)
            .filter(Boolean);
    }, [dynamicColumnsTBL_KSV_ORDER_MEM10]);

    const compareFields = React.useMemo(
        () => [
            "PROD_CD",
            "COLOR",
            "ADD_FLAG",
            "TOT_CNT",
            "PRICE",
            ...dynamicFields,
        ],
        [dynamicFields],
    );

    const diffMap = React.useMemo(() => {
        const map11 = new Map(
            (datasTBL_KSV_ORDER_MEM11 ?? []).map((r) => [makeKey(r), r]),
        );

        const result = {};

        for (const r10 of datasTBL_KSV_ORDER_MEM10 ?? []) {
            const k = makeKey(r10);
            const r11 = map11.get(k);
            if (!r11) continue;

            result[k] = {};
            for (const f of compareFields) {
                result[k][f] = norm(r10?.[f]) !== norm(r11?.[f]);
            }
        }
        return result;
    }, [datasTBL_KSV_ORDER_MEM10, datasTBL_KSV_ORDER_MEM11, compareFields]);

