                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL3));
                    tSQLArray.push(tSQL99_1);
                } else if (
                    parseFloat(stockUseObj.USE_QTY) > parseFloat(upCancelQty)
                ) {
