    };

    const insertORDER_MEM_ADD = () => {
        console.log("Order Mem Insert:" + selectedTBL_KSV_PROD_MEM.length);

        if (dataEDT_KSV_ORDER_MST3.RATE === "") return;

        var tObjArray = [...datasTBL_KSV_ORDER_MEM];
        var tFlag = 0;
        var tIdx = 0;

        var tNormalArray = [];
        var tAddArray = [];

        tObjArray.forEach((col, i) => {
            var tObj = { ...col };
            if (col.ADD_FLAG === "1") tAddArray.push(tObj);
            else tNormalArray.push(tObj);
        });

        var tResultArray = [];
        var tSeq = 1;

        var tSumTotCnt = 0;
        var tSumAddCnt = 0;

        for (tIdx = 0; tIdx < tNormalArray.length; tIdx++) {
            var tObjOne = { ...tNormalArray[tIdx] };

            tFlag = 0;
            var tAddObj = {};
            tAddArray.forEach((col, i) => {
                if (col.PROD_CD === tObjOne.PROD_CD) {
                    tAddObj = { ...col };
                    tAddObj.ADD_FLAG = "1";

                    var tKeys = Object.keys(tAddObj);
                    var tIdx1 = 0;
                    var tTot = 0;
                    for (tIdx1 = 0; tIdx1 < tKeys.length; tIdx1++) {
                        var tKey = tKeys[tIdx1];
                        if (tKeys[tIdx1].includes("SIZE_COL_")) {
                            var tValue = parseInt(tObjOne[`${tKey}`]);
                            tAddObj[`${tKey}`] = Math.round(
                                tValue *
                                    (parseInt(dataEDT_KSV_ORDER_MST3.RATE) /
                                        100.0),
                            );
                            tTot += tAddObj[`${tKey}`];
                        }
                    }
                    tAddObj.TOT_CNT = tTot;

                    tFlag = 1;
                }
            });

            if (tFlag !== 0) {
                tObjOne.id = tSeq;
                tSeq += 1;
                tSumTotCnt += parseInt(tObjOne.TOT_CNT);
                tResultArray.push(tObjOne);
                tAddObj.id = tSeq;
                tSeq += 1;
                tSumAddCnt += parseInt(tAddObj.TOT_CNT);
                tResultArray.push(tAddObj);
                continue;
            } else {
                tObjOne.id = tSeq;
                tSeq += 1;
                tSumTotCnt += parseInt(tObjOne.TOT_CNT);
                tResultArray.push(tObjOne);

                var tCheck2 = 0;
                selectedTBL_KSV_PROD_MEM.forEach((col9, i9) => {
                    if (tObjOne.COLOR === col9.COLOR) tCheck2 = 1;
                });
                if (tCheck2 === 0) continue;
            }

            tAddObj = { ...tObjOne };

            var tKeys = Object.keys(tAddObj);
            var tIdx1 = 0;
            var tTot = 0;
            for (tIdx1 = 0; tIdx1 < tKeys.length; tIdx1++) {
                var tKey = tKeys[tIdx1];
                if (tKeys[tIdx1].includes("SIZE_COL_")) {
                    var tValue = parseInt(tAddObj[`${tKey}`]);
                    tAddObj[`${tKey}`] = Math.round(
                        tValue *
                            (parseInt(dataEDT_KSV_ORDER_MST3.RATE) / 100.0),
                    );
                    tTot += tAddObj[`${tKey}`];
                }
            }

            tAddObj.TOT_CNT = tTot;
            tAddObj.PRICE = tObjOne.PRICE;
            tAddObj.ADD_FLAG = "1";
            tAddObj.id = tSeq;
            tSeq += 1;
            tSumAddCnt += parseInt(tAddObj.TOT_CNT);
            tResultArray.push(tAddObj);
        }

        var tOrderMst = { ...dataTBL_KSV_ORDER_MST };
        tOrderMst.ORDER_QTY = String(tSumTotCnt);
        tOrderMst.ADD_QTY = String(tSumAddCnt);
        tOrderMst.ORDER_MEM = [...tResultArray];
        setDatasTBL_KSV_ORDER_MEM(tResultArray);

        recompute_ORDER_QTY(tOrderMst);
    };

    const onCellEditCompleteKSV_ORDER_MEM = (e) => {
        let { rowData, newValue, field, originalEvent: event } = e;

        console.log("onCellEditComplete;", newValue, e);

        rowData[field] = newValue;
        var tRowData = { ...rowData };

        if (field !== "PRICE") {
            var tKeys = Object.keys(rowData);
            var tNewTot0 = 0;
            tKeys.forEach((col, i) => {
                if (col.includes("SIZE_COL_")) {
                    tNewTot0 += parseInt(rowData[`${col}`]);
                }
            });
            tRowData.TOT_CNT = String(tNewTot0);
        }

        var tSumTotCnt = 0;
        var tSumAddCnt = 0;
        var tOrderMems = [];
        datasTBL_KSV_ORDER_MEM.forEach((col, i) => {
            var tObj = { ...col };
            if (tObj.id === tRowData.id) {
                tOrderMems.push(tRowData);
                if (tObj.ADD_FLAG === "1")
                    tSumAddCnt += parseInt(tRowData.TOT_CNT);
                else tSumTotCnt += parseInt(tRowData.TOT_CNT);
            } else {
                tOrderMems.push(tObj);
                if (tObj.ADD_FLAG === "1") tSumAddCnt += parseInt(tObj.TOT_CNT);
                else tSumTotCnt += parseInt(tObj.TOT_CNT);
            }
        });
        setDatasTBL_KSV_ORDER_MEM(tOrderMems);

        var tOrderMst = { ...dataTBL_KSV_ORDER_MST };
        tOrderMst.ORDER_QTY = String(tSumTotCnt);
        tOrderMst.ADD_QTY = String(tSumAddCnt);
        tOrderMst.ORDER_MEM = [...tOrderMems];

        recompute_ORDER_QTY(tOrderMst);
    };

