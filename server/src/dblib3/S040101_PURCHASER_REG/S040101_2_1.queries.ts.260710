                tVendorSql += ` and  left(f2.vendor_name, 6) <> 'IMPORT' `;
            } else if (objUser.PART === 'VPUR') {
                tVendorSql = ` and  (f2.vendor_type in ('3', '7', '4') `;
                tVendorSql += ` or  (f2.vendor_type = '1' and left(f2.vendor_name, 6) = 'IMPORT'))  `;
            } else if (objUser.PART === 'VFP') {
