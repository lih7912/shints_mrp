    const onDropdownChangeEDT_KSV_ORDER_MST_STYLE_CD_SUB = (argData) => {
        editEDT_KSV_ORDER_MST_STYLE_CD(argData.STYLE_CD);

        var tQryObj = {};
        tQryObj.STYLE_CD = argData.STYLE_CD;

        var tEdtObj = { ...dataEDT_KSV_ORDER_MST };
        process_RESET_EDT(tEdtObj.BUYER_CD, argData.STYLE_CD);

        resetEDT_KSV_ORDER_MST();
        resetEDT_KSV_ORDER_MST1();
        resetEDT_KSV_ORDER_MST2();
        setDatasTBL_KSV_PROD_MEM([]);
        setDatasTBL_KSV_ORDER_MST([]);
        setDatasTBL_KSV_ORDER_MEM([]);

        serviceS020602_ORDER_REG
            .mgrQueryORDER_REG_QRY_STYLE_INFO(tQryObj)
            .then((data) => {
                console.log(data);
                if (typeof data.graphQLErrors === "undefined") {
                    var tStyleCd = { ...data.STYLE_CD[0] };
                    var tBuyerCd = { ...data.BUYER_CD[0] };

                    setSaveStyleInfo(tStyleCd);

                    // setDatasEDT_KSV_ORDER_MST_STYLE_CD(data.STYLE_CD);
                    // setDataEDT_KSV_ORDER_MST_STYLE_CD(data.STYLE_CD[0]);

                    // setDatasEDT_KSV_ORDER_MST_BUYER_CD(data.BUYER_CD);
                    // setDataEDT_KSV_ORDER_MST_BUYER_CD(data.BUYER_CD[0]);

                    var tUserInfo = serviceLib.getUserInfo();

                    let _dataEDT_KSV_ORDER_MST = { ...dataEDT_KSV_ORDER_MST };
                    _dataEDT_KSV_ORDER_MST.STYLE_NAME = tStyleCd.STYLE_NAME;
                    _dataEDT_KSV_ORDER_MST.STYLE_CD = tStyleCd.STYLE_CD;
                    _dataEDT_KSV_ORDER_MST.BUYER_NAME = tBuyerCd.BUYER_NAME;
                    _dataEDT_KSV_ORDER_MST.BUYER_CD = tBuyerCd.BUYER_CD;
                    _dataEDT_KSV_ORDER_MST.USER_ID = tUserInfo.USER_ID;
                    _dataEDT_KSV_ORDER_MST.APPROVAL_USER = "";
