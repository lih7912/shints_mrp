                    else tObj1.CANCEL_QTY = tObj.CANCEL_QTY;
                    tObj1.NEW_FACTORY_CD = tObj.NEW_FACTORY_CD;
                    if (!tObj.CANCEL_REASON) tObj1.CANCEL_REASON = '';
                    else tObj1.CANCEL_REASON = tObj.CANCEL_REASON;
                    tWorkArray.push(tObj1);
                }
            }

            if (tChk > 1) {
                var tRetArray = [];
                var tObj = {};
