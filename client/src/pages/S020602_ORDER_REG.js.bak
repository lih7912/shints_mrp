                                if (tObjORDER_MST.ORDER_CD.includes("-DL"))
                                    tObjORDER_MST.TYPE = "Main-D";
                                else if (tObjORDER_MST.ORDER_CD.includes("-ZL"))
                                    tObjORDER_MST.TYPE = "Main-Z";
                                else {
                                    if (tObjORDER_MST.ORDER_CD.includes("-D"))
                                        tObjORDER_MST.TYPE = "Combined-D";
                                    else if (
                                        tObjORDER_MST.ORDER_CD.includes("-Z")
                                    )
                                        tObjORDER_MST.TYPE = "Combined-Z";
                                    else tObjORDER_MST.TYPE = "Combined";
                                }
                            } else if (tObjORDER_MST.ORDER_CD.length === 16) {
                                if (tObjORDER_MST.ORDER_CD.includes("-DL"))
                                    tObjORDER_MST.TYPE = "Combined-D";
                                else if (tObjORDER_MST.ORDER_CD.includes("-ZL"))
                                    tObjORDER_MST.TYPE = "Combined-Z";
                            }

                            tObjORDER_MST.CURR_CD = tData0.CURR_CD;
                            tObjORDER_MST.NAT_CD = tData0.NAT_CD;
                            tObjORDER_MST.BUYER_PO = tData0.BUYER_PO;
                            tObjORDER_MST.EXF_DATE = tData0.EXF_DATE;
                            tObjORDER_MST.ETD_DATE = tData0.ETD_DATE;
                            tObjORDER_MST.IS_DL = tData0.IS_DL;
                            tObjORDER_MST.REMARK1 = tData0.REMARK1;
                            tObjORDER_MST.REMARK2 = tData0.REMARK2;
                            tObjORDER_MST.NOTE = tData0.NOTE;
                            tObjORDER_MST.ORDER_QTY = parseInt(
                                tData0.ORDER_QTY,
                            );
                            tObjORDER_MST.ADD_QTY = parseInt(tData0.ADD_QTY);
                            tObjORDER_MST.ORDER_MEM = [];
                            // console.log(tData0.ORDER_MEM);
                            tData0.ORDER_MEM.forEach((data, i) => {
                                var tObjOne = { ...data };
                                var tIdx = 0;
                                for (tIdx = 0; tIdx < tObjCols.length; tIdx++) {
                                    var tCol = tObjCols[tIdx];
                                    tObjOne[`${tCol.field}`] = parseInt(
                                        tObjOne.SIZE_CNT.substring(
                                            tIdx * 6,
                                            tIdx * 6 + 6,
                                        ),
                                    );
                                }
                                tObjOne.TOT_CNT = parseInt(tObjOne.TOT_CNT);
                                tObjOne.PRICE = parseFloat(tObjOne.PRICE);
                                tObjORDER_MST.ORDER_MEM.push(tObjOne);
                            });
                            // tObjORDER_MST.ORDER_MEM = tOrderMemArray;
                            // console.log(tObjORDER_MST.ORDER_MEM);
                            if (
                                tObjORDER_MST.TYPE === "Main" ||
                                tObjORDER_MST.TYPE === "Combined"
                            )
                                tOrderMsts_Old.push(tObjORDER_MST);
                        });
                        setSaveOrderMstOld(tOrderMsts_Old);

                        ///
                        setCreateDialog(true);
                    }
                } else {
                    console.log(
