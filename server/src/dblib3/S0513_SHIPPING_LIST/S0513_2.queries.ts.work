                        from
                            (
                                select
                                    F1.INVOICE_NO,
                                    A.ORDER_CD,
                                    A.PROD_CD,
                                    isnull(sum(D.AVR_PRICE * A.SHIP_CNT), 0) as SHIP_AMOUNT2,
                                    isnull(sum(A.SHIP_CNT), 0) AS SHIP_QTY,
                                    isnull(sum(A.SHIP_PRICE * A.SHIP_CNT), 0) as SHIP_AMOUNT
                                FROM
                                    KSV_ORDER_MST D,
                                    KSV_INVOICE_MST F1,
                                    KCD_STYLE D1,
                                    KSV_ORDER_SHIP A
                                where
                                    F1.INVOICE_NO = A.INVOICE_NO
                                    and A.ORDER_CD = D.ORDER_CD
