    // END Edit
    const search_MODIFY_INFO = (argOrder, argCPOrder) => {
        var tIn = {};
        tIn.ORDER_CD = argOrder;
        serviceS020602_ORDER_REG.mgrQueryORDER_MODIFY_QRY(tIn).then((data) => {
            if (typeof data.graphQLErrors === "undefined") {
                console.log(data);
                setSaveOrderMst(data.ORDER_MST[0]);
                var tOrderMst = { ...data.ORDER_MST[0] };

                // Style Image File
                if (data.FILE_INFO.length > 0) {
                    if (data.FILE_INFO[0].URL !== "")
                        setDataUrlImage(data.FILE_INFO[0].URL);
                }

                if (data.CAPA_MEM.length > 0) {
                    setStyleVal_capa1(true);
                    setSaveJOB_CD(data.CAPA_MEM[0].JOB_CD);
                } else setStyleVal_capa1(false);

                if (data.IS_CHANGE.length > 1) set_styleVal_change_Y();
                else set_styleVal_change_N();

                setSaveCurrency(data.CODE_CURRENCY);

                setDatasEDT_KSV_ORDER_MST_STYLE_CD(data.STYLE);
                let tFilterData = data.STYLE.filter((col, i) => {
                    if (col.STYLE_CD === data.ORDER_MST[0].STYLE_CD) return col;
                });
                setDataEDT_KSV_ORDER_MST_STYLE_CD(tFilterData[0]);

                setDatasEDT_KSV_ORDER_MST_BUYER_CD(data.BUYER);
                tFilterData = data.BUYER.filter((col, i) => {
                    if (
                        col.BUYER_CD ===
                        data.ORDER_MST[0].ORDER_CD.substring(0, 2)
                    )
