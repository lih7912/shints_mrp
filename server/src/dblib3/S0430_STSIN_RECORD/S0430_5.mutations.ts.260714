                    var tAUTHORITY = 'PIC';

                    var tREASON_MAKE = '';
                    var tREASON_MAKE2 = '';
                    var tREASON_MAKE3 = '';
                    var tSTOCK_STATUS = '';
                    if (parseFloat(obj1.PO_SEQ) === 99) {
                        tREASON_MAKE = 'MOQ';
                        tREASON_MAKE2 = '03.MOQ';
                        tREASON_MAKE3 = '03';
                        tSTOCK_STATUS = 'M';
                    } else if (parseFloat(obj1.PO_SEQ) === 98) {
                        tREASON_MAKE = 'OVER';
                        tREASON_MAKE2 =
                            '02.Overship in tolerance3%(include payment)  5-05';
                        tREASON_MAKE3 = '05';
                        tSTOCK_STATUS = 'W';
                    } else if (parseFloat(obj1.PO_SEQ) === 97) {
