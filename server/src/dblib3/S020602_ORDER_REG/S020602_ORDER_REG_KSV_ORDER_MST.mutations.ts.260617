            tMstMain.TOT_CNT = parseInt(tOrderMst1.ORDER_QTY);
            tMstMain.ADD_CNT = tTotAddQty;
            tMstMain.CURR_CD = tOrderMst1.CURR_CD;
            tMstMain.ORDER_DATE = tOrderMst1.ORDER_DATE;
            tMstMain.DUE_DATE = tOrderMst1.DUE_DATE;
            tMstMain.ETD = tOrderMst1.ETD_DATE;
            // tMstMain.MATL_DUE_DATE = tOrderMst1.MATL_DUE_DATE;
            tMstMain.NAT_CD = tOrderMst1.NAT_CD;
            tMstMain.FACTORY_CD = tOrderMst1.FACTORY_CD;
            tMstMain.SIZE_GROUP = tOrderMst1.SIZE_GROUP;
            // tMstMain.ORDER_STATUS = '*';

            if (tOrderMst.IS_SAMPLE === '1') tMstMain.ORDER_STATUS = '0';
            else tMstMain.ORDER_STATUS = '*';
            tMstMain.STATUS_CD = '0';
            /*
*                    Waiting                                                                                             
0                    Order Reg.                                                                                          
1                    PO Reg.                                                                                             
2                    MRP                                                                                                 
3                    PO                                                                                                  
4                    Cancel                                                                                              
5                    Partial Ship                                                                                        
6                    Stock Checking                                                                                      
7                    Ship End                                                                                            
8                    End Report                                                                                          
9                    End                                      
      */
            tMstMain.ORDER_FLAG = '0';
            tMstMain.SAMPLE_FLAG = tSampleFlag;
            tMstMain.MATL_SALE_FLAG = '0';
            tMstMain.FAC_LC_FLAG = tFacLcFlag;
            tMstMain.FAC_TT_FLAG = '0';

            tMstMain.REMARK = tOrderMst2.REMARK;
            tMstMain.REG_USER = tUserInfo.USER_ID;
            tMstMain.REG_DATETIME = tRetDate;
            tMstMain.UPD_USER = tUserInfo.USER_ID;
            tMstMain.UPD_DATETIME = tRetDate;

            // Capabooking Delete
            var tTabName = '';
            var tTabName1 = '';
            if (tMstMain.FACTORY_CD === 'FC044') {
                if (tMstMain.SAMPLE_FLAG === '1') {
                    tTabName = 'ksv_capasample_mst_ethiopia';
                    tTabName1 = 'ksv_capasample_mem_ethiopia';
                } else {
                    tTabName = 'ksv_capabook_mst_ethiopia';
                    tTabName1 = 'ksv_capabook_mem_ethiopia';
                }
            }
            if (tMstMain.FACTORY_CD === 'FC034') {
                if (tMstMain.SAMPLE_FLAG === '1') {
                    tTabName = 'ksv_capasample_mst';
                    tTabName1 = 'ksv_capasample_mem';
                } else {
                    tTabName = 'ksv_capabook_mst';
                    tTabName1 = 'ksv_capabook_mem';
                }
            }

            if (nStyleObj.DL === 'X') tMstMain.DL_FLAG = '0';
            if (nStyleObj.DL === 'D') tMstMain.DL_FLAG = '1';
            if (nStyleObj.DL === 'Z') tMstMain.DL_FLAG = '2';
            if (nStyleObj.DL === 'D/Z') tMstMain.DL_FLAG = '3';

            tSaveCombineIdx = 1;
            tCombineIdx = 1;
            tIdx = 0;
            var tMsts = [];
            // for (tIdx = 0; tIdx < tOrderMstArray.length; tIdx++) {
            for (tIdx = 0; tIdx < tSaveOrderMstArray.length; tIdx++) {
                var tORDER_CD_0;
                var tORDER_TYPE;
                var tObj = { ...tSaveOrderMstArray[tIdx] };

                if (tObj.TYPE === 'Main') {
                    tORDER_CD_0 = tORDER_CD;
                    tSubIdx = 0;
                    if (tOrderType.substring(0, 1) === 'C') {
                        tORDER_TYPE = '1';
                        tObj.NAT_CD = '';
                    } else {
                        tORDER_TYPE = '0';
                    }
                } else if (tObj.TYPE === 'Combined') {
                    var tCombineStr = '';
                    if (tCombineIdx < 10) tCombineStr = '0' + tCombineIdx;
                    else tCombineStr = tCombineIdx;
                    tORDER_CD_0 = tORDER_CD + '-' + tCombineStr;
                    tSaveCombineIdx = tCombineIdx;
                    tCombineIdx++;
                    tSubIdx = 0;
                    tORDER_TYPE = '2';
                } else if (tObj.TYPE === 'Main-D') {
                    tORDER_CD_0 = tORDER_CD + '-DL';
                    tORDER_TYPE = '2';
                } else if (tObj.TYPE === 'Combined-D') {
                    var tCombineStr = '';
                    if (tCombineIdx < 10) tCombineStr = '0' + tSaveCombineIdx;
                    else tCombineStr = tCombineIdx;
                    tORDER_CD_0 = tORDER_CD + '-' + tCombineStr + '-DL';
                    tORDER_TYPE = '2';
                    if (tObj.IS_OLD_COMBINED === '1')
                        tORDER_CD_0 = tObj.ORDER_CD;
                } else if (tObj.TYPE === 'Main-Z') {
                    tORDER_CD_0 = tORDER_CD + '-ZL';
                    tORDER_TYPE = '2';
                } else if (tObj.TYPE === 'Combined-Z') {
                    var tCombineStr = '';
                    if (tCombineIdx < 10) tCombineStr = '0' + tSaveCombineIdx;
                    else tCombineStr = tCombineIdx;
                    tORDER_CD_0 = tORDER_CD + '-' + tCombineStr + '-ZL';
                    tORDER_TYPE = '2';
                    if (tObj.IS_OLD_COMBINED === '1')
                        tORDER_CD_0 = tObj.ORDER_CD;
                } else {
                    var retArray = [];
                    var tObj = {};
                    tObj.CODE = `ERROR:Type Error(2):${tObj.TYPE}`;
                    tObj.id = 0;
                    retArray.push(tObj);
                    return retArray;
                }

                var tWObj = { ...tMstMain };
                tWObj.ORDER_CD = tORDER_CD_0;
                tWObj.ORDER_TYPE = tORDER_TYPE;
                tWObj.NAT_CD = tObj.NAT_CD;
                tWObj.REF_ORDER_NO = tObj.BUYER_PO;
                tWObj.REMARK = tObj.REMARK1.replace(/'/gi, "''");
                tWObj.COLLECTION = tObj.COLLECTION;
                tWObj.REF_Q_LINER = tObj.REMARK2.replace(/'/gi, "''");
                tWObj.REF_ORDER_REQ = tObj.NOTE.replace(/'/gi, "''");
                // tWObj.DUE_DATE = tObj.ETD_DATE;
                // tWObj.MATL_DUE_DATE = tObj.EXF_DATE;
                // tWObj.MATL_DUE_DATE = tObj.EXF_DATE;
                tWObj.DUE_DATE = tObj.EXF_DATE;
                tWObj.ETD = tObj.ETD_DATE;
                tWObj.TOT_CNT = parseInt(tObj.ORDER_QTY);
                tWObj.ADD_CNT = parseInt(tObj.ADD_QTY);
                tWObj.ORDER_OP_TYPE = tObj.TYPE;
                tWObj.MID_SIZE1 = tObj.MID_SIZE;

                if (args.datas.ORDER_MST.XX_ORDER_CD !== '')
                    tWObj.XX_ORDER_CD = args.datas.ORDER_MST.XX_ORDER_CD;
                else tWObj.XX_ORDER_CD = '';
                // tMsts.push(tWObj);

                if (tOpMode === '0' || tObj.TYPE.includes('Combined')) {
                    tWObj.org_due_date = tWObj.DUE_DATE;
                    let tSQL99 = AFLib.createTableSql('KSV_ORDER_MST', tWObj);
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    if (tObj.TYPE === 'Main') {
                        var tFobObj = {};
                        tFobObj.ORDER_CD = tORDER_CD;
                        tFobObj.FOB_SEQ = '1';
                        tFobObj.SHIP_QTY = '1';
                        tFobObj.FOB = tMstMain.AVR_PRICE;
                        // tFobObj.FOB = tMstMain.USD_PRICE;
