            } else {
                tSQL1 = `    AND   F1.SHIP_DATE between '${sDate}' and '${eDate}'`;
            }

            let sqlStr = `
                SELECT
                    isnull(F.INVOICE_NO, '') as INVOICE_NO,
                    isnull(F.BL_NO, '') as BL_NO,
                    isnull(F.ATD, '') as ATD,
                    isnull(F.DUE_DATE, '') as ETD,
                    F.BUYER_CD,
