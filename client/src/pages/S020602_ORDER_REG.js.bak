                var tIdx = 0;
                var tArrayInvoice = [];
                var tShipQty = 0;

                console.log(data.INFO_INVOICE_MEM);

                var sumSellQty = 0;
                var sumFocQty = 0;

                // Invoice가 있을때 가격수정 disable
                if (data.INFO_INVOICE_MEM.length > 0 && !argCPOrder)
                    setDisableValFob(true);

                for (tIdx = 0; tIdx < data.INFO_INVOICE_MEM.length; tIdx++) {
                    var tObj1 = data.INFO_INVOICE_MEM[tIdx];
                    var tObj0 = {};
                    tObj0.id = tIdx + 1;
                    tObj0.SALES_DATE = tObj1.SALES_DATE;
                    tObj0.SHIP_DATE1 = tObj1.SHIP_DATE1;
                    tObj0.DOCU_NO = tObj1.DOCU_NO;
                    tObj0.CURR_CD = tObj1.CURR_CD;
                    tObj0.USD_RATE = tObj1.USD_RATE;
                    tObj0.INVOICE_DATE = tObj1.SHIP_DATE;
                    tObj0.SHIP_PROD_TYPE = tObj1.SHIP_TYPE_NAME;
                    tObj0.SHIP_QTY = tObj1.SHIP_QTY;
                    tObj0.SHIP_PRICE = tObj1.SHIP_PRICE;
                    tObj0.SALES_PRICE = tObj1.SALES_PRICE;
                    tObj0.INVOICE_NO = tObj1.INVOICE_NO;
                    tObj0.DELIVERY_TYPE_NAME = tObj1.DELIVERY_TYPE_NAME;
                    tObj0.COUNTRY = tObj1.COUNTRY;
                    tShipQty += parseFloat(tObj1.SHIP_QTY);
                    if (parseFloat(tObj0.SALES_PRICE) > 0)
                        sumSellQty += parseFloat(tObj1.SHIP_QTY);
                    else sumFocQty += parseFloat(tObj1.SHIP_QTY);
                    tArrayInvoice.push(tObj0);
                }
                setDatasTBL_KSV_ORDER_MEM3(tArrayInvoice);
                _dataEDT_KSV_ORDER_MST5.SHIP_QTY = String(tShipQty);
                _dataEDT_KSV_ORDER_MST5.SELL_QTY = String(sumSellQty);
                _dataEDT_KSV_ORDER_MST5.FOC_QTY = String(sumFocQty);
                var saveShipQty = tShipQty;

                tIdx = 0;
                tArrayInvoice = [];
                tShipQty = 0;
                sumSellQty = 0;
                sumFocQty = 0;
                for (tIdx = 0; tIdx < data.INFO_INVOICE_DOCU.length; tIdx++) {
                    var tObj1 = data.INFO_INVOICE_DOCU[tIdx];
                    var tObj0 = {};
                    tObj0.id = tIdx + 1;
                    tObj0.SALES_DATE = tObj1.SALES_DATE;
                    tObj0.SHIP_DATE1 = tObj1.SHIP_DATE1;
                    tObj0.DOCU_NO = tObj1.DOCU_NO;
