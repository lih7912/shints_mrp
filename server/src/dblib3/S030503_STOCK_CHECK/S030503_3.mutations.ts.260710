            var tSrcIdx = 0;

            var tSrcObj = {};
            var tDestObj = {};

            tSrcObj = { ...args.datas.SRC_DATA[tSrcIdx] };
            tDestObj = { ...tWorkArray[tDestIdx] };

            var saveSrcObj = {};
