                      kk.ERR_QTY,
                      kk.LOCATION,
                      kk.DELIVERY,
                      kk.WEIGHT,
                      kk.CBM,
                      kk.CT_NO,
                      kk.MC_ID,
                      kk.PU_CD,
                      kk.STATUS_CD,
                      kk.STATUS_CD_N,
                      kk.FACTORY_CD,
                      kk.FACTORY_CD_N,
                      kk.SHIPMENT_CD,
