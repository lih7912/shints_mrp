// export default로 Query 내용 내보내기
function setBodyFont(sheet, rowIdx, fromCol, toCol) {
    for (let c = fromCol; c <= toCol; c++) {
        const cell = sheet.getCell(rowIdx, c);
        cell.font = {
            name: '돋움',
            size: 10,
            bold: false
        };
    }
};

function applyBorder(sheet, startRow, endRow, thinOrThick) {
    const LAST_COL = 10;   // J 컬럼

    for (let r = startRow; r <= endRow; r++) {
        for (let c = 1; c <= LAST_COL; c++) {
            const cell = sheet.getCell(r, c);
            cell.border = {
                top:    { style: thinOrThick },
                left:   { style: thinOrThick },
                bottom: { style: thinOrThick },
                right:  { style: thinOrThick }
            };
        }
    }
}

function safeMerge(sheet, range) {
    try { sheet.unMergeCells(range); } catch (e) {}
    sheet.mergeCells(range);
}

// 숫자 변환 유틸 (P탭 병합 판단용)
function toNumber(v) {
    if (v === null || v === undefined) return 0;
    if (typeof v === 'number') return v;
    const n = Number(String(v).replace(/,/g, '').trim());
    return isNaN(n) ? 0 : n;
}

