        setDatasTBL_KSV_PROD_MEM([]);
        setDatasTBL_KSV_ORDER_MST([]);
        setDatasTBL_KSV_ORDER_MEM([]);

        serviceS020602_ORDER_REG
            .mgrQueryORDER_REG_QRY_STYLE_INFO(tQryObj)
            .then((data) => {
                if (typeof data.graphQLErrors === "undefined") {
                    console.log(
                        "serviceS020602_ORDER_REG.mgrQueryORDER_REG_QRY_STYLE_INFO call(STYLE_CD) => " +
                            data.STYLE_CD.length,
                    );
                    console.log(
                        "serviceS020602_ORDER_REG.mgrQueryORDER_REG_QRY_STYLE_INFO call(BUYER_CD) => " +
                            data.BUYER_CD.length,
                    );
                    console.log(
                        "serviceS020602_ORDER_REG.mgrQueryORDER_REG_QRY_STYLE_INFO call(PROD_MST) => " +
                            data.PROD_MST.length,
                    );

                    var tStyleCd = { ...data.STYLE_CD[0] };
                    var tBuyerCd = { ...data.BUYER_CD[0] };

                    setSaveStyleInfo(tStyleCd);

                    var tUserInfo = serviceLib.getUserInfo();

                    var tArray = [];
                    data.PROD_MST.forEach((col, i) => {
                        var tObj = { ...col };
                        if (col.ADD_FLAG === "0") tObj.ADD_FLAG_NAME = "";
                        else tObj.ADD_FLAG_NAME = "ADD";
                        tArray.push(tObj);
                    });
                    setDatasTBL_KSV_PROD_MEM(tArray);

                    // File
                    if (data.FILE_INFO.length > 0) {
                        if (data.FILE_INFO[0].URL !== "")
                            setDataUrlImage(data.FILE_INFO[0].URL);
                    }
                } else {
                    console.log(
                        "serviceS020602_ORDER_REG.mgrQueryORDER_REG_QRY_STYLE_INFO error => " +
                            JSON.stringify(data.graphQLErrors),
                    );
                }
            });
