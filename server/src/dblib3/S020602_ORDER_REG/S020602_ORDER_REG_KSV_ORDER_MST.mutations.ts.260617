                                    qty = ${tWObj.TOT_CNT},
                                    sd = '${tWObj.DUE_DATE}'
                                where
                                    order_cd = '${tWObj.ORDER_CD}'
                                    and book_date = '${nRet2[0].book_date}'
                                    and user_id = '${nRet2[0].user_id}'
                            `;
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        } else {
                            /*
                    let tSQL99 = `
                        update ${tTabName1}
                        set
                            job_cd = '${tUpdateJobCd}',
                            send_flag = '0',
                            fob = ${tWObj.AVR_PRICE},
                            qty = ${tWObj.TOT_CNT},
                            sd = '${tWObj.DUE_DATE}'
                        where
                            order_cd = '${tWObj.ORDER_CD}'
                            and book_date = '${nRet2[0].book_date}'
                            and user_id = '${nRet2[0].user_id}'
                    `;
                    */
                            let tSQL99 = `
                                update ${tTabName1}
                                set
                                    job_cd = '${tUpdateJobCd}',
                                    send_flag = '0',
                                    fob = ${tWObj.USD_PRICE},
                                    qty = ${tWObj.TOT_CNT},
                                    sd = '${tWObj.DUE_DATE}'
                                where
                                    order_cd = '${tWObj.ORDER_CD}'
                                    and book_date = '${nRet2[0].book_date}'
                                    and user_id = '${nRet2[0].user_id}'
                            `;
                            const tSQL99_1 = prisma.$queryRaw(
                                Prisma.raw(tSQL99),
                            );
                            tSQLArray.push(tSQL99_1);
                        }
                    }
                }
            }

            if (tSaveOpMode === '1') {
                if (
                    parseInt(tOrderMst1.ORDER_QTY) !==
                        parseInt(tOrderMstObj.TOT_CNT) ||
                    tOrderMst1.SIZE_GROUP !== tOrderMstObj.SIZE_GROUP ||
                    tChangeSizeFlag === 1
                ) {
                    let sql100 = `
                        select
                            isnull(count(*), 0) as cnt
                        from
                            ksv_order_ship
                        where
                            order_cd = '${tOrderMst1.ORDER_CD}'
                    `;
                    var nRet100 = await prisma.$queryRaw(Prisma.raw(sql100));
                    if (nRet100.length > 0 && nRet100[0].cnt > 0) {
                        if (tOrderMst1.SIZE_GROUP !== tOrderMstObj.SIZE_GROUP) {
                            var tRetArray = [];
                            var tObj = {};
                            tObj.CODE =
                                'ERROR:Already input shipped. not change size';
                            tObj.id = 0;
                            tRetArray.push(tObj);
                            return tRetArray;
                        }
                    }

                    if (parseInt(tOrderMstObj.ORDER_STATUS) >= 8) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE =
                            'ERROR:End/End Report된 오더는 수량/사이즈가 변경이 안됨';
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                    let sql101 = `
                        select
                            isnull(count(*), 0) as cnt
                        from
                            ksv_stock_in
                        where
                            order_cd = '${tOrderMst1.ORDER_CD}'
                            -- and po_cd = ''
                    `;
                    var nRet101 = await prisma.$queryRaw(Prisma.raw(sql101));

                    var tFlag = 0;
                    // order 수량 및 사이즈 변경은 order_status 가 po이상일대 confirm필요
                    if (parseInt(tOrderMstObj.ORDER_STATUS) >= 3) {
                        // if (nRet101.length > 0 && nRet101[0].cnt > 0) {

                        console.log(`${__dirname}`);
                        var tPathArray = [];
                        var tPath0 = `${__dirname}`;
                        var tPath0_1 = '';
                        var tPathCols = tPath0.split(/\//);
                        var tFlag = 0;
                        tPathCols.forEach((col, i) => {
                            if (col === 'dblib3') {
                                tPathArray.forEach((col2, i2) => {
                                    if (col2 === 'src') {
                                    } else {
                                        tPath0_1 += `${col2}/`;
                                    }
                                });
                                tFlag = 1;
                            } else {
                                if (tFlag === 0) tPathArray.push(col);
                            }
                        });

