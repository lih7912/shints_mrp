            `;
            tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_PRICE_TERM = tRet;
            tWRet.CODE_PRICE_TERM.unshift(tCode);

            tSQL = '';
            let sqlStr = `
                SELECT
                    *
