// export default로 Mutation 내용 내보내기
const moduleMutation_S030503_3 = {
    Mutation: {
        mgrAutoUseStock_S030503_3: async (_, args, contextValue) => {
            var tRetDate = AFLib.getCurrTime();
            var tRetDate1 = tRetDate.substring(0, 8);
            var tUserInfo = AFLib.getUserInfo(contextValue);

            var tSQLArray = [];

            var tSQL0 = `
                select
                    isnull(max(mrp_seq), 0) + 1 as new_seq
                from
                    ksv_po_mrp
                where
                    po_cd = '${args.datas.PO_CD}'
            `;
            var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL0));
            var tNewMrpSeq = nRet0[0].new_seq;

            var m_PO_CD = args.datas.PO_CD;
            var m_PO_SEQ = args.datas.PO_SEQ;
            var m_USER_ID = tUserInfo.USER_ID;

            if (parseFloat(m_PO_SEQ) <= 0 || parseFloat(m_PO_SEQ) >= 97) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Po Seq는 0보다 크고 97보다 작아야 합니다.';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var sql100 = `
                select
                    *
                from
                    ksv_po_mst
                where
                    po_cd = '${m_PO_CD}'
                    and po_seq = '${m_PO_SEQ}'
            `;
            var nRet100 = await prisma.$queryRaw(Prisma.raw(sql100));
            if (nRet100.length > 0) {
                /*
          if (parseFloat(nRet100[0].PO_STATUS) > 2) {
              var tRetArray = [];
              var tObj = {};
              tObj.CODE = 'ERROR:해당 Po Seq는 이미 Auto Stock을 진행했습니다.';
              tObj.id = 0;
              tRetArray.push(tObj);
              return tRetArray;
          }
          */
            }

            var tSQL0_1 = `
                select
                    a.order_cd,
                    b.factory_cd
                from
                    ksv_po_mem a,
                    ksv_order_mst b
                where
                    a.po_cd = '${m_PO_CD}'
                    and a.order_cd = b.order_cd
            `;
            var nRet0_1 = await prisma.$queryRaw(Prisma.raw(tSQL0_1));

            var m_FACTORY_CD = nRet0_1[0].factory_cd;
            var m_BUYER_CD = nRet0_1[0].order_cd.substring(0, 2);
            var m_BUYER_CD_SQL = '';

            if (
                m_BUYER_CD === 'MG' ||
                m_BUYER_CD === 'MK' ||
                m_BUYER_CD === 'ME'
            ) {
                m_BUYER_CD_SQL = "left(order_cd,2) in ('MG','MK','ME')";
            } else if (m_BUYER_CD === 'SP') {
                m_BUYER_CD_SQL = "left(order_cd,2) in ('SF','SP')";
            } else if (m_BUYER_CD === 'SK') {
                m_BUYER_CD_SQL = "left(order_cd,2) in ('SF','SK')";
            } else {
                m_BUYER_CD_SQL = `order_cd like '${m_BUYER_CD}%'`;
            }

            let tSQL99 = `
                update ksv_po_mrp
                set
                    stock_chk = ''
                where
                    po_cd = '${m_PO_CD}'
                    and po_seq = '${m_PO_SEQ}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            let tSQL99 = `
                delete from kcd_matl_cd_rep
                where
                    reg_user = '${m_USER_ID}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            let tSQL99 = `
                insert into
                    kcd_matl_cd_rep
                select distinct
                    a.matl_cd,
                    case
                        when b.rep_matl_cd = '' then a.matl_cd
                        else b.rep_matl_cd
                    end,
                    '${m_USER_ID}'
                from
                    ksv_po_mrp a,
                    kcd_matl_mst b
                where
                    a.matl_cd = b.matl_cd
                    and a.po_cd = '${m_PO_CD}'
                    and a.po_seq = '${m_PO_SEQ}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            let tSQL99 = `
                delete from ksv_po_log
                where
                    po_cd = '${m_PO_CD}'
                    and po_seq = '1'
                    and fix_flag = '0'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            let tSQL99 = `
                insert into
                    ksv_po_log (po_cd, po_seq, reg_user, reg_datetime, fix_flag)
                values
                    (
                        '${m_PO_CD}',
                        '1',
                        '${m_USER_ID}',
                        '${tRetDate}',
                        '0'
                    )
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:STOCK_CHECK_STEP-1';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            tSQLArray = [];

            if (m_FACTORY_CD === 'FC044') {
                let tSQL99 = `
                    update ksv_po_mrp
                    set
                        stock_chk = '*'
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = '${m_PO_SEQ}'
                        and matl_cd in (
                            select
                                matl_cd
                            from
                                ksv_stock_matl
                            where
                                factory_cd in ('${m_FACTORY_CD}')
                                and matl_cd = ksv_po_mrp.matl_cd
                                and stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                                and remain_qty > 0.999
                                and ${m_BUYER_CD_SQL}
                        )
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                tSQLArray.push(tSQL99_1);

                let tSQL99 = `
                    update ksv_po_mrp
                    set
                        stock_chk = '*'
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = '${m_PO_SEQ}'
                        and matl_cd in (
                            select
                                matl_cd
                            from
                                kcd_matl_mst
                            where
                                rep_matl_cd in (
                                    select
                                        matl_cd
                                    from
                                        ksv_stock_matl
                                    where
                                        factory_cd in ('${m_FACTORY_CD}')
                                        and matl_cd = kcd_matl_mst.rep_matl_cd
                                        and stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                                        and remain_qty > 0.999
                                        and ${m_BUYER_CD_SQL}
                                )
                        )
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                tSQLArray.push(tSQL99_1);
            } else {
                let tSQL99 = `
                    update ksv_po_mrp
                    set
                        stock_chk = '*'
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = '${m_PO_SEQ}'
                        and matl_cd in (
                            select
                                matl_cd
                            from
                                ksv_stock_matl
                            where
                                factory_cd in ('${m_FACTORY_CD}')
                                and matl_cd = ksv_po_mrp.matl_cd
                                and stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                                and remain_qty > 0.999
                                and ${m_BUYER_CD_SQL}
                        )
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                tSQLArray.push(tSQL99_1);

                let tSQL99 = `
                    update ksv_po_mrp
                    set
                        stock_chk = '*'
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = '${m_PO_SEQ}'
                        and matl_cd in (
                            select
                                b.rep_matl_cd
                            from
                                ksv_stock_matl a,
                                kcd_matl_cd_rep b
                            where
                                a.matl_cd = b.matl_cd
                                and a.factory_cd in ('${m_FACTORY_CD}')
                                and a.stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                                and a.remain_qty > 0.999
                                and ${m_BUYER_CD_SQL}
                                and b.reg_user = '${m_USER_ID}'
                        )
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                tSQLArray.push(tSQL99_1);
            }

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:AutoStock:STOCK_CHECK_STEP-2';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var tSQL1 = `
                select
                    a.order_cd,
                    a.matl_cd,
                    a.mrp_seq,
                    a.po_qty,
                    a.matl_seq,
                    b.rep_matl_cd
                from
                    ksv_po_mrp a,
                    kcd_matl_mst b
                where
                    a.po_cd = '${m_PO_CD}'
                    and a.po_seq = '${m_PO_SEQ}'
                    and a.use_po_type = '1'
                    and a.diff_po_type in ('0', '3')
                    and a.stock_chk = '*'
                    and a.po_qty > 0
                    and b.matl_cd = a.matl_cd
                order by
                    6
            `;
            var nRet1 = await prisma.$queryRaw(Prisma.raw(tSQL1));

            var tIdx1 = 0;
            var m_nSecSeq = 0;

            for (tIdx1 = 0; tIdx1 < nRet1.length; tIdx1++) {
                var tOne1 = { ...nRet1[tIdx1] };

                tSQLArray = [];
                var nUseQty = parseFloat(tOne1.po_qty);
                var nUseSum = 0;

                var tSQL2 = '';
                if (m_FACTORY_CD === 'FC044') {
                    tSQL2 = `
                        select
                            a.po_cd,
                            a.po_seq,
                            a.order_cd,
                            a.matl_cd,
                            a.mrp_seq,
                            a.matl_seq,
                            a.stock_idx,
                            a.remain_qty,
                            d.matl_price,
                            d.curr_cd
                        from
                            ksv_stock_matl a,
                            kcd_matl_mem d
                        where
                            a.factory_cd in ('${m_FACTORY_CD}')
                            and a.matl_cd in ('${tOne1.matl_cd}', '${tOne1.rep_matl_cd}')
                            and a.stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                            and a.remain_qty >= 1
                            and ${m_BUYER_CD_SQL}
                            and d.matl_cd = a.matl_cd
                            and d.matl_seq = a.matl_seq
                        order by
                            7
                    `;
                } else {
                    tSQL2 = `
                        select
                            a.po_cd,
                            a.po_seq,
                            a.order_cd,
                            a.matl_cd,
                            a.mrp_seq,
                            a.matl_seq,
                            a.stock_idx,
                            a.remain_qty,
                            d.matl_price,
                            d.curr_cd
                        from
                            ksv_stock_matl a,
                            kcd_matl_mem d,
                            kcd_matl_cd_rep c
                        where
                            a.factory_cd in ('${m_FACTORY_CD}')
                            and a.matl_cd in ('${tOne1.matl_cd}', '${tOne1.rep_matl_cd}')
                            and a.stock_status in ('3','5','M','R','Y','P','C','A','N','W','O')
                            and a.remain_qty >= 1
                            and ${m_BUYER_CD_SQL}
                            and d.matl_cd = a.matl_cd
                            and d.matl_seq = a.matl_seq
                            and c.reg_user = '${m_USER_ID}'
                            and c.matl_cd = '${tOne1.matl_cd}'
                        order by
                            7
                    `;
                }

                var nRet2 = await prisma.$queryRaw(Prisma.raw(tSQL2));

                var tIdx2 = 0;
                for (tIdx2 = 0; tIdx2 < nRet2.length; tIdx2++) {
                    var tOne2 = nRet2[tIdx2];
                    var nStockQty = parseFloat(tOne2.remain_qty);

                    if (nUseQty <= 0) break;

                    var nUpdateQty = 0;

                    if (nStockQty >= nUseQty) {
                        nUpdateQty = nUseQty;
                        nUseQty -= nUseQty;
                        nUseSum += nUpdateQty;
                    } else {
                        nUpdateQty = nStockQty;
                        nUseQty -= nStockQty;
                        nUseSum += nUpdateQty;
                    }

                    m_nSecSeq += 1;
                    if (m_nSecSeq === 10000) m_nSecSeq = 0;

                    let tSQL99 = `
                        insert into
                            ksv_po_mrp (
                                po_cd,
                                po_seq,
                                order_cd,
                                matl_cd,
                                mrp_seq,
                                matl_seq,
                                matl_price,
                                use_size,
                                use_qty,
                                po_qty,
                                bef_po_qty,
                                diff_qty,
                                diff_po_type,
                                change_reason,
                                use_po_type,
                                curr_cd,
                                tot_amt,
                                curr_date,
                                usd_amt,
                                status_cd,
                                reg_user,
                                reg_datetime,
                                po_matl_cd,
                                po_mrp_seq,
                                stock_idx
                            )
                        values
                            (
                                '${m_PO_CD}',
                                '${m_PO_SEQ}',
                                '${tOne1.order_cd}',
                                '${tOne2.matl_cd}',
                                '${tNewMrpSeq}',
                                '${tOne2.matl_seq}',
                                '${tOne2.matl_price}',
                                '',
                                '${nUpdateQty}',
                                '${nUpdateQty}',
                                '0',
                                '0',
                                '0',
                                '',
                                '2',
                                '${tOne2.curr_cd}',
                                ' 0 ',
                                '${tRetDate1}',
                                '0',
                                '0',
                                '${m_USER_ID}',
                                '${tRetDate}',
                                '${tOne1.matl_cd}',
                                '${tOne1.mrp_seq}',
                                '${tOne2.stock_idx}'
                            )
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    let tSQL99 = `
                        update ksv_stock_matl
                        set
                            remain_qty = remain_qty - ${nUpdateQty},
                            use_qty = use_qty + ${nUpdateQty}
                        where
                            stock_idx = '${tOne2.stock_idx}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    let tSQL99 = `
                        insert into
                            ksv_stock_use (
                                stock_idx,
                                use_datetime,
                                use_qty,
                                use_po_cd,
                                use_po_seq,
                                use_order_cd,
                                use_matl_cd,
                                use_mrp_seq,
                                use_matl_seq,
                                factory_cd,
                                status_cd,
                                reg_user,
                                reg_datetime
                            )
                        values
                            (
                                '${tOne2.stock_idx}',
                                '${tRetDate}',
                                '${nUpdateQty}',
                                '${m_PO_CD}',
                                '${m_PO_SEQ}',
                                '${tOne1.order_cd}',
                                '${tOne2.matl_cd}',
                                '${tNewMrpSeq}',
                                '${tOne2.matl_seq}',
                                '${m_FACTORY_CD}',
                                '0',
                                '${m_USER_ID}',
                                '${tRetDate}'
                            )
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    tNewMrpSeq += 1;
                }

                if (nUseSum > 0) {
                    let tSQL99 = `
                        update ksv_po_mrp
                        set
                            use_qty = po_qty,
                            po_qty = po_qty - ${nUseSum},
                            po_matl_cd = '재고발주'
                        where
                            po_cd = '${m_PO_CD}'
                            and po_seq = '${m_PO_SEQ}'
                            and order_cd = '${tOne1.order_cd}'
                            and matl_cd = '${tOne1.matl_cd}'
                            and mrp_seq = '${tOne1.mrp_seq}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    let tSQL99 = `
                        update ksv_stock_mem
                        set
                            po_qty = po_qty - ${nUseSum}
                        where
                            po_cd = '${m_PO_CD}'
                            and po_seq = '${m_PO_SEQ}'
                            and order_cd = '${tOne1.order_cd}'
                            and matl_cd = '${tOne1.matl_cd}'
                            and mrp_seq = '${tOne1.mrp_seq}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);
                }

                try {
                    global.currentTransactionInfo = {
                        contextValue: contextValue,
                        functionName: AFLib.getFunctionName(),
                    };
                    await prisma.$transaction(tSQLArray);
                    delete global.currentTransactionInfo;
                } catch (e) {
                    var tRetArray = [];
                    var tObj = {};
                    tObj.CODE = `ERROR:AutoStock:STEP-3:${e.message}`;
                    tObj.id = 0;
                    tRetArray.push(tObj);
                    return tRetArray;
                }
            }

            var tRetArray = [];
            var tObj = {};
            tObj.CODE = 'SUCCEED:AutoStock';
            tObj.id = nRet1.count;
            tRetArray.push(tObj);

            return tRetArray;
        },

        mgrUseStock_S030503_3_N_1: async (_, args, contextValue) => {
            // DEST (N),  SRC(1)
            var tRetDate = AFLib.getCurrTime();
            var tRetDate1 = tRetDate.substring(0, 8);
            var tUserInfo = AFLib.getUserInfo(contextValue);

            var tSQLArray = [];

            var tSQL0 = `
                select
                    isnull(max(mrp_seq), 0) + 1 as new_seq
                from
                    ksv_po_mrp
                where
                    po_cd = '${args.datas.PO_CD}'
            `;
            var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL0));
            var tNewMrpSeq = nRet0[0].new_seq;

            var m_PO_CD = args.datas.PO_CD;
            var m_PO_SEQ = args.datas.PO_SEQ;
            var m_USER_ID = tUserInfo.USER_ID;

            if (parseFloat(m_PO_SEQ) <= 0 || parseFloat(m_PO_SEQ) >= 97) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = 'ERROR:Po Seq는 0보다 크도 97보다 작아야 합니다.';
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            var tUsedQty = 0;
            var tIdx9 = 0;
            var tSrcObj = { ...args.datas.SRC_DATA[0] };
            var tRemainQty = tSrcObj.USE_QTY;
            if (parseFloat(tSrcObj.USE_QTY) >= parseFloat(tSrcObj.REMAIN_QTY))
                tRemainQty = parseFloat(tSrcObj.REMAIN_QTY);
            for (tIdx9 = 0; tIdx9 < args.datas.DEST_DATA.length; tIdx9++) {
                if (tRemainQty <= 0) continue;

                var tDestObj = { ...args.datas.DEST_DATA[tIdx9] };

                var tUseQty = 0;

                if (parseFloat(tDestObj.PO_QTY) > tRemainQty) {
                    tUseQty = tRemainQty;
                    tRemainQty = 0;
                } else {
                    tUseQty = parseFloat(tDestObj.PO_QTY);
                    tRemainQty -= tUseQty;
                }

                var tSQL1 = `
                    update ksv_po_mrp
                    set
                        po_qty = po_qty - ${tUseQty},
                        po_matl_cd = '재고발주'
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = ${tDestObj.PO_SEQ}
                        and order_cd = '${tDestObj.ORDER_CD}'
                        and matl_cd = '${tDestObj.MATL_CD}'
                        and mrp_seq = ${tDestObj.MRP_SEQ}
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL1));
                tSQLArray.push(tSQL99_1);

                var tSQL2 = `
                    update ksv_stock_mem
                    set
                        po_qty = po_qty - ${tUseQty}
                    where
                        po_cd = '${m_PO_CD}'
                        and po_seq = ${tDestObj.PO_SEQ}
                        and order_cd = '${tDestObj.ORDER_CD}'
                        and matl_cd = '${tDestObj.MATL_CD}'
                        and mrp_seq = ${tDestObj.MRP_SEQ}
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL2));
                tSQLArray.push(tSQL99_1);

                var tSQL3 = `
                    insert into
                        ksv_po_mrp (
                            po_cd,
                            po_seq,
                            order_cd,
                            matl_cd,
                            mrp_seq,
                            matl_seq,
                            matl_price,
                            use_qty,
                            po_qty,
                            bef_po_qty,
                            diff_qty,
                            diff_po_type,
                            use_po_type,
                            curr_cd,
                            tot_amt,
                            curr_date,
                            usd_amt,
                            status_cd,
                            reg_user,
                            reg_datetime,
                            po_matl_cd,
                            po_mrp_seq,
                            stock_idx
                        )
                    values
                        (
                            '${m_PO_CD}',
                            ${tDestObj.PO_SEQ},
                            '${tDestObj.ORDER_CD}',
                            '${tSrcObj.MATL_CD}',
                            ${tNewMrpSeq},
                            '${tSrcObj.MATL_SEQ}',
                            ${tSrcObj.MATL_PRICE},
                            ${tUseQty},
                            ${tUseQty},
                            0,
                            0,
                            '0',
                            '2',
                            '${tDestObj.CURR_CD}',
                            0,
                            '${tRetDate1}',
                            0,
                            '0',
                            '${m_USER_ID}',
                            '${tRetDate}',
                            '${tDestObj.MATL_CD}',
