            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_NAT_CD = tRet;
            let tNatCd = {};
            tNatCd.NAT_CD = ' ';
            tNatCd.NAT_NAME = ' ';
            tWRet.CODE_NAT_CD.unshift(tNatCd);

            var tSQL = '';
            let sqlStr = `
                SELECT
                    *
                FROM
                    KCD_CURRENCY
                where
                    start_date = (
                        select
                            max(start_date)
                        from
                            kcd_currency
                        where
