}

const comparisonFn = function (prevProps, nextProps) {
    return prevProps.location.pathname === nextProps.location.pathname;
};

/** memo 비교: pathname이 변할 때만 리렌더 */
const propsAreEqual = (prevProps, nextProps) => {
  const prev = prevProps?.pathname ?? '';
  const next = nextProps?.pathname ?? '';
  return prev === next;
};
const MemoMgrKzzAcctCore = React.memo(MgrKzzAcctCore, propsAreEqual);

/** Wrapper(외부 노출): 기존 명칭 유지 + 라우터에서 pathname 주입 */
const MgrKzzAcct = () => {
  const location = useLocation(); // react-router v6
  return <MemoMgrKzzAcctCore pathname={location?.pathname ?? ''} />;
};

export default MgrKzzAcct;
