// export default로 Mutation 내용 내보내기
const moduleMutation_S030505_03 = {
    Mutation: {
        mgrAddPo_S030505_03: async (_, args, contextValue) => {
            const normalizeText = (value) => {
                if (value === null || typeof value === 'undefined') return '';
                return String(value).trim();
            };

            const ensureMaxLen = (fieldName, value, maxLen) => {
                if (value.length > maxLen) {
                    throw new Error(
                        `${fieldName} length overflow (${value.length} > ${maxLen}): '${value}'`,
                    );
                }
            };

            const fitMaxLen = (value, maxLen) => {
                if (typeof value !== 'string') return '';
                if (value.length <= maxLen) return value;
                return value.substring(0, maxLen);
            };

            const getDbColumnLength = async (tableName, columnName, fallback) => {
                try {
                    const lenSql = `
                        SELECT
                            COL_LENGTH('${tableName}', '${columnName}') AS col_len
                    `;
                    const lenRet = await prisma.$queryRaw(Prisma.raw(lenSql));
                    const dbLen = lenRet?.[0]?.col_len;
                    if (dbLen === null || typeof dbLen === 'undefined') {
                        return fallback;
                    }
                    const parsed = parseInt(dbLen, 10);
                    if (Number.isNaN(parsed) || parsed <= 0) {
                        return fallback;
                    }
                    return parsed;
                } catch (e) {
                    return fallback;
                }
            };

            // Add Seq연동
            var tDate = new Date();
            var mm = tDate.getMonth() + 1;
            var mm_str = '';
            if (mm > 9) mm_str = mm.toString();
            else mm_str = '0' + mm;

            var dd = tDate.getDate();
            var dd_str = '';
            if (dd > 9) dd_str = dd;
            else dd_str = '0' + dd;

            var hours = tDate.getHours();
            var hours_str = '';
            if (hours > 9) hours_str = hours.toString();
            else hours_str = '0' + hours;

            var minutes = tDate.getMinutes();
            var minutes_str = '';
            if (minutes > 9) minutes_str = minutes.toString();
            else minutes_str = '0' + minutes;

            var seconds = tDate.getSeconds();
            var seconds_str = '';
            if (seconds > 9) seconds_str = seconds.toString();
            else seconds_str = '0' + seconds;

            var yyyy = tDate.getFullYear();

            var tRetDate =
                yyyy.toString() +
                mm_str +
                dd_str +
                hours_str +
                minutes_str +
                seconds_str;
            var tRetDate1 = tRetDate.substring(0, 8);
            var tYY = 'B' + yyyy.toString().substring(2) + '-';

            // let tPO = "POA2022S672";
            var tUserInfo = AFLib.getUserInfo(contextValue);
            var tPoCd = normalizeText(args.datas.PO_CD);

            var tPoSeq = '';
            if (
                typeof args.datas.PO_SEQ === 'undefined' ||
                args.datas.PO_SEQ === ' '
            ) {
                tPoSeq = '';
            } else tPoSeq = normalizeText(args.datas.PO_SEQ);

            var tOrderCd = '';
            if (
                typeof args.datas.ORDER_CD === 'undefined' ||
                args.datas.ORDER_CD === ' '
            ) {
                tOrderCd = '';
            } else tOrderCd = normalizeText(args.datas.ORDER_CD);

            const poCdMaxLen = await getDbColumnLength('KSV_PO_MEM', 'PO_CD', 10);
            const orderCdMaxLen = await getDbColumnLength('KSV_PO_MEM', 'ORDER_CD', 20);
            ensureMaxLen('PO_CD', tPoCd, poCdMaxLen);
            ensureMaxLen('ORDER_CD', tOrderCd, orderCdMaxLen);

            var tDeliveryType = '';
            if (
                typeof args.datas.DELIVERY_TYPE === 'undefined' ||
                args.datas.DELIVERY_TYPE === ' '
            ) {
                tDeliveryType = '';
            } else tDeliveryType = normalizeText(args.datas.DELIVERY_TYPE);

            const deliveryTypeMaxLen = await getDbColumnLength(
                'KSV_PO_MST',
                'DELIVERY_TYPE',
                10,
            );
            tDeliveryType = fitMaxLen(tDeliveryType, deliveryTypeMaxLen);

            var tSQLArray = [];

            var tStartMrpSeq = 0;
            var tSql0 = `
                select
                    isnull(max(mrp_seq), 0) as max_cnt
                from
                    ksv_po_mrp
                where
                    po_cd = '${tPoCd}'
                    and po_seq = '${tPoSeq}'
            `;
            if (tPoSeq !== '') {
                var nRet0 = await prisma.$queryRaw(Prisma.raw(tSql0));
                tStartMrpSeq = nRet0[0].max_cnt;
            }

            var tSql = `
                select
                    isnull(max(po_seq), 100) as max_cnt
                from
                    ksv_po_mst
                where
                    po_cd = '${tPoCd}'
                    and po_seq > 100
            `;
            var nRet = await prisma.$queryRaw(Prisma.raw(tSql));
            var tNewPoSeq = parseInt(nRet[0].max_cnt) + 1;

            console.log('---------------------------', tNewPoSeq);

            if (tPoSeq !== '') {
                tNewPoSeq = parseInt(tPoSeq) + 1;
            }

            var tInsSql1 = `
                INSERT INTO
                    KSV_PO_MEM (PO_CD, PO_SEQ, ORDER_CD)
                VALUES
                    ('${tPoCd}', ${tNewPoSeq}, '${tOrderCd}')
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql1));
            if (tPoSeq === '') tSQLArray.push(tSQL99_1);

            var tInsSql2 = `
                INSERT INTO
                    KSV_PO_MST (
                        PO_CD,
                        PO_SEQ,
                        PO_TYPE,
                        PO_DATE,
                        PO_STATUS,
                        MATL_DUE_DATE,
                        PROD_DUE_DATE,
                        PLACE_CD,
                        CURR_DATE,
                        YY,
                        SEQ,
                        factory_cd,
                        delivery_type,
                        STATUS_CD,
                        REG_USER,
                        REG_DATETIME
                    )
                SELECT
                    PO_CD,
                    ${tNewPoSeq},
                    'A',
                    '${tRetDate1}',
                    '4',
                    isnull(MATL_DUE_DATE, ''),
                    isnull(PROD_DUE_DATE, ''),
                    isnull(PLACE_CD, ''),
                    '${tRetDate1}',
                    YY,
                    SEQ,
                    '${args.datas.FACTORY_CD}',
                    '${tDeliveryType}',
                    '0',
                    '${tUserInfo.USER_ID}',
                    '${tRetDate}'
                FROM
                    KSV_PO_MST
                WHERE
                    PO_CD = '${tPoCd}'
                    AND PO_SEQ = '1'
                    AND NOT EXISTS (
                        SELECT
                            1
                        FROM
                            KSV_PO_MST B
                        WHERE
                            B.PO_CD = '${tPoCd}'
                            AND B.PO_SEQ = ${tNewPoSeq}
                    )
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql2));
            tSQLArray.push(tSQL99_1);

            var tInsSql3 = '';
            var tIdx = 0;
            for (tIdx = 0; tIdx < args.datas1.length; tIdx++) {
                var col = { ...args.datas1[tIdx] };

                var tMrpSeq = tStartMrpSeq + tIdx + 1;
                var tTotAmt = parseInt(col.PO_QTY) * parseFloat(col.MATL_PRICE);

                var tSql = `
                    INSERT INTO
                        KSV_PO_MRP (
                            PO_CD,
                            PO_SEQ,
                            ORDER_CD,
                            MATL_CD,
                            MRP_SEQ,
                            MATL_SEQ,
                            MATL_PRICE,
                            USE_SIZE,
                            USE_QTY,
                            PO_QTY,
                            BEF_PO_QTY,
                            DIFF_QTY,
                            DIFF_PO_TYPE,
                            CHANGE_REASON,
                            CURR_CD,
                            TOT_AMT,
                            CURR_DATE,
                            USD_AMT,
                            STATUS_CD,
                            REG_USER,
                            REG_DATETIME,
                            USE_PO_TYPE,
                            reason_type,
                            fare_type,
                            remark,
                            stock_idx
                        )
                    VALUES
                        (
                            '${tPoCd}',
                            ${tNewPoSeq},
                            '${tOrderCd}',
                            '${col.MATL_CD}',
                            ${tMrpSeq},
                            ${col.MATL_SEQ},
                            ${col.MATL_PRICE},
                            '',
                            ${col.PO_QTY},
                            ${col.PO_QTY},
                            0,
                            0,
                            '0',
                            ' ',
                            '${col.CURR_CD}',
                            ${tTotAmt},
                            '${tRetDate1}',
                            0,
                            '0',
                            '${tUserInfo.USER_ID}',
                            '${tRetDate}',
                            '${col.USE_PO_TYPE}',
                            '${col.REASON_TYPE}',
                            '${col.FARE_TYPE}',
                            '${col.REMARK}',
                            '${col.STOCK_IDX}'
                        );
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSql));
                tSQLArray.push(tSQL99_1);

                if (col.USE_PO_TYPE === '1') {
                    // 발주
                    tSql = `
                        INSERT INTO
                            KSV_STOCK_MEM (
                                PO_CD,
                                PO_SEQ,
                                ORDER_CD,
                                MATL_CD,
                                MRP_SEQ,
                                MATL_SEQ,
                                PO_QTY,
                                IN_QTY,
                                OUT_QTY,
                                INFAC_QTY,
                                OUTFAC_QTY,
                                REMAIN_QTY,
                                use_qty,
                                FACTORY_CD,
                                DIFF_PO_TYPE,
                                diff_qty,
                                STOCK_STATUS,
                                STATUS_CD,
                                REG_USER,
                                REG_DATETIME
                            )
                        VALUES
                            (
                                '${tPoCd}',
                                ${tNewPoSeq},
                                '${tOrderCd}',
                                '${col.MATL_CD}',
                                ${tMrpSeq},
                                ${col.MATL_SEQ},
                                ${col.PO_QTY},
                                0,
                                0,
                                0,
                                0,
                                0,
                                0,
                                '${args.datas.FACTORY_CD}',
                                '0',
                                0,
                                '0',
                                '0',
                                '${tUserInfo.USER_ID}',
                                '${tRetDate}'
                            );
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSql));
                    tSQLArray.push(tSQL99_1);

                    var tSqlTmp = `
                        select
                            count(*) as cnt
                        from
                            ksv_po_vendor
                        where
                            vendor_cd = '${col.VENDOR_CD}'
                            and po_cd = '${tPoCd}'
                    `;
                    var tRetTmp = await prisma.$queryRaw(Prisma.raw(tSqlTmp));
                    if (tRetTmp.length <= 0) {
                        tSql = `
                            insert INTO
                                KSV_po_vendor (PO_CD, vendor_cd, end_date)
                            VALUES
                                ('${tPoCd}', '${col.VENDOR_CD}', '');
                        `;
                        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSql));
                        tSQLArray.push(tSQL99_1);
                    }
                } else {
                    // 재고사용
                    tSql = `
                        update ksv_stock_matl
                        set
                            remain_qty = remain_qty - ${col.PO_QTY},
                            use_qty = use_qty + ${col.PO_QTY}
                        where
                            stock_idx = '${col.STOCK_IDX}';
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSql));
                    tSQLArray.push(tSQL99_1);

                    tSql = `
                        insert into
                            ksv_stock_use (
                                stock_idx,
                                use_datetime,
                                use_qty,
                                use_po_cd,
                                use_po_seq,
                                use_order_cd,
                                use_matl_cd,
                                use_mrp_seq,
                                use_matl_seq,
                                factory_cd,
                                status_cd,
                                reg_user,
                                reg_datetime
                            )
                        values
                            (
                                '${col.STOCK_IDX}',
                                '${tRetDate}',
                                ${col.PO_QTY},
                                '${tPoCd}',
                                ${tNewPoSeq},
                                '${tOrderCd}',
                                '${col.MATL_CD}',
                                ${tMrpSeq},
                                ${col.MATL_SEQ},
                                '${args.datas.FACTORY_CD}',
                                '0',
                                '${tUserInfo.USER_ID}',
                                '${tRetDate}'
                            );
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSql));
                    tSQLArray.push(tSQL99_1);
                }
            }

            var tInsSql4 = `
                INSERT INTO
                    KSV_STOCK_MST (
                        PO_CD,
                        PO_SEQ,
                        IN_FACTORY_CD,
                        OUT_FACTORY_CD,
                        STATUS_CD,
                        REG_DATETIME,
                        REG_USER
                    )
                SELECT
                    
                        '${tPoCd}',
                        ${tNewPoSeq},
                        'FC010',
                        '${args.datas.FACTORY_CD}',
                        '0',
                        '${tRetDate}',
                        '${tUserInfo.USER_ID}'
                WHERE
                    EXISTS (
                        SELECT
                            1
                        FROM
                            KSV_PO_MST
                        WHERE
                            PO_CD = '${tPoCd}'
                            AND PO_SEQ = ${tNewPoSeq}
                    )
                    AND NOT EXISTS (
                        SELECT
                            1
                        FROM
                            KSV_STOCK_MST
                        WHERE
                            PO_CD = '${tPoCd}'
                            AND PO_SEQ = ${tNewPoSeq}
                            AND IN_FACTORY_CD = 'FC010'
                            AND OUT_FACTORY_CD = '${args.datas.FACTORY_CD}'
                    )
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql4));
            if (args.datas.PO_SEQ === '') tSQLArray.push(tSQL99_1);

            // 자재종합표
            /*
            const retMatlAdj1 = await mrpProcedureService.run('adjust', {
                poCd: tPoCd,
                userId: tUserInfo.USER_ID,
            });
            if (!retMatlAdj1.ok)
                throw new Error(retMatlAdj1.message || retMatlAdj1.step);
            */

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:${e.message}`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }

            // 당분간 확인될때까지 코드 유지. 260513 Won
            // 자재종합표
            tSQLArray = [];
            var tDelSql5 = `
                 delete from ksv_po_matllist
                 where  po_cd = '${tPoCd}${tUserInfo.USER_ID}'
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tDelSql5));
            tSQLArray.push(tSQL99_1);

            var tExecSql = `exec kspPoMatlListAdjustNoSeq '${tPoCd}','${tUserInfo.USER_ID}' `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tExecSql));
            tSQLArray.push(tSQL99_1);

            try {
                global.currentTransactionInfo = {
                    contextValue: contextValue,
                    functionName: AFLib.getFunctionName(),
                };
                await prisma.$transaction(tSQLArray);
                delete global.currentTransactionInfo;
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `SUCCESS:${tNewPoSeq}`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            } catch (e) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE = `ERROR:${e.message}`;
                tObj.id = 0;
                tRetArray.push(tObj);
                return tRetArray;
            }


        },

        mgrUpdatePo_S030505_03: async (_, args, contextValue) => {
            const normalizeText = (value) => {
                if (value === null || typeof value === 'undefined') return '';
                return String(value).trim();
            };

            const getDbColumnLength = async (tableName, columnName, fallback) => {
                try {
                    const lenSql = `
                        SELECT
                            COL_LENGTH('${tableName}', '${columnName}') AS col_len
                    `;
                    const lenRet = await prisma.$queryRaw(Prisma.raw(lenSql));
                    const dbLen = lenRet?.[0]?.col_len;
                    if (dbLen === null || typeof dbLen === 'undefined') {
                        return fallback;
                    }
                    const parsed = parseInt(dbLen, 10);
                    if (Number.isNaN(parsed) || parsed <= 0) {
                        return fallback;
                    }
                    return parsed;
                } catch (e) {
                    return fallback;
                }
            };

            const fitMaxLen = (value, maxLen) => {
                if (typeof value !== 'string') return '';
                if (value.length <= maxLen) return value;
                return value.substring(0, maxLen);
            };

            //
            var tDate = new Date();
            var mm = tDate.getMonth() + 1;
            var mm_str = '';
            if (mm > 9) mm_str = mm.toString();
            else mm_str = '0' + mm;

            var dd = tDate.getDate();
            var dd_str = '';
            if (dd > 9) dd_str = dd;
            else dd_str = '0' + dd;

            var hours = tDate.getHours();
            var hours_str = '';
            if (hours > 9) hours_str = hours.toString();
            else hours_str = '0' + hours;

            var minutes = tDate.getMinutes();
            var minutes_str = '';
            if (minutes > 9) minutes_str = minutes.toString();
            else minutes_str = '0' + minutes;

            var seconds = tDate.getSeconds();
            var seconds_str = '';
            if (seconds > 9) seconds_str = seconds.toString();
            else seconds_str = '0' + seconds;

            var yyyy = tDate.getFullYear();

            var tRetDate =
                yyyy.toString() +
                mm_str +
                dd_str +
                hours_str +
                minutes_str +
                seconds_str;
            var tRetDate1 = tRetDate.substring(0, 8);
            var tYY = 'B' + yyyy.toString().substring(2) + '-';

            // let tPO = "POA2022S672";
            var tUserInfo = AFLib.getUserInfo(contextValue);

            var tInput1 = { ...args.datas };
            tInput1.DELIVERY_TYPE = normalizeText(tInput1.DELIVERY_TYPE);
            const deliveryTypeMaxLen = await getDbColumnLength(
                'KSV_PO_MST',
                'DELIVERY_TYPE',
                10,
            );
            tInput1.DELIVERY_TYPE = fitMaxLen(
                tInput1.DELIVERY_TYPE,
                deliveryTypeMaxLen,
            );

            var tSQLArray = [];
            for (let tInput2 of args.datas1) {
                var tOldQty = 0;
                var tRemainQty = 0;

                if (tInput2.USE_PO_TYPE === '1') {
                    var tSql = `
                        SELECT
                            in_qty
                        FROM
                            ksv_stock_mem
                        WHERE
                            po_cd = '${tInput1.PO_CD}'
                            and order_cd = '${tInput2.ORDER_CD}'
                            and po_seq = '${tInput1.PO_SEQ}'
                            and matl_cd = '${tInput2.MATL_CD}'
                            and matl_seq = '${tInput2.MATL_SEQ}'
                            and mrp_seq = '${tInput2.USE_MRP_SEQ}'
                    `;
                    var nRet = await prisma.$queryRaw(Prisma.raw(tSql));
                    if (nRet.length > 0 && parseInt(nRet[0].in_qty) > 0) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE = 'ERROR:Already inputted.';
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                } else {
                    var tSql = `
                        SELECT
                            po_qty
                        FROM
                            ksv_po_mrp
                        WHERE
                            po_cd = '${tInput1.PO_CD}'
                            and order_cd = '${tInput2.ORDER_CD}'
                            and po_seq = '${tInput1.PO_SEQ}'
                            and matl_cd = '${tInput2.MATL_CD}'
                            and matl_seq = '${tInput2.MATL_SEQ}'
                            and mrp_seq = '${tInput2.USE_MRP_SEQ}'
                    `;
                    var nRet = await prisma.$queryRaw(Prisma.raw(tSql));
                    tOldQty = 0;
                    if (nRet.length > 0) tOldQty = parseInt(nRet[0].po_qty);

                    var tSql1 = `
                        select
                            remain_qty
                        from
                            ksv_stock_matl
                        where
                            stock_idx = '${tInput2.STOCK_IDX}'
                    `;
                    var nRet1 = await prisma.$queryRaw(Prisma.raw(tSql1));
                    tRemainQty = 0;
                    if (nRet1.length > 0)
                        tRemainQty = parseInt(nRet1[0].remain_qty);

                    if (tOldQty + tRemainQty < parseInt(tInput2.PO_QTY)) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE = 'ERROR:Check Stock Remain Qty.';
                        tObj.id = 0;
                        tRetArray.push(tObj);
                        return tRetArray;
                    }
                }

                var tInsSql1 = `
                    update ksv_po_mrp
                    set
                        use_qty = '${tInput2.PO_QTY}',
                        po_qty = '${tInput2.PO_QTY}',
                        reason_type = '${tInput2.REASON_TYPE}',
                        fare_type = '${tInput2.FARE_TYPE}'
                    WHERE
                        po_cd = '${tInput1.PO_CD}'
                        and order_cd = '${tInput2.ORDER_CD}'
                        and po_seq = '${tInput1.PO_SEQ}'
                        and matl_cd = '${tInput2.MATL_CD}'
                        and matl_seq = '${tInput2.MATL_SEQ}'
                        and mrp_seq = '${tInput2.USE_MRP_SEQ}'
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql1));
                tSQLArray.push(tSQL99_1);

                var tInsSql2 = `
                    update ksv_po_mst
                    set
                        delivery_type = '${tInput1.DELIVERY_TYPE}'
                    WHERE
                        po_cd = '${tInput1.PO_CD}'
                        and po_seq = '${tInput1.PO_SEQ}'
                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql2));
                tSQLArray.push(tSQL99_1);

                if (tInput2.USE_PO_TYPE === '1') {
                    var tInsSql3 = `
                        update ksv_stock_mem
                        set
                            po_qty = '${tInput2.PO_QTY}'
                        WHERE
                            po_cd = '${tInput1.PO_CD}'
                            and order_cd = '${tInput2.ORDER_CD}'
                            and po_seq = '${tInput1.PO_SEQ}'
                            and matl_cd = '${tInput2.MATL_CD}'
                            and matl_seq = '${tInput2.MATL_SEQ}'
                            and mrp_seq = '${tInput2.USE_MRP_SEQ}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql3));
                    tSQLArray.push(tSQL99_1);
                } else {
                    var tInsSql3 = `
                        update ksv_stock_matl
                        set
                            remain_qty = remain_qty + ${tOldQty} - ${tInput2.PO_QTY},
                            use_qty = use_qty - (${tOldQty} - ${tInput2.PO_QTY})
                        where
                            stock_idx = '${tInput2.STOCK_IDX}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tInsSql3));
                    tSQLArray.push(tSQL99_1);

                    var tInsSql4 = `
                        update ksv_stock_use
                        set
                            use_qty = '${tInput2.PO_QTY}'
                        WHERE
                            stock_idx = '${tInput2.STOCK_IDX}'
