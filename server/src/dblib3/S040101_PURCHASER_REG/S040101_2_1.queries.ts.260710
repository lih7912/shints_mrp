                        vendor_cd,
                        pu_cd,
                        po_cd2,
                        left(reg_datetime, 8) as reg_datetime
                    FROM
                        ksv_pu_mst2
                    WHERE
                        vendor_cd IN (${Prisma.join(vendors)})
                `;
            }

            var mailRows = [];
            if (vendors.length > 0 && poCds.length > 0) {
                const mailRows = await prisma.$queryRaw`
                    select
