    const process_DELETE_ORDER = async () => {
        var _tObj0 = { ...dataEDT_KSV_ORDER_MST };
        var _tObj = { ...dataEDT_KSV_ORDER_MST1 };

        if (_tObj.ORDER_CD === "") return;

        if (saveJOB_CD !== "") {
            var tRet = await confirm(
                `Capa(${saveJOB_CD}) 삭제도 함께 진행합니다.  오더를 Delete하시겠습니까?`,
            );
            if (!tRet) {
                alert("Capa를 먼저 삭제해 주세요");
                return;
            }
        }

        if (parseFloat(dataEDT_KSV_ORDER_MST1.FOB) > 0) {
            var tRet = await confirm(
                `가격을 0으로 자동수정후 Cancel을 진행합니다.  오더를 Cancel하시겠습니까?`,
            );
            if (!tRet) {
                alert("가격을 0으로 수정해 주세요");
                return;
            }
            _tObj.FOB = "0";
            _tObj.FOB_USD = "0";
        }

        var tObj = {};
        tObj.ORDER_CD = _tObj.ORDER_CD;
        tObj.USER_ID = _tObj0.BUYER_TEAM;

        setLoadingTBL_KSV_ORDER_MST(true);
        serviceS020602_ORDER_REG.mgrDelete_DELETE_ORDER(tObj).then((data) => {
            setLoadingTBL_KSV_ORDER_MST(false);
            if (typeof data.graphQLErrors === "undefined") {
                if (data.length > 0) alert(data[0].CODE);
                if (data.length > 0 && data[0].CODE.includes("SUCC")) {
                    process_REFRESH(tObj.ORDER_CD);
                } else {
                }
            } else {
                alert("graphql error");
            }
        });
    };

