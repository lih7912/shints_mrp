                    AND b.order_cd = '${args.data.ORDER_CD}'
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.FACTORY = tRet;

            let sqlStr = `
                SELECT
                    *
                FROM
                    KCD_FACTORY
                where
                    factory_cd in ('FC010', 'FC034', 'FC044', 'FC045')
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_FACTORY_CD = tRet;
            let tFactoryCd = {};
