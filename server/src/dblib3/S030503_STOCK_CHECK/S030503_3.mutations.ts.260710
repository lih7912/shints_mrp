            var tUserInfo = AFLib.getUserInfo(contextValue);

            var tRemainPoQty = 0;
            args.datas.SRC_DATA.forEach((col, i) => {
                tRemainPoQty += parseFloat(col.USE_QTY);
            });

            var tCols = args.datas.PO_CD.split('/');
            var tPoArray = [];
            var sqlPoCd = '';
            tCols.forEach((col, i) => {
                if (col) {
                    tPoArray.push(col);
                    if (sqlPoCd === '') sqlPoCd = `'${col}'`;
                    else sqlPoCd += `,'${col}'`;
                }
            });

            var wSrcObj = {};
            var wDestObj = {};

            var tSQL0 = `
                select
                    *
                from
