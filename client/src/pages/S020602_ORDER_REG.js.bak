    // DATAGRID CODE : TBL_KSV_ORDER_MST

    const addCombinedOrder = () => {
        if (dataEDT_KSV_ORDER_MST.IS_COMBINED !== "1") return;

        if (
            typeof dataEDT_KSV_ORDER_MST1_SIZE_GROUP === "undefined" ||
            typeof dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_NAME ===
                "undefined" ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP === null ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_GROUP === null ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_GROUP.trim() === ""
        ) {
            alert("Size가 먼저 선택되어야 합니다");
            return;
        }

        var tORDER_MST_ARRAY = [...datasTBL_KSV_ORDER_MST];
        var tWArray = [];

        var tIdx = 0;
        for (tIdx = 0; tIdx < tORDER_MST_ARRAY.length; tIdx++) {
            var tOne = tORDER_MST_ARRAY[tIdx];
            tOne.ORDER_QTY_ONLY = String(
                parseFloat(tOne.ORDER_QTY) - parseFloat(tOne.ADD_QTY),
            );
            if (tOne.id === dataTBL_KSV_ORDER_MST.id) {
                tOne.ORDER_MEM = [...datasTBL_KSV_ORDER_MEM];
                tWArray.push(tOne);
            } else {
                tWArray.push(tOne);
            }
        }

        var _dataEDT_KSV_ORDER_MST1 = { ...dataEDT_KSV_ORDER_MST1 };
        var _dataEDT_KSV_ORDER_MST4 = { ...dataEDT_KSV_ORDER_MST4 };

        if (
            _dataEDT_KSV_ORDER_MST4.NAT_CD === "" ||
            _dataEDT_KSV_ORDER_MST4.BUYER_PO === "" ||
            _dataEDT_KSV_ORDER_MST4.ETD_DATE === "" ||
            _dataEDT_KSV_ORDER_MST4.EXF_DATE === ""
        ) {
            alert("buyer_po, country, exf, etd는  입력되지 않은것이 있습니다");

            return;
        }

        var tFlag = 0;
        tORDER_MST_ARRAY.forEach((col, i) => {
            if (col.BUYER_PO === _dataEDT_KSV_ORDER_MST4.BUYER_PO) tFlag = 1;
        });
        if (tFlag === 1) {
            alert(
                "등록하고자 하는 BUYER PO가 이미 등록되어 있습니다. Buyer Po을 다시 입력하세요",
            );
            return;
        }

        var tObjORDER_MST = {};
        tObjORDER_MST.id = tORDER_MST_ARRAY.length + 1;
        tObjORDER_MST.ORDER_CD = "";
        tObjORDER_MST.TYPE = "Combined";
        tObjORDER_MST.CURR_CD = _dataEDT_KSV_ORDER_MST1.CURR_CD;
        tObjORDER_MST.NAT_CD = _dataEDT_KSV_ORDER_MST4.NAT_CD;
        tObjORDER_MST.NAT_NAME = dataEDT_KSV_ORDER_MST4_NAT_CD.NAT_NAME;
        tObjORDER_MST.BUYER_PO = _dataEDT_KSV_ORDER_MST4.BUYER_PO;
        tObjORDER_MST.EXF_DATE = _dataEDT_KSV_ORDER_MST4.EXF_DATE;
        tObjORDER_MST.ETD_DATE = _dataEDT_KSV_ORDER_MST4.ETD_DATE;
        tObjORDER_MST.IS_DL = _dataEDT_KSV_ORDER_MST4.IS_DL;
        tObjORDER_MST.REMARK1 = _dataEDT_KSV_ORDER_MST4.REMARK1;
        tObjORDER_MST.REMARK2 = _dataEDT_KSV_ORDER_MST4.REMARK2;
        tObjORDER_MST.NOTE = _dataEDT_KSV_ORDER_MST4.NOTE;
        tObjORDER_MST.ORDER_QTY = 0;
        tObjORDER_MST.ADD_QTY = 0;
        tObjORDER_MST.ORDER_QTY_ONLY = 0;
        tObjORDER_MST.ORDER_MEM = [];
        tWArray.push(tObjORDER_MST);

        setDatasTBL_KSV_ORDER_MST(tWArray);
        setDataTBL_KSV_ORDER_MST(tObjORDER_MST);

        setSelectedTBL_KSV_ORDER_MST(tObjORDER_MST);

        setDatasTBL_KSV_ORDER_MEM([]);
        setSelectedTBL_KSV_PROD_MEM([]);

        _dataEDT_KSV_ORDER_MST4.BUYER_PO = "";
        setDataEDT_KSV_ORDER_MST4(_dataEDT_KSV_ORDER_MST4);

        tSaveTBL_KSV_ORDER_MST_ID = tObjORDER_MST.id;

        var tEdt3 = { ...dataEDT_KSV_ORDER_MST3 };
        tEdt3.RATE = "0";
        setDataEDT_KSV_ORDER_MST3(tEdt3);
    };

    const updateCombinedOrder = () => {
        var _dataEDT_KSV_ORDER_MST4 = { ...dataEDT_KSV_ORDER_MST4 };

        if (
            _dataEDT_KSV_ORDER_MST4.NAT_CD === "" ||
            _dataEDT_KSV_ORDER_MST4.BUYER_PO === "" ||
            _dataEDT_KSV_ORDER_MST4.ETD_DATE === "" ||
            _dataEDT_KSV_ORDER_MST4.EXF_DATE === ""
        ) {
            alert("buyer_po, country, exf, etd중 입력되지 않은것이 있습니다");

            return;
        }

        var tNatName = "";
        datasEDT_KSV_ORDER_MST4_NAT_CD.forEach((col, i) => {
            if (col.NAT_CD === _dataEDT_KSV_ORDER_MST4.NAT_CD)
                tNatName = col.NAT_NAME;
        });

        var tObjORDER_MST = { ...dataTBL_KSV_ORDER_MST };
        tObjORDER_MST.NAT_CD = _dataEDT_KSV_ORDER_MST4.NAT_CD;
        tObjORDER_MST.NAT_NAME = tNatName;
        tObjORDER_MST.BUYER_PO = _dataEDT_KSV_ORDER_MST4.BUYER_PO;
        tObjORDER_MST.EXF_DATE = _dataEDT_KSV_ORDER_MST4.EXF_DATE;
        tObjORDER_MST.ETD_DATE = _dataEDT_KSV_ORDER_MST4.ETD_DATE;
        tObjORDER_MST.REMARK1 = _dataEDT_KSV_ORDER_MST4.REMARK1;
        tObjORDER_MST.REMARK2 = _dataEDT_KSV_ORDER_MST4.REMARK2;
        tObjORDER_MST.NOTE = _dataEDT_KSV_ORDER_MST4.NOTE;

        if (dataEDT_KSV_ORDER_MST.IS_COMBINED !== "1") return;

        var tORDER_MST_ARRAY = [...datasTBL_KSV_ORDER_MST];
        var tWArray = [];

        var tIdx = 0;
        for (tIdx = 0; tIdx < tORDER_MST_ARRAY.length; tIdx++) {
            var tOne = tORDER_MST_ARRAY[tIdx];
            if (tOne.id === tObjORDER_MST.id) {
                var tVal =
                    parseFloat(tObjORDER_MST.ORDER_QTY) -
                    parseFloat(tObjORDER_MST.ADD_QTY);
                tObjORDER_MST.ORDER_QTY_ONLY = String(tVal);
                tWArray.push(tObjORDER_MST);
            } else {
                var tVal =
                    parseFloat(tOne.ORDER_QTY) - parseFloat(tOne.ADD_QTY);
                tOne.ORDER_QTY_ONLY = String(tVal);
                tWArray.push(tOne);
            }
        }

        setDatasTBL_KSV_ORDER_MST(tWArray);
        setDataTBL_KSV_ORDER_MST(tObjORDER_MST);
        setSelectedTBL_KSV_ORDER_MST(tObjORDER_MST);
    };

    const editTBL_KSV_ORDER_MST = (argData) => {};

    const calc_MAIN_ORDER_MEM = (argData) => {
        var _tTotalCnt = 0;
        var _tAddCnt = 0;

        var tTmpArray = [];
        var tIdx = 0;
        for (tIdx = 1; tIdx < datasTBL_KSV_ORDER_MST.length; tIdx++) {
            var tObj = { ...datasTBL_KSV_ORDER_MST[tIdx] };
            // if (tObj.TYPE === 'Main' || tObj.TYPE === 'Combined') {
            if (tObj.TYPE === "Combined") {
            } else {
                continue;
            }
            var tIdx1 = 0;
            for (tIdx1 = 0; tIdx1 < tObj.ORDER_MEM.length; tIdx1++) {
                var tOne = { ...tObj.ORDER_MEM[tIdx1] };

                var tFlag = -1;
                var tIdx2 = 0;
                for (tIdx2 = 0; tIdx2 < tTmpArray.length; tIdx2++) {
                    var tOne1 = tTmpArray[tIdx2];
                    if (
                        tOne.COLOR === tOne1.COLOR &&
                        tOne.ADD_FLAG === tOne1.ADD_FLAG
                    ) {
                        var tKeys = Object.keys(tOne1);
                        var tIdx3 = 0;
                        var tTotCnt = 0;
                        for (tIdx3 = 0; tIdx3 < tKeys.length; tIdx3++) {
                            var tKey = tKeys[tIdx3];
                            if (tKey.includes("SIZE_COL_")) {
                                var tMainValue = parseInt(tOne1[`${tKey}`]);
                                var tSubValue = parseInt(tOne[`${tKey}`]);
                                tOne1[`${tKey}`] = tMainValue + tSubValue;
                                tTotCnt += tMainValue + tSubValue;
                            }
                        }
                        tOne1.TOT_CNT = tTotCnt;
                        _tTotalCnt += tOne1.TOT_CNT;
                        if (tOne.ADD_FLAG === "1") _tAddCnt += tOne1.TOT_CNT;

                        tFlag = 0;
                        break;
                    }
                }

                if (tFlag < 0) tTmpArray.push(tOne);
            }
        }

        _tTotalCnt = 0;
        _tAddCnt = 0;

        tTmpArray.forEach((col, i) => {
            _tTotalCnt += parseInt(col.TOT_CNT);
            if (col.ADD_FLAG === "1") _tAddCnt += parseInt(col.TOT_CNT);
        });

        var tRetObj = {};
        tRetObj.TotalCnt = _tTotalCnt;
        tRetObj.AddCnt = _tAddCnt;
        tRetObj.TmpArray = [...tTmpArray];

        return tRetObj;
    };

    const onRowClick1TBL_KSV_ORDER_MST = (argData0) => {
        if (
            typeof dataEDT_KSV_ORDER_MST1_SIZE_GROUP === "undefined" ||
            typeof dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_NAME ===
                "undefined" ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP === null ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_GROUP === null ||
            dataEDT_KSV_ORDER_MST1_SIZE_GROUP.SIZE_GROUP.trim() === ""
