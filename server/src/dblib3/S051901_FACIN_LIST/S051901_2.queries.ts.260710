                      kk.COLOR,
                      kk.SPEC,
                      kk.UNIT,
                      isnull(sum(kk.S_OUT_QTY), 0) as S_OUT_QTY,
                      isnull(sum(kk.MOQ_QTY), 0) as MOQ_QTY,
                      kk.SHORTAGE_QTY,
                      kk.DEFECT_QTY,
