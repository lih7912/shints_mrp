    const s3FileDownload = async (argFileUrl, argFileName) => {
        serviceLib.downloadFile(argFileUrl, argFileName);
    };

    const s3FileDelete = async () => {
        try {
            if (!selectedKCD_BUYER_FILE_INFO) {
                alert("삭제할 파일을 선택해주세요");
            } else {
                const body = {
                    objectName: selectedKCD_BUYER_FILE_INFO.OBJECT_NAME,
                };
                let tUrl = `${apiOption.apiuri}/restapi/deleteImg`;
                const response = await axios.post(tUrl, body);

                console.log(response);

                var tEdtObj0 = { ...dataEDT_KSV_ORDER_MST1 };
                var tInObj = {};
                tInObj.FILE_KEY = tEdtObj0.ORDER_CD;
                tInObj.TITLE = selectedKCD_BUYER_FILE_INFO.TITLE;
                tInObj.NAME = selectedKCD_BUYER_FILE_INFO.NAME;
                tInObj.URL = selectedKCD_BUYER_FILE_INFO.URL;
                tInObj.OBJECT_NAME = selectedKCD_BUYER_FILE_INFO.OBJECT_NAME;

                if (response) {
                    serviceS020602_ORDER_REG
                        .mgrInsert_FILE_DELETE(tInObj)
                        .then((data) => {
                            if (typeof data.graphQLErrors === "undefined") {
                                search_FILE_INFO();
                            } else {
                                console.log(
                                    "mgrInsert_S020602_5_FILE_DELETE => " +
                                        JSON.stringify(data.graphQLErrors),
                                );
                            }
                        });
                } else {
                    alert("삭제 실패");
                }
            }
        } catch (err) {
            alert("에러 발생");
            console.log(err);
        }
    };

