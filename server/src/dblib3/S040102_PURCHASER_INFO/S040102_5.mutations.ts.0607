                    from
                        ksv_stock_in a,
                        kcd_matl_mst b,
                        kcd_vendor c,
                        ksv_po_mst d
                    where
                        a.matl_cd = b.matl_cd
                        and b.vendor_cd = c.vendor_cd
                        and a.po_cd in (
                            select distinct
                                po_cd
