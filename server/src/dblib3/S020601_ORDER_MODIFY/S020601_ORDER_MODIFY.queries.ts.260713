                WHERE
                    CD_GROUP = 'SAMPLE_REASON'
            `;
            tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_SAMPLE_REASON = tRet;
            tWRet.CODE_SAMPLE_REASON.unshift(tCode);

            tSQL = '';
            let sqlStr = `
                SELECT
