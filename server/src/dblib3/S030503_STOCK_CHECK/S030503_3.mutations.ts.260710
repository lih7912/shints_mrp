                `;
                const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL5));
                tSQLArray.push(tSQL99_1);

                var tSQL4 = `
                    update ksv_stock_matl
                    set
                        remain_qty = remain_qty - ${tUseQty},
                        use_qty = use_qty + ${tUseQty}
