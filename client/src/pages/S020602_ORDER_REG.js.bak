    const onCheckboxChangeEDT_KSV_ORDER_MST_IS_COMBINED = (e, name) => {
        let val = "";
        let _dataEDT_KSV_ORDER_MST = { ...dataEDT_KSV_ORDER_MST };
        if (e.checked) {
            val = "1";
            // _dataEDT_KSV_ORDER_MST.IS_SAMPLE = '0';
            // _dataEDT_KSV_ORDER_MST.IS_COMBINED = '0';
            _dataEDT_KSV_ORDER_MST.IS_FACTORY_FOB = "0";
            _dataEDT_KSV_ORDER_MST.IS_EXPECTED = "0";
        } else {
            val = "0";
        }
        if (val === "1" && datasTBL_KSV_ORDER_MST.length > 0) {
            var tOne = { ...datasTBL_KSV_ORDER_MST[0] };
            if (parseFloat(tOne.ORDER_QTY) > 0) {
                alert(
                    "수량이 있는 Normal Order는 Combined Order로 변경불가합니다. Reset후 다시 등록하세요",
                );
                val = "0";
            }
        }
        if (val === "0" && datasTBL_KSV_ORDER_MST.length > 1) {
            alert(
                "Combined Order가 등록된 Order의 Type인 변경 불가합니다. Reset후 다시 등록하세요",
            );
            val = "1";
        }
        _dataEDT_KSV_ORDER_MST[`${name}`] = val;
        setDataEDT_KSV_ORDER_MST(_dataEDT_KSV_ORDER_MST);

        if (val === "1") set_styleVal_combine_Y();
        else set_styleVal_combine_N();

        if (datasTBL_KSV_ORDER_MST.length > 0) {
            if (val === "1") {
                var tArray = [...datasTBL_KSV_ORDER_MST];
                var tObj0 = { ...tArray[0] };
                tObj0.BUYER_PO = "Combined Order";
                tArray[0] = { ...tObj0 };
                setDatasTBL_KSV_ORDER_MST(tArray);
                setDataTBL_KSV_ORDER_MST(tObj0);
            } else {
                var tArray = [...datasTBL_KSV_ORDER_MST];
                var tObj0 = { ...tArray[0] };
                tObj0.BUYER_PO = "";
                tArray[0] = { ...tObj0 };
                setDatasTBL_KSV_ORDER_MST(tArray);
                setDataTBL_KSV_ORDER_MST(tObj0);
            }
        }
    };

