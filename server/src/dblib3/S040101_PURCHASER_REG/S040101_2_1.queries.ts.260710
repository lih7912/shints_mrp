                tDatas.push(tObj);
            });

            const vendors: string[] = [];
            for (const row of tRet1) {
                const cd = row.VENDOR_CD;
                if (cd && vendors.indexOf(cd) === -1) vendors.push(cd);
            }

            const poCds: string[] = [];
            for (const row of tRet1) {
                const cd = row.PO_CD;
                if (cd && poCds.indexOf(cd) === -1) poCds.push(cd);
            }

            var puRows = [];
            if (vendors.length > 0) {
