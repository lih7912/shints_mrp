                    e.factory_name,
                    f.buyer_name,
                    a.order_status
                    -- isnull(g.won_amt2, 0) as usd_rate,
                    -- a.curr_cd
                from
                    ksv_order_mst a
                    left join kcd_currency g on g.curr_cd = a.curr_cd
                    and g.start_date = (
                        select
                            min(start_date)
                        from
                            kcd_currency
                        where
                            curr_cd = a.curr_cd
                    )
                    left join ksv_order_ship b on b.order_cd = a.order_cd
                    and b.ship_ptype in ('0', '5')
                    left join (
                        select
                            order_cd,
                            sum(ship_cnt) as ship_cnt
                        from
                            ksv_order_ship
                        where
                            ship_ptype in ('0', '5')
                        group by
                            order_cd
                    ) d on d.order_cd = a.order_cd,
                    kcd_style c,
