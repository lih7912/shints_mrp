    const onDropdownChangeEDT_KSV_ORDER_MST1_CURR_CD = (e, name) => {
        let val = (e.value && e.value.CD_CODE) || "";

        let _dataEDT_KSV_ORDER_MST1 = { ...dataEDT_KSV_ORDER_MST1 };

        var bef_CURR_CD = _dataEDT_KSV_ORDER_MST1.CURR_CD;

        let tTypeVal = _dataEDT_KSV_ORDER_MST1[`${name}`];
        if (typeof tTypeVal === "string" && typeof val === "string") {
            _dataEDT_KSV_ORDER_MST1[`${name}`] = String(val);
        } else if (typeof tTypeVal === "number" && typeof val === "string") {
            _dataEDT_KSV_ORDER_MST1[`${name}`] = parseInt(val);
        }

        console.log(saveCurrency);

        if (datasTBL_KSV_ORDER_MEM3.length <= 0) {
            if (saveCurrency.length <= 0) {
                setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
                setDataEDT_KSV_ORDER_MST1_CURR_CD(e.value);
            } else {
                var objPrice = {};
                saveCurrency.forEach((col11, i11) => {
                    if (col11.CURR_CD === val) objPrice = { ...col11 };
                });

                if (val === "USD") {
                    _dataEDT_KSV_ORDER_MST1.FOB =
                        _dataEDT_KSV_ORDER_MST1.FOB_USD;
                } else {
                    var tPrice =
                        parseFloat(_dataEDT_KSV_ORDER_MST1.FOB_USD) /
                        parseFloat(objPrice.USD_RATE);
                    if (val === "KRW") tPrice = parseFloat(tPrice).toFixed(0);
                    else tPrice = parseFloat(tPrice).toFixed(4);
                    _dataEDT_KSV_ORDER_MST1.FOB = tPrice;
                }
                setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
                setDataEDT_KSV_ORDER_MST1_CURR_CD(e.value);

                tArray = [];
                datasTBL_KSV_ORDER_MEM.forEach((col, i) => {
                    var tObj = { ...col };
                    tObj.PRICE = _dataEDT_KSV_ORDER_MST1.FOB;
                    tArray.push(tObj);
                });
                setDatasTBL_KSV_ORDER_MEM(tArray);
            }
        } else {
            // Price 변경
            var objPrice = {};
            saveCurrency.forEach((col11, i11) => {
                if (col11.CURR_CD === bef_CURR_CD) objPrice = { ...col11 };
            });

            var tSrcAmt =
                parseFloat(_dataEDT_KSV_ORDER_MST1.FOB.replace(/,/g, "")) *
                parseFloat(objPrice.USD_RATE); // SRC Curr-> USD 금액으로

            objPrice = {};
            saveCurrency.forEach((col11, i11) => {
                if (col11.CURR_CD === val) objPrice = { ...col11 };
            });
            var tDestAmt = tSrcAmt / parseFloat(objPrice.USD_RATE); // Src USD -> Dest Curr 금액으로

            if (val === "KRW") tDestAmt = parseFloat(tDestAmt).toFixed(0);
            else tDestAmt = parseFloat(tDestAmt).toFixed(4);
            _dataEDT_KSV_ORDER_MST1.FOB = tDestAmt;

            setDataEDT_KSV_ORDER_MST1(_dataEDT_KSV_ORDER_MST1);
            setDataEDT_KSV_ORDER_MST1_CURR_CD(e.value);

            search_GET_CURR_DATA(e.value.CD_CODE);

            var tArray = [];
            datasTBL_KSV_ORDER_MEM3.forEach((col, i) => {
                var tObj = { ...col };
                tObj.SALES_PRICE = tDestAmt;
                tObj.CURR_CD = val;
                tArray.push(tObj);
            });
            setDatasTBL_KSV_ORDER_MEM3(tArray);

            tArray = [];
            datasTBL_KSV_ORDER_MEM.forEach((col, i) => {
                var tObj = { ...col };
                tObj.PRICE = _dataEDT_KSV_ORDER_MST1.FOB;
                tArray.push(tObj);
            });
            setDatasTBL_KSV_ORDER_MEM(tArray);
        }
    };

