                s_diff += tObj.diff;
            });

            var tObjTot = {
                ...tRetSumShip[0],
            };
            tObjTot.title = 'TOTAL';
            tObjTot.ship_cnt = s_ship_cnt;
            tObjTot.ord_amt = s_ord_amt;
