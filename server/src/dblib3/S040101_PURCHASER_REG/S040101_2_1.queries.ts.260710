            }

            // START

            var tSql1 = `
                select
                    top 1000 f3.BUYER_NAME,
                    f3.BUYER_CD,
                    a.PO_CD,
                    f2.VENDOR_NAME,
                    b.VENDOR_CD,
                    f2.VENDOR_MATL_TYPE,
                    f2.VENDOR_TYPE,
