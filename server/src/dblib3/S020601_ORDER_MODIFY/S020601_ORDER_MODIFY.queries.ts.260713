                    and c.style_cd = b.style_cd
                    and c.buyer_cd = a.buyer_cd
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.BUYER = tRet;

            let sqlStr = `
                SELECT
                    *
                FROM
                    KCD_BUYER
                where
                    buyer_cd = '${tBuyerCd}'
            `;
            var tRet = await prisma.$queryRaw(Prisma.raw(sqlStr));
            tWRet.CODE_BUYER_CD = tRet;
            let tBuyerCd0 = {};
            tBuyerCd0.BUYER_CD = ' ';
            tBuyerCd0.BUYER_NAME = ' ';
