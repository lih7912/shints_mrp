            delete global.currentTransactionInfo;
        } catch (e) {
            var tRetArray = [];
            var tObj = {};
            tObj.CODE = 'ERROR:REVISE CHANGE';
            tObj.id = 0;
            tRetArray.push(tObj);
            var tRet4 = AFLib2.CommonFunc.DeleteMrpWork(
                tUserInfo.USER_ID,
                tInput1.PO_CD,
            );
            return tRetArray;
        }
        */

        //  Reason Update
        // tSQLArray = [];
        let tSQL99 = `
            delete ksv_po_reason
            where
                po_cd = '${tInputObj.PO_CD}'
                and po_seq = '${tNewPoSeq}'
        `;
        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
        tSQLArray.push(tSQL99_1);

        var tSeqComment = String(tInput1.SEQ_COMMENT || '').replace(
            /'/gi,
            "''",
        );
        var tSeqReason = String(tInput1.SEQ_REASON || '').substring(0, 2);
        var tBuyerChk = String(tInput1.BUYER_CHK || '0').substring(0, 1);
        var tSalesChk = String(tInput1.SALES_CHK || '0').substring(0, 1);
        var tMatlChk = String(tInput1.MATL_CHK || '0').substring(0, 1);
        var tCadChk = String(tInput1.CAD_CHK || '0').substring(0, 1);
        var tMrpChk = String(tInput1.MRP_CHK || '0').substring(0, 1);
        var tMrp2Chk = String(tInput1.MRP2_CHK || '0').substring(0, 1);
        var tEtcChk = String(tInput1.ETC_CHK || '0').substring(0, 1);
        var tApproval = String(tInput1.APPROVAL || '0').substring(0, 1);

        let tSQL99 = `
            insert into
                ksv_po_reason (
                    po_cd,
                    po_seq,
                    buyer,
                    sales,
                    matl,
                    cad,
                    mrp,
                    mrp2,
                    etc,
                    seq_reason,
                    seq_comment,
                    approval,
                    reg_user,
                    reg_datetime
                )
            values
                (
                    '${tInputObj.PO_CD}',
                    '${tNewPoSeq}',
                    '${tBuyerChk}',
                    '${tSalesChk}',
                    '${tMatlChk}',
                    '${tCadChk}',
                    '${tMrpChk}',
                    '${tMrp2Chk}',
                    '${tEtcChk}',
                    '${tSeqReason}',
                    '${tSeqComment}',
                    '${tApproval}',
                    '${tUserInfo.USER_ID}',
                    '${tRetDate}'
                )
        `;
        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
        tSQLArray.push(tSQL99_1);

        let tSQL99 = `
            update ksv_po_mrp
            set
                seq_comment = '${tSeqComment}'
            where
                po_cd = '${tInputObj.PO_CD}'
                and po_seq = '${tNewPoSeq}'
        `;
        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
        tSQLArray.push(tSQL99_1);

        // Insert Po Vendor
        let tSQL99 = `
            insert into
                ksv_po_vendor (po_cd, vendor_cd, end_date)
            select distinct
                a.po_cd,
                c.vendor_cd,
                ''
            from
                ksv_po_mrp a,
                kcd_matl_mst b,
                kcd_vendor c
            where
                a.po_cd = '${tInputObj.PO_CD}'
                and a.use_po_type = '1'
                and a.diff_po_type <> '1'
                and b.matl_cd = a.matl_cd
                and c.vendor_cd = b.vendor_cd
                and c.vendor_cd not in (
                    select
                        vendor_cd
                    from
                        ksv_po_vendor
                    where
                        po_cd = '${tInputObj.PO_CD}'
                )
        `;
        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
        tSQLArray.push(tSQL99_1);

        var tSQL_req_status = `
            update ksv_po_mst
            set
                req_status = ''
            where
                po_cd = '${tInputObj.PO_CD}'
        `;
        var tRet_req_status = await prisma.$queryRaw(
            Prisma.raw(tSQL_req_status),
        );

        try {
            global.currentTransactionInfo = {
                contextValue: contextValue,
                functionName: AFLib.getFunctionName(),
            };
            await prisma.$transaction(tSQLArray);
            delete global.currentTransactionInfo;
            var tRetArray = [];
            var tObj = {};
            tObj.CODE = `SUCCESS:REVISE CHANGE:${tInputObj.PO_CD}:${tNewPoSeq}`;
            tObj.id = 0;
            tRetArray.push(tObj);

            var tRet4 = AFLib2.CommonFunc.DeleteMrpWork(
                tUserInfo.USER_ID,
                tInputObj.PO_CD,
            );

            return tRetArray;
        } catch (e) {
            var tRetArray = [];
            var tObj = {};
            tObj.CODE = 'ERROR:REVISE CHANGE';
            tObj.id = 0;
            tRetArray.push(tObj);

            var tRet4 = AFLib2.CommonFunc.DeleteMrpWork(
                tUserInfo.USER_ID,
                tInputObj.PO_CD,
            );
            return tRetArray;
        }
    }
}

