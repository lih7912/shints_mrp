                            `;
                            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL3));
                            tSQLArray.push(tSQL99_1);
                        }
                    }
                } else {
                    var tCheck2 = 0;
                    if (
                        parseFloat(stockMatlObj.STOCK_QTY) - parseFloat(upCancelQty) >= 0
                    )
                        tCheck2 = 1;

                    tCheck2 = 0; // 수정시까지 Stock Out 처리안함

                    var sql887 = `
