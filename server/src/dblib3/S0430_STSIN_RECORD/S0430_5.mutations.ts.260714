                // tSQLArray = [];

                // New Mrp Seq
                let sqlNewMrpSeq = `
                    select
                        po_cd,
                        isnull(max(mrp_seq), 0) as max_mrp_seq
                    from
                        ksv_po_mrp
                    where
                        po_cd in (${poCdSql})
                        and matl_cd = '${mainObj.MATL_CD}'
                    group by
                        po_cd
                `;
                let retNewMrpSeq = await prisma.$queryRaw(
                    Prisma.raw(sqlNewMrpSeq),
                );

                // StockMem2 체크: Purchase 미등록
                let chkStockMem2 = `
                    select
                        *
                    from
                        ksv_stock_mem2
                    where
                        po_cd in (${poCdSql})
                        and matl_cd = '${mainObj.MATL_CD}'
                        and pu_cd = '${mainObj.PU_CD}'
                `;
                let retStockMem2 = await prisma.$queryRaw(
                    Prisma.raw(chkStockMem2),
                );
                if (retStockMem2.length <= 0) {
                    var tRetArray = [];
                    var tObj = {};
                    tObj.CODE = `ERROR:In Purchase Manager, search for [${mainObj.PU_CD}/${mainObj.MATL_CD}] and click Save to save the changes and then proceed with sts-in. `;
                    tObj.id = 0;
                    tRetArray.push(tObj);
                    return tRetArray;
                }

                // Stock Mem의 Pu Update 처리
                let sqlUpdatePu = `
                    update a
                    set
                        pu_cd = '${mainObj.PU_CD}'
                    from
                        ksv_stock_mem a,
                        kcd_matl_mst b,
                        kcd_vendor c
                    where
                        a.matl_cd = b.matl_cd
                        and b.vendor_cd = c.vendor_cd
                        and a.po_cd in (
                            select distinct
                                po_cd
                            from
                                ksv_stock_mem2
                            where
                                pu_cd = '${mainObj.PU_CD}'
                        )
                        and b.vendor_cd = (
                            select
                                vendor_cd
                            from
                                ksv_pu_mst2
                            where
                                pu_cd = '${mainObj.PU_CD}'
                        )
                        and a.matl_cd in ('${mainObj.MATL_CD}')
                        and (
                            a.pu_cd is null
                            or a.pu_cd = ''
                        )
                `;
                let retUpdatePu = await prisma.$queryRaw(
                    Prisma.raw(sqlUpdatePu),
                );

                // 정상 STS-IN 처리
                var saveObj = {};
                let sqlStockMem = `
                    select
                        a.*,
                        b.LC_FLAG,
                        b.DEPOSIT_RATE,
                        b.CURR_CD as CURR_CD2,
                        b.VENDOR_CD,
                        c.PO_PRICE as PO_PRICE2
                    from
                        ksv_stock_mem a,
                        ksv_pu_mst2 b,
                        ksv_stock_mem2 c
                    where
                        a.po_cd in (${poCdSql})
                        and a.pu_cd = '${mainObj.PU_CD}'
                        and a.pu_cd = b.pu_cd
                        and a.matl_cd = '${mainObj.MATL_CD}'
                        and a.po_cd = c.po_cd
                        and a.matl_cd = c.matl_cd
                        and a.pu_cd = c.pu_cd
                        -- and    (a.po_seq < 97 or a.po_seq > 99)
                        and (a.po_qty - a.in_qty) > 0
                        and a.po_qty > 0
                        and c.reg_datetime = (
                            select
                                max(reg_datetime)
                            from
                                ksv_stock_mem2
                            where
                                a.po_cd = po_cd
                                and a.matl_cd = matl_cd
                                and a.pu_cd = pu_cd
                        )
                    order by
                        a.po_cd,
                        a.order_cd
                `;
                let retStockMem = await prisma.$queryRaw(
                    Prisma.raw(sqlStockMem),
                );

                if (retStockMem.length <= 0) {
                    let sqlStockMem_9 = `
                        select
                            a.*,
                            b.LC_FLAG,
                            b.DEPOSIT_RATE,
                            b.CURR_CD as CURR_CD2,
                            b.VENDOR_CD,
                            c.PO_PRICE as PO_PRICE2
                        from
                            ksv_stock_mem a,
                            ksv_pu_mst2 b,
                            ksv_stock_mem2 c
                        where
                            a.po_cd in (${poCdSql})
                            and a.pu_cd = '${mainObj.PU_CD}'
                            and a.pu_cd = b.pu_cd
                            and a.matl_cd = '${mainObj.MATL_CD}'
                            and a.po_cd = c.po_cd
                            and a.matl_cd = c.matl_cd
                            and a.pu_cd = c.pu_cd
                            and (
                                a.po_seq < 97
                                or a.po_seq > 99
                            )
                            and a.po_qty > 0
                            and (
                                b.curr_cd is not null
                                and b.curr_cd <> ''
                            )
                            and c.reg_datetime = (
                                select
                                    max(reg_datetime)
                                from
                                    ksv_stock_mem2
                                where
                                    a.po_cd = po_cd
                                    and a.matl_cd = matl_cd
                                    and a.pu_cd = pu_cd
                            )
                        order by
                            a.po_cd,
                            a.order_cd
                    `;
                    let retStockMem_9 = await prisma.$queryRaw(
                        Prisma.raw(sqlStockMem_9),
                    );
                    if (retStockMem_9.length > 0) {
                        saveObj = { ...retStockMem_9[0] };
                        if (!saveObj.CURR_CD)
                            saveObj.CURR_CD = saveObj.CURR_CD2;
                    }
                } else {
                    saveObj = { ...retStockMem[0] };
                }
                mainObj.BUYER_CD = saveObj.ORDER_CD.substring(0, 2);
                mainObj.VENDOR_CD = saveObj.VENDOR_CD;

                console.log(
                    `===========>정상 StsIn : (2) ${mainObj.PO_CD}/${mainObj.MATL_CD}/${retStockMem.length}/${remainPoQty}/${remainPoQtyFoc}`,
                );
                var totalInFocQty = 0;
                var idxStockMem = 0;

                for (
                    idxStockMem = 0;
                    idxStockMem < retStockMem.length;
                    idxStockMem++
                ) {
                    if (remainPoQty <= 0 && remainPoQtyFoc <= 0) continue;

                    var obj1 = { ...retStockMem[idxStockMem] };
                    var col0 = { ...retStockMem[idxStockMem] };
                    if (obj1.CURR_CD === '') obj1.CURR_CD = obj1.CURR_CD2;
                    if (col0.CURR_CD === '') col0.CURR_CD = col0.CURR_CD2;
                    if (idxStockMem === 0) saveObj = { ...col0 };

                    var tInQty0 =
                        parseFloat(obj1.PO_QTY) - parseFloat(obj1.IN_QTY);
                    console.log(
                        `===========>(3-0) ${tInQty0}/${obj1.PO_QTY}/${obj1.IN_QTY}`,
                    );

                    if (tInQty0 <= 0) continue;

                    var tInQty = 0;
                    var tInQtyFoc = 0;

                    if (remainPoQty > 0) {
                        if (tInQty0 > remainPoQty) {
                            tInQty = remainPoQty;
                            remainPoQty = 0;
                            if (remainPoQtyFoc > 0) {
                                tInQtyFoc = tInQty0 - remainPoQty;
                                if (tInQtyFoc > remainPoQtyFoc) {
                                    tInQtyFoc = remainPoQtyFoc;
                                    remainPoQtyFoc = 0;
                                } else {
                                    remainPoQtyFoc -= tInQtyFoc;
                                }
                            }
                        } else {
                            tInQty = tInQty0;
                            remainPoQty -= tInQty;
                        }
                    } else {
                        if (remainPoQtyFoc > 0) {
                            tInQtyFoc = tInQty0;
                            if (tInQtyFoc > remainPoQtyFoc) {
                                tInQtyFoc = remainPoQtyFoc;
                                remainPoQtyFoc = 0;
                            } else {
                                remainPoQtyFoc -= tInQtyFoc;
                            }
                        }
                    }

                    console.log(
                        `===========>(3) ${obj1.PO_CD}/${obj1.MATL_CD}=>${remainPoQty}/${remainPoQtyFoc}=>${tInQty}/${tInQtyFoc}`,
                    );

                    var tMinOrder = '';
                    if (
                        parseFloat(obj1.PO_SEQ) === 99 ||
                        parseFloat(obj1.PO_SEQ) === 98
                    ) {
                        let sqlMinOrder = `
                            select
                                top 1 order_cd
                            from
                                ksv_po_mem
                            where
                                po_cd = '${obj1.PO_CD}'
                        `;
                        let retMinOrder = await prisma.$queryRaw(
                            Prisma.raw(sqlMinOrder),
                        );
                        if (retMinOrder.length > 0)
                            tMinOrder = retMinOrder[0].order_cd;

                        var tStockStatus = '';
                        if (parseFloat(obj1.PO_SEQ) === 99) tStockStatus = 'N';
                        if (parseFloat(obj1.PO_SEQ) === 98) tStockStatus = 'W';

                        let tSQL99 = `
                            update ksv_stock_matl
                            set
                                stock_status = '${tStockStatus}'
                            from
                                ksv_stock_matl a,
                                ksv_po_mrp b
                            where
                                b.po_cd = '${obj1.PO_CD}'
                                and b.po_seq = '${obj1.PO_SEQ}'
                                and b.order_cd = '${obj1.ORDER_CD}'
                                and b.matl_cd = '${obj1.MATL_CD}'
                                and b.mrp_seq = '${obj1.MRP_SEQ}'
                                and b.stock_idx = a.stock_idx
                                and a.stock_status = 'O'
                        `;
                        const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                        tSQLArray.push(tSQL99_1);
                    }

                    let tSQL99 = `
                        update ksv_stock_mem
                        set
                            in_qty = in_qty + '${tInQty + tInQtyFoc}',
                            stock_status = '1'
                        where
                            po_cd = '${obj1.PO_CD}'
                            and po_seq = '${obj1.PO_SEQ}'
                            and order_cd = '${obj1.ORDER_CD}'
                            and matl_cd = '${obj1.MATL_CD}'
                            and mrp_seq = '${obj1.MRP_SEQ}'
                            and matl_seq = '${obj1.MATL_SEQ}'
                            and pu_cd = '${obj1.PU_CD}'
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    if (parseFloat(obj1.PO_SEQ) === 97) {
                        totalInFocQty += tInQty + tInQtyFoc;
                    }

                    var tBillFlag = '0';
                    var tBillDate = '';
                    var tEndFlag = '0';
                    var tEndDate = '';
                    var tCalcFlag = '0';

                    var tUsdAmt =
                        parseFloat(tInQty) * parseFloat(mainObj.PO_PRICE);
                    var tUsdRate = 1.0;
                    if (obj1.CURR_CD2 !== 'USD') {
                        let tCurrency = `
                            select
                                *
                            from
                                kcd_currency
                            where
                                curr_cd = '${obj1.CURR_CD}'
                                and start_date = '${tRetDate1}'
                        `;
                        let retCurrency = await prisma.$queryRaw(
                            Prisma.raw(tCurrency),
                        );
                        if (retCurrency.length > 0) {
                            tUsdRate = parseFloat(retCurrency[0].USD_RATE);
                        } else {
                            let tCurrency1 = `
                                select
                                    *
                                from
                                    kcd_currency
                                where
                                    curr_cd = '${obj1.CURR_CD}'
                                    and start_date = (
                                        select
                                            max(start_date)
                                        from
                                            kcd_currency
                                        where
                                            curr_cd = '${obj1.CURR_CD}'
                                    )
                            `;
                            let retCurrency1 = await prisma.$queryRaw(
                                Prisma.raw(tCurrency1),
                            );
                            if (retCurrency1.length > 0) {
                                tUsdRate = parseFloat(retCurrency1[0].USD_RATE);
                            }
                        }
                        tUsdAmt = tUsdAmt * tUsdRate;
                    }

                    tLcFlag = '0';
                    if (obj1.LC_FLAG === '1') tLcFlag = '1';
                    else if (parseFloat(obj1.DEPOSIT_RATE) > 0) {
                        tDepositFlag = '1';
                        tDepositRate = parseFloat(obj1.DEPOSIT_RATE);
                    }

                    var tLcQty = 0;
                    var tLcBillNo = '';
                    var tLcConfFlag = '';

                    if (tLcFlag === '1' || tDepositFlag === '1') {
                        let tSQL998_3 = `
                            select
                                isnull(lc_qty, 0) as lc_qty,
                                isnull(pay_report, '') as pay_report,
                                isnull(lc_conf_flag, '') as lc_conf_flag
                            from
                                ksv_stock_in
                            where
                                po_cd = '${col0.PO_CD}'
                                and po_seq = '${col0.PO_SEQ}'
                                and order_cd = '${col0.ORDER_CD}'
                                and matl_cd = '${col0.MATL_CD}'
                                and mrp_seq = '${col0.MRP_SEQ}'
                                and matl_seq = '${col0.MATL_SEQ}'
                                and pu_cd = '${col0.PU_CD}'
                                and lc_qty > 0
                                and in_qty <= 0
                        `;
                        let nRet998_3 = await prisma.$queryRaw(
                            Prisma.raw(tSQL998_3),
                        );
                        if (nRet998_3.length <= 0) {
                        } else {
                            tLcQty = parseFloat(nRet998_3[0].lc_qty);
                            tLcBillNo = nRet998_3[0].pay_report;
                            tLcConfFlag = nRet998_3[0].lc_conf_flag;

                            nRet998_3.forEach((col9, i9) => {
                                tLcQty += parseFloat(col9.lc_qty);
                                tLcBillNo = col9.pay_report;
                                tLcConfFlag = col9.lc_conf_flag;
                            });

                            let tSQL998_4 = `
                                select
                                    in_qty
                                from
                                    ksv_stock_in
                                where
                                    po_cd = '${col0.PO_CD}'
                                    and po_seq = '${col0.PO_SEQ}'
                                    and order_cd = '${col0.ORDER_CD}'
                                    and matl_cd = '${col0.MATL_CD}'
                                    and pu_cd = '${col0.PU_CD}'
                                    and in_qty > 0
                                    and lc_bill_no = '${tLcBillNo}'
                            `;
                            let nRet998_4 = await prisma.$queryRaw(
                                Prisma.raw(tSQL998_4),
                            );

                            var tLcQty1 = 0;
                            nRet998_4.forEach((col4, i4) => {
                                tLcQty1 += parseFloat(col4.in_qty);
                            });

                            console.log(`LC Info: ${tLcQty}/${tLcQty1}`);

                            if (tLcConfFlag !== '1') {
                                var tRetArray = [];
                                var tObj = {};
                                tObj.CODE =
                                    'ERROR:STS IN (Check Deposit&LC Record:Not Confirm) ';
                                tObj.id = 0;
                                tRetArray.push(tObj);
                                return tRetArray;
                            }

                            if (tLcQty1 >= tLcQty) {
                                tLcBillNo = '';
                                tLcQty = 0;
                                tLcConfFlag = '';
                            }
                        }
                    }

                    var wOutQty = 0;
                    if (
                        tInPuMst0.VENDOR_CD === 'V2078' ||
                        tInPuMst0.VENDOR_CD === 'V0228' ||
                        tInPuMst0.VENDOR_CD === 'V2584'
                    ) {
                        wOutQty = tInQty;
                        tEndFlag = '1';
                        tEndDate = tRetDate1;
                        tCalcFlag = '1';
                    }

                    if (tInQty > 0) {
                        let tSQL99 = `
                            insert into
                                ksv_stock_in (
                                    PO_CD,
                                    PO_SEQ,
                                    ORDER_CD,
                                    MATL_CD,
                                    VENDOR_CD,
                                    MRP_SEQ,
                                    MATL_SEQ,
