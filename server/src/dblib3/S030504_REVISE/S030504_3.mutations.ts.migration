class S030504_QRY_COMM {
    async mrpMake(args, contextValue) {
        //
        var tRetDate = AFLib.getCurrTime();
        var tRetDate1 = tRetDate.substring(0, 8);
        var tUserInfo = AFLib.getUserInfo(contextValue);
        var tInputObj = args.datas;

        try {
            const retNetTemp = await mrpMigration.runNetTemp({
                poCd: tInputObj.PO_CD,
                userId: tUserInfo.USER_ID,
            });
            if (!retNetTemp.ok)
                throw new Error(retNetTemp.message || retNetTemp.step);

            var tSQL_GetOrder = `
                select distinct
                    a.ORDER_CD
                from
                    ksv_po_mem a,
                    ksv_order_mst b
                where
                    a.po_cd = '${tInputObj.PO_CD}'
                    and a.order_cd = b.order_cd
                    and b.order_status <> '4'
            `;
            var tRet0 = await prisma.$queryRaw(Prisma.raw(tSQL_GetOrder));
            console.log('get order:' + tRet0.length);

            var tIdx = 0;
            for (tIdx = 0; tIdx < tRet0.length; tIdx++) {
                var tOneObj = tRet0[tIdx];
                var tIsCombined = tOneObj.ORDER_CD.substring(5, 6);

                var tSQL = '';
                if (tIsCombined === 'C') {
                    var tSQL1 = `
                        select
                            a.order_cd
                        from
                            ksv_order_mst a,
                            ksv_po_mem b
                        where
                            b.po_cd = ''
                            and left(a.order_cd, 10) = b.order_cd
                            and a.order_cd like '${tOneObj.ORDER_CD}-%'
                            and b.po_seq = '1'
                        order by
                            1
                    `;
                    var tRet1 = await prisma.$queryRaw(Prisma.raw(tSQL1));

                    var tOrderBaby = '';
                    var tIdx1 = 0;
                    for (tIdx1 = 0; tIdx1 < tRet1.length; tIdx1++) {
                        var tOrderBaby = tRet1[tIdx1].order_cd;
                        const retNetTempZipComb =
                            await mrpMigration.runNetTempZipComb({
                                poCd: tInputObj.PO_CD,
                                userId: tUserInfo.USER_ID,
                                orderCd: tOrderBaby,
                            });
                        if (!retNetTempZipComb.ok)
                            throw new Error(
                                retNetTempZipComb.message ||
                                    retNetTempZipComb.step,
                            );
                    }
                    if (tRet1.length <= 0) {
                        const retNetTempZip1 = await mrpMigration.runNetTempZip(
                            {
                                poCd: tInputObj.PO_CD,
                                userId: tUserInfo.USER_ID,
                                orderCd: tOneObj.ORDER_CD,
                            },
                        );
                        if (!retNetTempZip1.ok)
                            throw new Error(
                                retNetTempZip1.message || retNetTempZip1.step,
                            );
                    }
                } else {
                    const retNetTempZip2 = await mrpMigration.runNetTempZip({
                        poCd: tInputObj.PO_CD,
                        userId: tUserInfo.USER_ID,
                        orderCd: tOneObj.ORDER_CD,
                    });
                    if (!retNetTempZip2.ok)
                        throw new Error(
                            retNetTempZip2.message || retNetTempZip2.step,
                        );
                }
            }

            const retMrpTemp = await mrpMigration.runMrpTemp({
                poCd: tInputObj.PO_CD,
                userId: tUserInfo.USER_ID,
            });
            if (!retMrpTemp.ok)
                throw new Error(retMrpTemp.message || retMrpTemp.step);

            // PoMrpTempBef
            var tSQL_MrpTempBef1 = `
                delete ksv_po_mrptempbef
                where
                    user_id = '${tUserInfo.USER_ID}'
            `;
            var tRet_MrpTempBef1 = await prisma.$queryRaw(
                Prisma.raw(tSQL_MrpTempBef1),
            );

            var tSQL_MrpTempBef2 = `
                insert into
                    ksv_po_mrptempbef (
                        user_id,
                        po_cd,
                        po_seq,
                        order_cd,
                        matl_cd,
                        use_qty,
                        po_qty,
                        bef_po_qty,
                        diff_qty,
                        po_matl_cd
                    )
                select
                    '${tUserInfo.USER_ID}',
                    po_cd,
                    0,
                    order_cd,
                    matl_cd,
                    sum(use_qty),
                    sum(po_qty),
                    sum(po_qty),
                    0,
                    po_matl_cd
                from
                    ksv_po_mrp
                where
                    po_cd = '${tInputObj.PO_CD}'
                    and use_po_type = '1'
                    and po_seq < 97
                group by
                    po_cd,
                    order_cd,
                    matl_cd,
                    po_matl_cd
            `;
            var tRet_MrpTempBef2 = await prisma.$queryRaw(
                Prisma.raw(tSQL_MrpTempBef2),
            );

            const retReCalc = await mrpProcedureService.run('recalc', {
                poCd: tInputObj.PO_CD,
                userId: tUserInfo.USER_ID,
            });
            if (!retReCalc.ok)
                throw new Error(retReCalc.message || retReCalc.step);

            const retReDetail = await mrpProcedureService.run('redetail', {
                poCd: tInputObj.PO_CD,
                userId: tUserInfo.USER_ID,
            });
            if (!retReDetail.ok)
                throw new Error(retReDetail.message || retReDetail.step);

            // GetNewPoSeq
            var sql100 = `
                SELECT
                    (isnull(max(po_seq), 0) + 1) as max_po_seq
                FROM
                    ksv_po_mst
                where
                    po_cd = '${tInputObj.PO_CD}'
                    and po_seq < 97
            `;
            var tRet100 = await prisma.$queryRaw(Prisma.raw(sql100));

            var tNewPoSeq = parseInt(tRet100[0].max_po_seq);
            var tLastPoSeq = tNewPoSeq - 1;

            var tResultSQL = `
                select
                    a.matl_cd,
                    b.matl_name,
                    a.order_cd
                from
                    ksv_po_mrp a,
                    kcd_matl_mst b
                where
                    a.po_cd = '${tInputObj.PO_CD}'
                    and b.matl_cd = a.matl_cd
                    and a.diff_po_type <> '2'
                group by
                    a.matl_cd,
                    b.matl_name,
                    a.order_cd
                having
                    sum(a.use_real_qty) = 0
                order by
                    a.order_cd,
                    a.matl_cd
            `;
            var tResultRet = await prisma.$queryRaw(Prisma.raw(tResultSQL));

            var tReturnStr = '';
            tResultRet.forEach((col, i) => {
                tReturnStr + `${col.matl_cd}.${col.matl_name},${col.order_cd}|`;
            });

            var sql101 = `
                select
                    top 1 seq_comment
                from
                    ksv_po_mrp
                where
                    po_cd = '${tInputObj.PO_CD}'
                    and po_seq = '${tLastPoSeq}'
            `;
            var tRet101 = await prisma.$queryRaw(Prisma.raw(sql101));
            var tSqlComment = '';
            if (tRet101.length > 0) tSqlComment = tRet101[0].seq_comment;

            var tRetArray = [];
            var tObj = {};
            tObj.id = 0;
            tObj.CODE1 = tReturnStr;
            tObj.CODE2 = tSqlComment;
            tObj.NEW_PO_SEQ = String(tNewPoSeq);
            tObj.LAST_PO_SEQ = String(tLastPoSeq);
            tObj.CODE = `SUCCESS:REVISE MAKE:${tInputObj.PO_CD}:${tReturnStr}:${tObj.NEW_PO_SEQ}:${tObj.LAST_PO_SEQ}`;
            tRetArray.push(tObj);

            // Exit Process
            var tRet2 = AFLib2.CommonFunc.UpdateMrpWork(
                tUserInfo.USER_ID,
                tInputObj.PO_CD,
                tObj.CODE,
            );
            return tRetArray;
        } catch (e) {
            var tRetArray = [];
            var tObj = {};
            tObj.CODE = 'ERROR:REVISE MAKE';
            tObj.id = 0;
            tObj.CODE1 = '';
            tObj.CODE2 = '';
            tObj.NEW_PO_SEQ = '';
            tObj.LAST_PO_SEQ = '';
            tRetArray.push(tObj);
            var tRet2 = AFLib2.CommonFunc.UpdateMrpWork(
                tUserInfo.USER_ID,
                tInputObj.PO_CD,
                tObj.CODE,
            );

            return tRetArray;
        }
    }

    async changeProc(args, contextValue) {
        //
        var tDate = new Date();
        var mm = tDate.getMonth() + 1;
        var mm_str = '';
        if (mm > 9) mm_str = mm.toString();
        else mm_str = '0' + mm;

        var dd = tDate.getDate();
        var dd_str = '';
        if (dd > 9) dd_str = dd;
        else dd_str = '0' + dd;

        var hours = tDate.getHours();
        var hours_str = '';
        if (hours > 9) hours_str = hours.toString();
        else hours_str = '0' + hours;

        var minutes = tDate.getMinutes();
        var minutes_str = '';
        if (minutes > 9) minutes_str = minutes.toString();
        else minutes_str = '0' + minutes;

        var seconds = tDate.getSeconds();
        var seconds_str = '';
        if (seconds > 9) seconds_str = seconds.toString();
        else seconds_str = '0' + seconds;

        var yyyy = tDate.getFullYear();

        var tRetDate =
            yyyy.toString() +
            mm_str +
            dd_str +
            hours_str +
            minutes_str +
            seconds_str;
        var tRetDate1 = tRetDate.substring(0, 8);
        var tYY = 'B' + yyyy.toString().substring(2) + '-';

        // let tPO = "POA2022S672";
        var tUserInfo = AFLib.getUserInfo(contextValue);

        /*
      var tSQL = `
          SELECT
              max(A.SEQ) + 1 as max_seq
          FROM
              KSV_ORDER_MST A,
              KCD_STYLE B
          WHERE
              A.STYLE_CD = B.STYLE_CD
              and A.YY = ${tOneMst.YY}
              and B.BUYER_CD = '${tOneMst.BUYER_CD}'
      `;
      var nRet0 = await prisma.$queryRaw(Prisma.raw(tSQL));
      var tRet = nRet0[0];
      var tMaxSeq = tRet.max_seq;
*/

        /*
      let tSQL99 = `
          update ksv_pu_mst2
          set
              pay_type = '${tInput.PAY_TYPE}',
              pay_date = '${tInput.PAY_DATE}'
          where
              pu_cd = '${tInput.PU_CD}'
      `;
      const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
      tSQLArray.push(tSQL99_1);
*/

        var tInput1 = args.datas; // po basic
        var tInputObj = args.datas; // po basic
        var tInput2 = args.datas1; // recalc info
        var tInput3 = args.datas2; // order

        args.datas1.forEach((col, i) => {
            if (parseInt(col.ORDER_STATUS) > 7) {
                var tRetArray = [];
                var tObj = {};
                tObj.CODE =
                    'ERROR:REVISE SAVE:Order statrus END. END order는 추가발주 할수 없습니다';
                tObj.id = 0;
                tRetArray.push(tObj);
                var tRet4 = AFLib2.CommonFunc.DeleteMrpWork(
                    tUserInfo.USER_ID,
                    tInput1.PO_CD,
                );

                return tRetArray;
            }
        });

        var tSQLArray = [];

        var tNewPoSeq = '1';
        var tLastPoSeq = '1';

        tNewPoSeq = String(parseInt(args.datas1[0].PO_SEQ));
        tLastPoSeq = String(parseInt(tNewPoSeq) - 1);
        var sql0 = '';
        var nRet0 = '';
        /*
      var sql0 = `
          select
              (isnull(max(po_seq), 0) + 1) as new_po_seq
          from
              ksv_po_mrp
          where
              po_cd = '${tInput1.PO_CD}'
              and po_seq < 98
      `;
      var nRet0 = await prisma.$queryRaw(Prisma.raw(sql0));
      if (nRet0.length > 0) {
          tNewPoSeq = `${nRet0[0].new_po_seq}`;
          tLastPoSeq = `${nRet0[0].new_po_seq-1}`;
      }
      */

        // 해당 자재가 발주처리되었으면 해당 자제에 대한 Revise불가
        //
        var tIdx1 = 0;
        /*
      for (tIdx1 = 0; tIdx1 < tInput2.length; tIdx1 ++) {
          var tInputOne = tInput2[tIdx1];
          var sql1 = `
              select
                  isnull(max(a.send_datetime), '') as send_datetime
              from
                  ksv_mail_log a,
                  kcd_matl_mst b,
                  kcd_vendor c,
                  ksv_po_mrp d
              where
                  a.po_cd = d.po_cd
                  and d.matl_cd = b.matl_cd
                  and b.vendor_cd = c.vendor_cd
                  and a.vendor_cd = c.vendor_cd
                  and d.po_cd = '${tInput1.PO_CD}'
                  and d.matl_cd = '${tInputOne.MATL_CD}'
                  and a.po_seq = '${tLastPoSeq}'
          `;
          var nRet1 = await prisma.$queryRaw(Prisma.raw(sql1));
          if (nRet1.length > 0 && nRet1[0].send_datetime !== '') {
              var tRetArray = [];
              var tObj = {};
              tObj.CODE = 'ERROR: 이미 발주된 자재는 마지막 시퀀스에 추가할 수 없습니다. 자재부에 문의해주세요.';
              tObj.id = 0; 
              tRetArray.push(tObj);
              var tRet4  = AFLib2.CommonFunc.DeleteMrpWork(tUserInfo.USER_ID, tInput1.PO_CD );
              return (tRetArray);
          }
      }
*/

        // PO_LOG - new Po seq에  ksv_po_log생성
        sql0 = `
            select
                count(po_cd) as cnt1
            from
                ksv_po_log
            where
                po_cd = '${tInput1.PO_CD}'
                and po_seq = '${tNewPoSeq}'
        `;
        nRet0 = await prisma.$queryRaw(Prisma.raw(sql0));
        if (nRet0.length > 0 && nRet0[0].cnt1 > 0) {
            let tSQL99 = `
                delete from ksv_po_log
                where
                    po_cd = '${tInput1.PO_CD}'
                    and po_seq = '${tNewPoSeq}';
                
                insert into
                    ksv_po_log (po_cd, po_seq, reg_user, reg_datetime, fix_flag)
                values
                    (
                        '${tInput1.PO_CD}',
                        '${tNewPoSeq}',
                        '${tUserInfo.USER_ID}',
                        '${tRetDate}',
                        '0'
                    );
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);
        } else {
            let tSQL99 = `
                insert into
                    ksv_po_log (po_cd, po_seq, reg_user, reg_datetime, fix_flag)
                values
                    (
                        '${tInput1.PO_CD}',
                        '${tNewPoSeq}',
                        '${tUserInfo.USER_ID}',
                        '${tRetDate}',
                        '0'
                    );
            `;
            const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
            tSQLArray.push(tSQL99_1);
        }

        try {
            global.currentTransactionInfo = {
                contextValue: contextValue,
                functionName: AFLib.getFunctionName(),
            };
            await prisma.$transaction(tSQLArray);
            delete global.currentTransactionInfo;
        } catch (e) {
            var tRetArray = [];
            var tObj = {};
            tObj.CODE = 'ERROR:REVISE SAVE';
            tObj.id = 0;
            tRetArray.push(tObj);
            var tRet4 = AFLib2.CommonFunc.DeleteMrpWork(
                tUserInfo.USER_ID,
                tInput1.PO_CD,
            );
            return tRetArray;
        }

        var tFactoryCd = '';
        var tPoType = '';
        sql0 = `
            select
                top 1 factory_cd, po_type
            from
                ksv_po_mst
            where
                po_cd = '${tInput1.PO_CD}'
        `;
        nRet0 = await prisma.$queryRaw(Prisma.raw(sql0));
        if (nRet0.length > 0) {
            tFactoryCd = nRet0[0].factory_cd;
            tPoType = nRet0[0].po_type;
        }

        var tNewMrpSeq = 0;
        sql0 = `
             select (isnull(max(mrp_seq), 0) + 1) as max_mrp_seq from ksv_po_mrp 
             where po_cd = '${tInput1.PO_CD}'
        `;
        nRet0 = await prisma.$queryRaw(Prisma.raw(sql0));
        if (nRet0.length > 0) tNewMrpSeq = nRet0[0].max_mrp_seq;

        tIdx1 = 0;
        for (tIdx1 = 0; tIdx1 < tInput2.length; tIdx1++) {
            var tInputOne = tInput2[tIdx1];
            var tInDiffQty = parseFloat(tInputOne.DIFF_QTY);

            // Cancel인 경우 -가 넘어옴
            var tBalQty = parseFloat(tInputOne.DIFF_QTY);
            // if (tInputOne.DIFF_QTY <= 0) continue;

            let sql2 = `
                -- SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 
                select
                    a.po_cd,
                    a.po_seq,
                    a.order_cd,
                    a.matl_cd,
                    a.mrp_seq,
                    a.diff_re_type,
                    a.diff_re_qty,
                    a.bef_po_qty,
                    a.use_stock_qty,
                    a.matl_seq,
                    a.matl_price,
                    a.curr_cd,
                    a.tot_amt,
                    isnull(a.use_size, '') as use_size,
                    a.stock_idx,
                    a.root_idx,
                    a.factory_cd,
                    isnull(a.org_po_seq, '') as org_po_seq,
                    a.po_matl_cd,
                    b.cd_name
                from
                    ksv_po_mrptempre_detail a,
                    kcd_code b
                where
                    a.user_id = '${tUserInfo.USER_ID}'
                    and a.po_cd = '${tInput1.PO_CD}'
                    and a.po_seq = '${tNewPoSeq}'
                    and a.seq = ${tInputOne.SEQ}
                    and a.diff_re_type = b.cd_code
                    and b.cd_group = 'DIFF_RE_TYPE'
                order by
                    5,
                    6
            `;
            let nRet2 = await prisma.$queryRaw(Prisma.raw(sql2));

            var tIdx100 = 0;
            for (tIdx100 = 0; tIdx100 < nRet2.length; tIdx100++) {
                var tIn = { ...nRet2[tIdx100] };

                tSQLArray = [];

                if (tIn.diff_re_type === '3') {
                    // ADD : 1. ksv_po_mrp생성, Ksv_stock_mem 생성
                    var tDiffType = '3';
                    // var tDiffQty = tBalQty;
                    var tDiffQty = parseFloat(tIn.diff_re_qty);
                    if (tDiffQty !== tInDiffQty) tDiffQty = tInDiffQty;

                    var tUsePoType = '1';
                    var tSeqComment = '';
                    var tRemark = '';
                    let tSQL99 = `
                        -- SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 
                        insert into
                            ksv_po_mrp (
                                po_cd,
                                po_seq,
                                order_cd,
                                matl_cd,
                                mrp_seq,
                                matl_seq,
                                matl_price,
                                use_size,
                                use_qty,
                                po_qty,
                                bef_po_qty,
                                diff_qty,
                                diff_po_type,
                                change_reason,
                                use_po_type,
                                curr_cd,
                                tot_amt,
                                curr_date,
                                usd_amt,
                                status_cd,
                                reg_user,
                                reg_datetime,
                                org_po_seq,
                                seq_comment,
                                remark,
                                use_real_qty
                            )
                        values
                            (
                                '${tIn.po_cd}',
                                '${tIn.po_seq}',
                                '${tIn.order_cd}',
                                '${tIn.matl_cd}',
                                '${tNewMrpSeq}',
                                '${tIn.matl_seq}',
                                '${tIn.matl_price}',
                                '${tIn.use_size}',
                                '${tDiffQty}',
                                '${tDiffQty}',
                                '0',
                                '0',
                                '${tDiffType}',
                                '',
                                '${tUsePoType}',
                                '${tIn.curr_cd}',
                                '${tIn.tot_amt}',
                                '${tRetDate1}',
                                '0',
                                '0',
                                '${tUserInfo.USER_ID}',
                                '${tRetDate}',
                                '${tIn.org_po_seq}',
                                '${tSeqComment}',
                                '${tRemark}',
                                '${tDiffQty}'
                            )
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    let tSQL99 = `
                        insert into
                            ksv_stock_mem (
                                po_cd,
                                po_seq,
                                order_cd,
                                matl_cd,
                                mrp_seq,
                                matl_seq,
                                po_qty,
                                in_qty,
                                out_qty,
                                infac_qty,
                                outfac_qty,
                                remain_qty,
                                factory_cd,
                                diff_qty,
                                diff_po_type,
                                stock_status,
                                status_cd,
                                reg_user,
                                reg_datetime
                            )
                        select
                            '${tIn.po_cd}',
                            '${tIn.po_seq}',
                            '${tIn.order_cd}',
                            '${tIn.matl_cd}',
                            '${tNewMrpSeq}',
                            '${tIn.matl_seq}',
                            '${tDiffQty}',
                            '0',
                            '0',
                            '0',
                            '0',
                            '0',
                            '${tFactoryCd}',
                            '0',
                            '0',
                            '0',
                            '0',
                            '${tUserInfo.USER_ID}',
                            '${tRetDate}'
                        where not exists (
                            select 1
                            from ksv_stock_mem a
                            where
                                a.po_cd = '${tIn.po_cd}'
                                and a.po_seq = '${tIn.po_seq}'
                                and a.order_cd = '${tIn.order_cd}'
                                and a.matl_cd = '${tIn.matl_cd}'
                                and a.mrp_seq = '${tNewMrpSeq}'
                                and a.diff_po_type = '0'
                        )
                    `;
                    const tSQL99_1 = prisma.$queryRaw(Prisma.raw(tSQL99));
                    tSQLArray.push(tSQL99_1);

                    tNewMrpSeq += 1;
                } else if (tIn.diff_re_type === '5') {
                    // 재고취소 후 마이너스재고 등록 및 원재고 플러스
                    // ksv_po_mrp 생성 ksv_stock_use생성, ksv_stock_matl update
                    var tDiffType = '5';
                    var tStockCancelQty = parseFloat(tIn.diff_re_qty) * -1;
                    var tDiffQty = parseFloat(tIn.diff_re_qty);

                    var tUsePoType = '2';
                    var tSeqComment = '';
                    var tRemark = '';

                    if (parseFloat(tStockCancelQty) < 0) {
                        var tRetArray = [];
                        var tObj = {};
                        tObj.CODE =
