        </span>
        <span className="af-span-3-0" style={{ width: '10rem' }}>
          <div className="af-span-div" style={{ marginLeft: '0.5rem', display: 'inline-block', width: '9rem' }}>
            <label style={{ marginRight: '0.5rem' }}>
              <input
                type="radio"
                name="dateType"
                checked={dateType === 'request'}
                onChange={() => setDateType('request')}
              />{' '}
